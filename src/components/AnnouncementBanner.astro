---
import { Icon } from "astro-icon/components";

interface Props {
  enabled?: boolean;
  emoji?: string;
  headline: string;
  description?: string;
  linkText?: string;
  linkUrl: string;
  gradientFrom?: string;
  gradientVia?: string;
  gradientTo?: string;
}

const {
  enabled = true,
  emoji = "🎤",
  headline,
  description,
  linkText = "Learn More",
  linkUrl,
  gradientFrom = "cyan-600",
  gradientVia = "blue-600",
  gradientTo = "purple-600",
} = Astro.props;

// Don't render if disabled
if (!enabled) return null;
---

<div class={`bg-gradient-to-r from-${gradientFrom} via-${gradientVia} to-${gradientTo} text-white`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <a 
      href={linkUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4 text-center group"
    >
      <span class="inline-flex items-center gap-2">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
        </span>
        <span class="font-bold text-sm sm:text-base">{emoji} {headline}</span>
      </span>
      {description && (
        <>
          <span class="hidden sm:inline text-white/60">|</span>
          <span class="text-sm text-white/90">{description}</span>
        </>
      )}
      <span class="inline-flex items-center gap-1 text-sm font-medium group-hover:underline">
        {linkText}
        <Icon name="bi:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
      </span>
    </a>
  </div>
</div>

<style>
  /* Safelist gradient classes since Tailwind can't detect dynamic class names */
  .from-cyan-600 { --tw-gradient-from: #0891b2; }
  .via-blue-600 { --tw-gradient-via: #2563eb; }
  .to-purple-600 { --tw-gradient-to: #9333ea; }
  .from-emerald-600 { --tw-gradient-from: #059669; }
  .via-teal-600 { --tw-gradient-via: #0d9488; }
  .to-cyan-600 { --tw-gradient-to: #0891b2; }
  .from-orange-600 { --tw-gradient-from: #ea580c; }
  .via-red-600 { --tw-gradient-via: #dc2626; }
  .to-pink-600 { --tw-gradient-to: #db2777; }
  .from-indigo-600 { --tw-gradient-from: #4f46e5; }
  .via-purple-600 { --tw-gradient-via: #9333ea; }
  .to-pink-600 { --tw-gradient-to: #db2777; }
  .from-red-600 { --tw-gradient-from: #dc2626; }
  .via-red-700 { --tw-gradient-via: #b91c1c; }
  .to-red-800 { --tw-gradient-to: #991b1b; }
</style>
