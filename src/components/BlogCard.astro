---
const { post } = Astro.props;
import { getFormattedDate } from "@utils/all";
const imgSrc = typeof post.data.image === 'string' ? post.data.image : post.data.image?.src;
const imgAlt = typeof post.data.image === 'string' ? post.data.title : (post.data.image?.alt || post.data.title);
---

<a href={`/blog/${post.slug}/`} class="group block transition-transform">
  <div class="aspect-video bg-slate-100 rounded-md overflow-hidden">
    {imgSrc && (
      <img
        src={imgSrc}
        alt={imgAlt}
        width="600"
        height="315"
        class="w-full h-full rounded-md object-cover"
        loading="lazy"
        decoding="async"
      />
    )}
  </div>
  <div class="mt-4">
    <span class="text-blue-400 uppercase tracking-wider text-xs font-medium">
      {post.data.category}
    </span>
    <h2 class="text-xl font-semibold leading-snug tracking-tight mt-1 group-hover:underline">
      {post.data.title}
    </h2>
    <div class="flex gap-2 mt-3 text-sm text-gray-400">
      <span>{post.data.author}</span>
      <span>•</span>
      <time datetime={post.data.publishDate}>
        {getFormattedDate(post.data.publishDate)}
      </time>
    </div>
  </div>
</a>
