---
// src/components/BlogPromoCard.astro
// Mid-article promotional card for books, courses, and services
interface Props {
  variant?: 'book' | 'course' | 'service' | 'newsletter';
}

const { variant = 'book' } = Astro.props;

const promos = {
  book: {
    eyebrow: '📘 Recommended Reading',
    title: 'Ansible For Real-Life Automation',
    description: 'Learn real-world automation patterns used in production environments. Available on Apress and Amazon.',
    cta: 'View Books',
    ctaUrl: '/books/',
    accent: 'border-blue-500',
    bgClass: 'promo-book',
    image: '/blog/promo/book.jpg',
  },
  course: {
    eyebrow: '🎓 Level Up Your Skills',
    title: 'Hands-On Cloud & Automation Courses',
    description: 'Practical courses on Ansible, Kubernetes, and Platform Engineering. 40,000+ students on Udemy, Coursera, and Pluralsight.',
    cta: 'Browse Courses',
    ctaUrl: '/courses/',
    accent: 'border-green-500',
    bgClass: 'promo-course',
    image: '/blog/promo/course.jpg',
  },
  service: {
    eyebrow: '🤝 Need Expert Help?',
    title: 'AI & Cloud Advisory Services',
    description: 'From architecture assessment to hands-on delivery. Let me help your team adopt AI and cloud-native technologies the right way.',
    cta: 'Book a Call',
    ctaUrl: '/contact/',
    accent: 'border-purple-500',
    bgClass: 'promo-service',
    image: '/blog/promo/service.jpg',
  },
  newsletter: {
    eyebrow: '📬 Stay in the Loop',
    title: 'Get Weekly AI & Cloud Insights',
    description: 'Join 2,000+ engineers getting practical tips on AI, Kubernetes, Ansible, and Platform Engineering. No spam, unsubscribe anytime.',
    cta: 'Subscribe Free',
    ctaUrl: 'https://luca-berton.kit.com/ce74a48bfa',
    accent: 'border-amber-500',
    bgClass: 'promo-newsletter',
    image: '/blog/promo/newsletter.jpg',
    external: true,
  },
};

const promo = promos[variant];
---

<aside class={`not-prose my-10 rounded-xl overflow-hidden border-l-4 ${promo.accent}`} role="complementary">
  <a
    href={promo.ctaUrl}
    target={promo.external ? '_blank' : undefined}
    rel={promo.external ? 'noopener' : undefined}
    class="block group"
  >
    <img
      src={promo.image}
      alt={promo.title}
      width="1200"
      height="300"
      loading="lazy"
      decoding="async"
      class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-[1.02]"
    />
    <div class="p-5 sm:p-6 bg-white">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{promo.eyebrow}</p>
      <h4 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-blue-600 transition-colors">{promo.title}</h4>
      <p class="text-sm text-gray-600 mb-3 leading-relaxed">{promo.description}</p>
      <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:text-blue-800 transition-colors">
        {promo.cta}
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </a>
</aside>
