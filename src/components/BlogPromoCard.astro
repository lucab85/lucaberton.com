---
// src/components/BlogPromoCard.astro
// Mid-article promotional card for books, courses, and services
// Books and courses rotate based on the page slug hash for deterministic variety
interface Props {
  variant?: 'book' | 'course' | 'service' | 'newsletter';
}

const { variant = 'book' } = Astro.props;

// --- Books rotation pool (actual covers) ---
const books = [
  {
    title: 'Practical RHEL AI',
    description: 'Designing, Deploying and Scaling AI Solutions with Red Hat Enterprise Linux.',
    cover: '/blog/books/practical_RHEL_AI.jpg',
    buyUrl: 'https://amzn.to/4qjORdC',
    blogUrl: '/practical-rhel-ai/',
  },
  {
    title: 'Kubernetes Recipes',
    description: 'A Practical Guide for Container Orchestration and Deployment.',
    cover: '/blog/thumbnails/kubernetes-recipes-book-cover.jpg',
    buyUrl: 'https://amzn.to/3DzC8QA',
    blogUrl: '/kubernetes-recipes/',
  },
  {
    title: 'Red Hat Enterprise Linux 9 for SysAdmins',
    description: 'A technical guide for building secure production systems using RHEL 9.',
    cover: '/blog/books/9365891175.jpg',
    buyUrl: 'https://amzn.to/4hRsc3Z',
    blogUrl: '/blog/booklist/',
  },
  {
    title: 'Mastering the RHCE Exam',
    description: 'Your complete guide to Linux administration, automation, and certification.',
    cover: '/blog/books/RHCE.jpg',
    buyUrl: 'https://amzn.to/3ZOJ2IM',
    blogUrl: '/blog/booklist/',
  },
  {
    title: 'Red Hat Ansible Automation',
    description: 'Advanced Ansible techniques covering complex playbooks, modules, and integrations.',
    cover: '/blog/books/9355518994.jpg',
    buyUrl: 'https://amzn.to/41K0cbm',
    blogUrl: '/blog/booklist/',
  },
  {
    title: 'Hands-on Ansible Automation',
    description: 'Managing hybrid cloud environments with Ansible and multi-cloud orchestration.',
    cover: '/blog/books/9789355515599.jpg',
    buyUrl: 'https://amzn.to/43HEMuL',
    blogUrl: '/blog/booklist/',
  },
  {
    title: 'Ansible for Kubernetes by Example',
    description: 'Learn how to automate Kubernetes clusters with Ansible.',
    cover: '/blog/books/9781484292853.jpg',
    buyUrl: 'https://amzn.to/3NLCAMB',
    blogUrl: '/blog/booklist/',
  },
  {
    title: 'Ansible for VMware by Examples',
    description: 'Automate VMware environments with Ansible for infrastructure management.',
    cover: '/blog/books/9781484288795.jpg',
    buyUrl: 'https://amzn.to/3XHeDLd',
    blogUrl: '/blog/booklist/',
  },
];

// --- Courses rotation pool ---
const courses = [
  {
    title: 'Federated RAGs with LangChain',
    description: 'Build production-ready Retrieval Augmented Generation pipelines.',
    cover: '/blog/courses/pluralsight-federated-rags.jpg',
    url: '/courses/',
    platform: 'Pluralsight',
  },
  {
    title: 'RAG with LangChain',
    description: 'Master Retrieval Augmented Generation for AI applications.',
    cover: '/blog/courses/pluralsight-rag.jpg',
    url: '/courses/',
    platform: 'Pluralsight',
  },
  {
    title: 'MLOps Fundamentals',
    description: 'Learn machine learning operations for production AI systems.',
    cover: '/blog/courses/coursera-mlops.jpg',
    url: '/courses/',
    platform: 'Coursera',
  },
  {
    title: 'Observability in Cloud',
    description: 'Master observability patterns for cloud-native applications.',
    cover: '/blog/courses/coursera-observability.jpg',
    url: '/courses/',
    platform: 'Coursera',
  },
  {
    title: 'Infrastructure Servers & Security',
    description: 'Secure APIs and back-end infrastructure patterns.',
    cover: '/blog/courses/coursera-infrastructure-servers.jpg',
    url: '/courses/',
    platform: 'Coursera',
  },
  {
    title: 'Root Cause Analysis',
    description: 'Systematic troubleshooting for production systems.',
    cover: '/blog/courses/coursera-rca.jpg',
    url: '/courses/',
    platform: 'Coursera',
  },
  {
    title: 'CI/CD Pipelines',
    description: 'Build and optimize continuous integration and delivery workflows.',
    cover: '/blog/courses/coursera-pipeline.jpg',
    url: '/courses/',
    platform: 'Coursera',
  },
  {
    title: 'Ansible Automation',
    description: 'Complete Ansible course from basics to advanced automation.',
    cover: '/blog/courses/educative-ansible.jpg',
    url: '/courses/',
    platform: 'Educative',
  },
  {
    title: 'Securing Cloud Operations',
    description: 'Cloud security best practices and operational hardening.',
    cover: '/blog/courses/starweaver-securing-cloud-operations.jpg',
    url: '/courses/',
    platform: 'Starweaver',
  },
  {
    title: 'Azure DevTest Labs',
    description: 'Optimize development and testing environments on Azure.',
    cover: '/blog/courses/pluralsight-azure-devtest.jpg',
    url: '/courses/',
    platform: 'Pluralsight',
  },
];

// Deterministic rotation based on URL path
const url = Astro.url.pathname || '';
let hash = 0;
for (let i = 0; i < url.length; i++) {
  hash = ((hash << 5) - hash + url.charCodeAt(i)) | 0;
}
hash = Math.abs(hash);

const book = books[hash % books.length];
const course = courses[hash % courses.length];

// Static promos
const staticPromos = {
  service: {
    eyebrow: '🤝 Need Expert Help?',
    title: 'AI & Cloud Advisory Services',
    description: 'From architecture assessment to hands-on delivery. Let me help your team adopt AI and cloud-native technologies the right way.',
    cta: 'Book a Call',
    ctaUrl: '/contact/',
    accent: 'border-purple-500',
    image: '/blog/promo/service.jpg',
  },
  newsletter: {
    eyebrow: '📬 Stay in the Loop',
    title: 'Get Weekly AI & Cloud Insights',
    description: 'Join 2,000+ engineers getting practical tips on AI, Kubernetes, Ansible, and Platform Engineering. No spam, unsubscribe anytime.',
    cta: 'Subscribe Free',
    ctaUrl: 'https://luca-berton.kit.com/ce74a48bfa',
    accent: 'border-amber-500',
    image: '/blog/promo/newsletter.jpg',
    external: true,
  },
};
---

{variant === 'book' && (
  <aside class="not-prose my-10 rounded-xl overflow-hidden border-l-4 border-blue-500 bg-white shadow-sm" role="complementary">
    <a href={book.blogUrl || book.buyUrl} class="block group">
      <div class="flex flex-col sm:flex-row items-center gap-4 p-5 sm:p-6">
        <img
          src={book.cover}
          alt={`${book.title} book cover`}
          width="120"
          height="160"
          loading="lazy"
          decoding="async"
          class="w-24 sm:w-28 h-auto rounded shadow-md flex-shrink-0 transition-transform duration-300 group-hover:scale-105"
        />
        <div class="text-center sm:text-left">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">📘 By Luca Berton</p>
          <h4 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-blue-600 transition-colors">{book.title}</h4>
          <p class="text-sm text-gray-600 mb-3 leading-relaxed">{book.description}</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:text-blue-800 transition-colors">
            Learn More
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </div>
      </div>
    </a>
  </aside>
)}

{variant === 'course' && (
  <aside class="not-prose my-10 rounded-xl overflow-hidden border-l-4 border-green-500 bg-white shadow-sm" role="complementary">
    <a href={course.url} class="block group">
      <div class="flex flex-col sm:flex-row items-center gap-4 p-5 sm:p-6">
        <img
          src={course.cover}
          alt={`${course.title} course cover`}
          width="200"
          height="120"
          loading="lazy"
          decoding="async"
          class="w-40 sm:w-48 h-auto rounded shadow-md flex-shrink-0 transition-transform duration-300 group-hover:scale-105"
        />
        <div class="text-center sm:text-left">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">🎓 {course.platform} Course</p>
          <h4 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-green-600 transition-colors">{course.title}</h4>
          <p class="text-sm text-gray-600 mb-3 leading-relaxed">{course.description}</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-green-600 group-hover:text-green-800 transition-colors">
            Browse Courses
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </div>
      </div>
    </a>
  </aside>
)}

{variant === 'newsletter' && (() => {
  const promo = staticPromos.newsletter;
  return (
    <aside class={`not-prose my-10 rounded-xl overflow-hidden border-l-4 ${promo.accent} bg-white`} role="complementary">
      <a
        href={promo.ctaUrl}
        target={promo.external ? '_blank' : undefined}
        rel={promo.external ? 'noopener' : undefined}
        class="flex flex-col sm:flex-row items-center gap-5 p-5 sm:p-6 group"
      >
        <img
          src="/blog/promo/newsletter-small.jpg"
          alt={promo.title}
          width="160"
          height="200"
          loading="lazy"
          decoding="async"
          class="w-40 sm:w-48 h-auto rounded shadow-md flex-shrink-0 transition-transform duration-300 group-hover:scale-105"
        />
        <div class="text-center sm:text-left">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{promo.eyebrow}</p>
          <h4 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-blue-600 transition-colors">{promo.title}</h4>
          <p class="text-sm text-gray-600 mb-3 leading-relaxed">{promo.description}</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:text-blue-800 transition-colors">
            {promo.cta}
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </div>
      </a>
    </aside>
  );
})()}

{variant === 'service' && (() => {
  const promo = staticPromos.service;
  return (
    <aside class={`not-prose my-10 rounded-xl overflow-hidden border-l-4 ${promo.accent}`} role="complementary">
      <a
        href={promo.ctaUrl}
        target={promo.external ? '_blank' : undefined}
        rel={promo.external ? 'noopener' : undefined}
        class="block group"
      >
        <img
          src={promo.image}
          alt={promo.title}
          width="1200"
          height="300"
          loading="lazy"
          decoding="async"
          class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        />
        <div class="p-5 sm:p-6 bg-white">
          <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">{promo.eyebrow}</p>
          <h4 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-blue-600 transition-colors">{promo.title}</h4>
          <p class="text-sm text-gray-600 mb-3 leading-relaxed">{promo.description}</p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue-600 group-hover:text-blue-800 transition-colors">
            {promo.cta}
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </div>
      </a>
    </aside>
  );
})()}
