---
export interface Props {
  items: { name: string; url?: string }[];
}

const { items } = Astro.props;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lucaberton.com/" },
    ...items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": item.name,
      ...(item.url ? { "item": `https://lucaberton.com${item.url}` } : {}),
    })),
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-5 pt-6">
  <ol class="flex items-center gap-1 text-sm text-gray-500">
    <li>
      <a href="/" class="hover:text-gray-700 transition">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        <span class="mx-1">/</span>
        {item.url && i < items.length - 1 ? (
          <a href={item.url} class="hover:text-gray-700 transition">{item.name}</a>
        ) : (
          <span class="text-gray-900 font-medium">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
