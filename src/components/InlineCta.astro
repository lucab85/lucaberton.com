---
/**
 * Inline CTA callout for blog posts.
 * Insert in MDX files with: import InlineCta from "@components/InlineCta.astro"
 * Usage: <InlineCta />
 */
interface Props {
  title?: string;
  text?: string;
  ctaText?: string;
  ctaUrl?: string;
}

const {
  title = "Want hands-on help?",
  text = "I help enterprises implement what you just read — from architecture to production. Free 30-minute discovery call.",
  ctaText = "Book a Call with Luca",
  ctaUrl = "https://calendly.com/lucaberton/"
} = Astro.props;
---

<div class="not-prose my-8 p-5 bg-gradient-to-r from-blue-50 to-indigo-50 border-l-4 border-blue-600 rounded-r-xl">
  <p class="font-bold text-gray-900 text-base">{title}</p>
  <p class="text-sm text-gray-600 mt-1">{text}</p>
  <a href={ctaUrl} class="inline-block mt-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-5 rounded-lg text-sm transition-all hover:scale-105 active:scale-95">{ctaText}</a>
</div>
