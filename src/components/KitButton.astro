---
// src/components/KitButton.astro
interface Props {
  formId: string;
  buttonText?: string;
  buttonStyle?: 'primary' | 'secondary' | 'link';
}

const {
  formId,
  buttonText = "Subscribe Now",
  buttonStyle = 'primary'
} = Astro.props;

const formUrl = `https://luca-berton.kit.com/${formId}`;
---

{buttonStyle === 'link' ? (
  <a
    href={formUrl}
    target="_blank"
    rel="noopener"
    class="kit-link"
    data-kit-toggle={formId}
  >
    {buttonText}
  </a>
) : (
  <a
    href={formUrl}
    target="_blank"
    rel="noopener"
    class={`kit-button ${buttonStyle}`}
    data-kit-toggle={formId}
  >
    {buttonText}
  </a>
)}

<style>
  .kit-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 500;
    transition: all 0.2s;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
  }

  .kit-button.primary {
    background-color: #2563eb;
    color: white;
    border: none;
  }

  .kit-button.primary:hover {
    background-color: #1d4ed8;
  }

  .kit-button.secondary {
    background-color: white;
    color: #2563eb;
    border: 2px solid #2563eb;
  }

  .kit-button.secondary:hover {
    background-color: #f8fafc;
  }

  .kit-link {
    color: #2563eb;
    text-decoration: underline;
    cursor: pointer;
  }

  .kit-link:hover {
    color: #1d4ed8;
  }
</style>
