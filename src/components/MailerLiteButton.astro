---
// src/components/MailerLiteButton.astro
interface Props {
  formId: string;
  buttonText?: string;
  buttonStyle?: 'primary' | 'secondary' | 'link';
}

const { 
  formId, 
  buttonText = "Subscribe Now", 
  buttonStyle = 'primary' 
} = Astro.props;
---

{buttonStyle === 'link' ? (
  <a 
    href="javascript:void(0)" 
    class="ml-onclick-form mailer-link" 
    onclick={`ml('show', '${formId}', true)`}
  >
    {buttonText}
  </a>
) : (
  <button 
    class={`ml-onclick-form mailer-button ${buttonStyle}`}
    onclick={`ml('show', '${formId}', true)`}
  >
    {buttonText}
  </button>
)}

<style>
  .mailer-button {
    padding: 0.75rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 500;
    transition: all 0.2s;
    cursor: pointer;
  }

  .mailer-button.primary {
    background-color: #2563eb;
    color: white;
    border: none;
  }

  .mailer-button.primary:hover {
    background-color: #1d4ed8;
  }

  .mailer-button.secondary {
    background-color: white;
    color: #2563eb;
    border: 2px solid #2563eb;
  }

  .mailer-button.secondary:hover {
    background-color: #f8fafc;
  }

  .mailer-link {
    color: #2563eb;
    text-decoration: underline;
    cursor: pointer;
  }

  .mailer-link:hover {
    color: #1d4ed8;
  }
</style>