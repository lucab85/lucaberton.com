---
/**
 * Mermaid Component for rendering diagrams in MDX
 * 
 * Usage in MDX files:
 * 
 * import Mermaid from '../../components/Mermaid.astro';
 * 
 * <Mermaid chart={`
 * flowchart LR
 *   A[Start] --> B{Decision}
 *   B -->|Yes| C[Do something]
 *   B -->|No| D[Do something else]
 *   C --> E[End]
 *   D --> E
 * `} />
 * 
 * Or use code blocks with mermaid language (rendered by the global script):
 * 
 * ```mermaid
 * flowchart TD
 *   A --> B
 * ```
 */

interface Props {
  chart: string;
  caption?: string;
}

const { chart, caption } = Astro.props;
const uniqueId = `mermaid-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="mermaid-wrapper my-8">
  <div class="mermaid" id={uniqueId} data-chart={chart}>
    {chart}
  </div>
  {caption && (
    <p class="text-center text-sm text-gray-500 mt-2 italic">{caption}</p>
  )}
</div>

<style>
  .mermaid-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .mermaid {
    background: #f8fafc;
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    max-width: 100%;
  }
  
  :global(.dark) .mermaid {
    background: #1e293b;
  }
</style>
