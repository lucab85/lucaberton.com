---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl?: string;
}

const { currentPage, totalPages, baseUrl = "/blog" } = Astro.props;

function getPageUrl(pageNum: number): string {
  if (pageNum === 1) return baseUrl;
  return `${baseUrl}/${pageNum}`;
}

// Show max 5 page numbers with ellipsis
function getVisiblePages(current: number, total: number): (number | string)[] {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  
  const pages: (number | string)[] = [];
  
  if (current <= 3) {
    pages.push(1, 2, 3, 4, "...", total);
  } else if (current >= total - 2) {
    pages.push(1, "...", total - 3, total - 2, total - 1, total);
  } else {
    pages.push(1, "...", current - 1, current, current + 1, "...", total);
  }
  
  return pages;
}

const visiblePages = getVisiblePages(currentPage, totalPages);
---

{totalPages > 1 && (
  <nav class="flex justify-center items-center mt-12 gap-2 flex-wrap text-sm" aria-label="Pagination">
    {currentPage > 1 && (
      <a
        href={getPageUrl(currentPage - 1)}
        rel="prev"
        class="px-3 py-2 rounded-md bg-gray-100 hover:bg-gray-200 transition flex items-center gap-1"
        aria-label="Previous page"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Prev
      </a>
    )}

    {visiblePages.map((pageNum) => {
      if (pageNum === "...") {
        return <span class="px-3 py-2 text-gray-400">...</span>;
      }
      
      const isCurrent = pageNum === currentPage;
      return (
        <a
          href={getPageUrl(pageNum as number)}
          aria-current={isCurrent ? "page" : undefined}
          class={`px-3 py-2 rounded-md transition ${
            isCurrent
              ? "bg-blue-500 text-white font-medium"
              : "bg-gray-100 hover:bg-gray-200"
          }`}
        >
          {pageNum}
        </a>
      );
    })}

    {currentPage < totalPages && (
      <a
        href={getPageUrl(currentPage + 1)}
        rel="next"
        class="px-3 py-2 rounded-md bg-gray-100 hover:bg-gray-200 transition flex items-center gap-1"
        aria-label="Next page"
      >
        Next
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    )}
  </nav>
)}

<div class="text-center text-sm text-gray-500 mt-4">
  Page {currentPage} of {totalPages}
</div>
