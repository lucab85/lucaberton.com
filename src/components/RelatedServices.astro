---
/**
 * Auto-suggests relevant service pages based on blog post tags/category.
 * Add to blog post layout to create automatic internal links to service pages.
 */
export interface Props {
  category: string;
  tags: string[];
}

const { category, tags } = Astro.props;
const allTags = [category.toLowerCase(), ...tags.map(t => t.toLowerCase())];

// Map keywords to services
const serviceMatches = [
  {
    keywords: ['ai', 'ml', 'gpu', 'llm', 'rag', 'instructlab', 'rhel-ai', 'openshift-ai', 'mlops', 'deep-learning', 'fine-tuning', 'inference'],
    title: 'AI Integration & GPU Platforms',
    description: 'Need help deploying AI/ML platforms? Get expert consulting on OpenShift AI, GPU orchestration, and MLOps.',
    url: '/services/ai-integration/',
    icon: '🧠',
  },
  {
    keywords: ['kubernetes', 'k8s', 'docker', 'container', 'openshift', 'helm', 'microservices', 'cloud-native'],
    title: 'Kubernetes & Containerization',
    description: 'Master Kubernetes and container orchestration with hands-on workshops and architecture consulting.',
    url: '/services/kubernetes-workshops/',
    icon: '☸️',
  },
  {
    keywords: ['ansible', 'python', 'automation', 'playbook', 'devops', 'ci-cd', 'terraform'],
    title: 'Ansible & Python Training',
    description: 'Level up your automation skills with expert-led Ansible and Python training.',
    url: '/services/ansible-python-training/',
    icon: '🐍',
  },
  {
    keywords: ['cloud', 'aws', 'azure', 'gcp', 'infrastructure', 'networking', 'security', 'cloud-security'],
    title: 'Cloud Infrastructure Design',
    description: 'Build resilient, cost-effective cloud environments with expert architecture consulting.',
    url: '/services/cloud-infrastructure/',
    icon: '☁️',
  },
  {
    keywords: ['strategy', 'platform-engineering', 'finops', 'governance', 'soc2', 'iso27001', 'compliance'],
    title: 'Automation Strategy Consulting',
    description: 'Streamline workflows and build automation strategies that scale.',
    url: '/services/automation-strategy/',
    icon: '⚙️',
  },
];

// Find matching services (max 2)
const matches = serviceMatches
  .map(s => ({
    ...s,
    score: s.keywords.filter(k => allTags.some(t => t.includes(k) || k.includes(t))).length,
  }))
  .filter(s => s.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 2);
---

{matches.length > 0 && (
  <div class="mt-10 p-6 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl border border-blue-100">
    <h3 class="text-lg font-bold text-gray-900 mb-4">
      📌 Need expert help with this topic?
    </h3>
    <div class={`grid gap-4 ${matches.length > 1 ? 'md:grid-cols-2' : ''}`}>
      {matches.map((service) => (
        <a href={service.url} class="group flex items-start gap-3 bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-md transition-all">
          <span class="text-2xl">{service.icon}</span>
          <div>
            <h4 class="font-semibold text-gray-900 group-hover:text-blue-700 transition-colors">
              {service.title}
            </h4>
            <p class="text-sm text-gray-600 mt-1">{service.description}</p>
          </div>
        </a>
      ))}
    </div>
    <p class="text-sm text-gray-500 mt-4 text-center">
      <a href="/contact/" class="text-blue-600 hover:underline font-medium">Book a free consultation →</a>
    </p>
  </div>
)}
