---
/**
 * Sticky bottom CTA bar — shows on scroll, hidden on page load.
 * Mobile-first: compact bar with Calendly booking CTA.
 * Disappears when user scrolls to footer or is near page top.
 */
---

<div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-50 transform translate-y-full transition-transform duration-300 ease-in-out">
  <div class="bg-slate-900/95 backdrop-blur-sm border-t border-slate-700 px-4 py-3">
    <div class="max-w-4xl mx-auto flex items-center justify-between gap-3">
      <div class="hidden sm:block">
        <p class="text-white text-sm font-semibold">Need expert guidance?</p>
        <p class="text-slate-400 text-xs">Free 30-min consultation with Luca Berton</p>
      </div>
      <p class="sm:hidden text-white text-sm font-semibold">Free 30-min AI & Cloud consultation</p>
      <a
        href="https://calendly.com/lucaberton/"
        class="flex-shrink-0 bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-5 rounded-lg text-sm transition-all hover:scale-105 active:scale-95 whitespace-nowrap"
      >
        Book Now
      </a>
    </div>
  </div>
</div>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  if (stickyCta) {
    let lastScrollY = 0;
    let shown = false;

    const update = () => {
      const scrollY = window.scrollY;
      const docHeight = document.documentElement.scrollHeight;
      const winHeight = window.innerHeight;
      const nearBottom = scrollY + winHeight > docHeight - 200;
      const pastThreshold = scrollY > 600;

      if (pastThreshold && !nearBottom && !shown) {
        stickyCta.classList.remove('translate-y-full');
        shown = true;
      } else if ((!pastThreshold || nearBottom) && shown) {
        stickyCta.classList.add('translate-y-full');
        shown = false;
      }
      lastScrollY = scrollY;
    };

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { update(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
