---
// src/components/TableOfContents.astro
// Auto-generated TOC from article headings, shown as a clean summary box
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const tocItems = headings.filter(h => h.depth <= 3);
---

{tocItems.length > 2 && (
  <nav class="not-prose my-8 rounded-xl border border-gray-200 bg-gray-50/80 p-5 sm:p-6" aria-label="Table of contents">
    <details open>
      <summary class="cursor-pointer text-sm font-bold text-gray-700 uppercase tracking-wider select-none flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        In this article
      </summary>
      <ol class="mt-3 space-y-1 text-sm">
        {tocItems.map((h) => (
          <li class={h.depth === 3 ? 'ml-4' : ''}>
            <a
              href={`#${h.slug}`}
              class="text-gray-600 hover:text-blue-600 transition-colors block py-0.5 leading-snug"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </details>
  </nav>
)}
