---
/**
 * Foldable Table of Contents — auto-generated from headings via client JS.
 * Place <TableOfContents /> at the top of any .mdx post.
 */
interface Props {
  open?: boolean;
  maxDepth?: number;
}
const { open = false, maxDepth = 3 } = Astro.props;
---

<nav
  id="toc-nav"
  class="my-6 rounded-xl border border-gray-200 bg-gradient-to-b from-gray-50 to-white overflow-hidden not-prose"
  data-max-depth={maxDepth}
>
  <details {...(open ? { open: true } : {})} class="group">
    <summary class="flex cursor-pointer items-center justify-between gap-2 px-5 py-4 font-bold text-gray-900 hover:bg-gray-100 transition-colors select-none list-none [&::-webkit-details-marker]:hidden text-sm uppercase tracking-wider">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h14"/></svg>
        Table of Contents
      </span>
      <svg class="w-4 h-4 text-gray-400 transition-transform duration-200 group-open:rotate-180 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <ol id="toc-list" class="px-5 pb-4 pt-1 space-y-1 text-sm list-none m-0 border-t border-gray-200">
      <!-- Populated by client JS -->
    </ol>
  </details>
</nav>

<script>
  function buildTOC() {
    const nav = document.getElementById('toc-nav');
    const list = document.getElementById('toc-list');
    if (!nav || !list) return;
    const maxDepth = parseInt(nav.dataset.maxDepth || '3', 10);
    const selector = Array.from({ length: maxDepth }, (_, i) => `article h${i + 2}, .prose h${i + 2}`).join(', ');
    const headings = document.querySelectorAll(selector);
    if (headings.length < 2) { nav.style.display = 'none'; return; }
    headings.forEach((h, i) => {
      if (!h.id) h.id = `heading-${i}`;
      const level = parseInt(h.tagName[1], 10) - 2;
      const li = document.createElement('li');
      li.style.paddingLeft = `${level * 1}rem`;
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent || '';
      a.className = 'text-gray-600 hover:text-blue-600 transition-colors no-underline block py-0.5';
      if (level === 0) a.classList.add('font-medium', 'text-gray-800');
      li.appendChild(a);
      list.appendChild(li);
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', buildTOC);
  } else {
    buildTOC();
  }
</script>
