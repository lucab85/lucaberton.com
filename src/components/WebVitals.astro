---
/**
 * Web Vitals tracking script.
 * Reports CLS, LCP, FID, INP, TTFB, and FCP to console (and optionally to an endpoint).
 * Add to Layout.astro to monitor Core Web Vitals in production.
 * Uses the web-vitals library via CDN (tiny, ~1.5KB).
 */
---

<script is:inline>
  // Lightweight CWV tracking - loads only on interaction (not blocking)
  (function() {
    var loaded = false;
    function loadVitals() {
      if (loaded) return;
      loaded = true;
      
      // Use the web-vitals library for accurate measurement
      import('https://unpkg.com/web-vitals@4/dist/web-vitals.attribution.js?module').then(function(module) {
        function logVital(metric) {
          // Log to console in development
          console.log('[CWV]', metric.name, Math.round(metric.value), metric.rating);
          
          // Optionally send to your analytics endpoint:
          // navigator.sendBeacon('/api/vitals', JSON.stringify({
          //   name: metric.name,
          //   value: metric.value,
          //   rating: metric.rating,
          //   url: window.location.pathname,
          // }));
        }
        
        module.onCLS(logVital);
        module.onFID(logVital);
        module.onLCP(logVital);
        module.onINP(logVital);
        module.onTTFB(logVital);
        module.onFCP(logVital);
      }).catch(function() {
        // Silently fail if web-vitals can't load
      });
    }
    
    // Load after page is interactive (don't block anything)
    if (document.readyState === 'complete') {
      setTimeout(loadVitals, 1000);
    } else {
      window.addEventListener('load', function() {
        setTimeout(loadVitals, 1000);
      });
    }
  })();
</script>
