---
// AnsiblePilot Section - Highlighting Luca's YouTube channel and website
---

<div class="mt-24">
  <div class="mb-8 text-center">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
      Creator of <span class="text-indigo-600">Ansible Pilot</span>
    </h2>
    <p class="text-lg mt-4 text-slate-600">
      The Leading Resource for Ansible Automation Learning
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-6xl mt-12">
    <!-- YouTube Channel Card -->
    <div class="group relative bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-slate-200 hover:border-indigo-400">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-16 h-16 text-red-600" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-slate-900 mb-2">YouTube Channel</h3>
          <p class="text-slate-600 mb-4">
            Step-by-step tutorials, live demos, and practical automation guides
          </p>
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div class="bg-slate-50 p-3 rounded-lg">
              <div class="text-2xl font-bold text-indigo-600">6.1K</div>
              <div class="text-sm text-slate-600">Subscribers</div>
            </div>
            <div class="bg-slate-50 p-3 rounded-lg">
              <div class="text-2xl font-bold text-indigo-600">1M+</div>
              <div class="text-sm text-slate-600">Total Views</div>
            </div>
          </div>
          <a 
            href="https://www.youtube.com/@BertonLuca" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-red-600 font-semibold hover:text-red-700 transition-colors group-hover:gap-3 duration-300">
            Visit YouTube Channel
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Website Card -->
    <div class="group relative bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-slate-200 hover:border-indigo-400">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-16 h-16 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-slate-900 mb-2">AnsiblePilot.com</h3>
          <p class="text-slate-600 mb-4">
            Comprehensive tutorials, books, and resources for Ansible automation mastery
          </p>
          <div class="grid grid-cols-2 gap-4 mb-4">
            <div class="bg-slate-50 p-3 rounded-lg">
              <div class="text-2xl font-bold text-indigo-600">115K</div>
              <div class="text-sm text-slate-600">Active Users/Year</div>
            </div>
            <div class="bg-slate-50 p-3 rounded-lg">
              <div class="text-2xl font-bold text-indigo-600">648K</div>
              <div class="text-sm text-slate-600">Total Users</div>
            </div>
          </div>
          <a 
            href="https://www.ansiblepilot.com/" 
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-indigo-600 font-semibold hover:text-indigo-700 transition-colors group-hover:gap-3 duration-300">
            Visit AnsiblePilot.com
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Content Highlights -->
  <div class="mt-12 bg-gradient-to-br from-indigo-50 to-blue-50 rounded-2xl p-8 max-w-6xl mx-auto">
    <h3 class="text-2xl font-bold text-slate-900 mb-6 text-center">What You'll Find</h3>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 text-indigo-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <h4 class="font-semibold text-slate-900 mb-1">Step-by-Step Tutorials</h4>
          <p class="text-sm text-slate-600">From beginner to advanced automation patterns</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 text-indigo-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        <div>
          <h4 class="font-semibold text-slate-900 mb-1">Video Demonstrations</h4>
          <p class="text-sm text-slate-600">Watch real-world automation in action</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-6 h-6 text-indigo-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        <div>
          <h4 class="font-semibold text-slate-900 mb-1">Expert Resources</h4>
          <p class="text-sm text-slate-600">Books, guides, and best practices</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Bar -->
  <div class="mt-8 max-w-6xl mx-auto">
    <div class="bg-white rounded-xl shadow-md p-6 border border-slate-200">
      <div class="flex flex-wrap justify-around gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-indigo-600">36.2K</div>
          <div class="text-sm text-slate-600 mt-1">Watch Time Hours</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-indigo-600">559K</div>
          <div class="text-sm text-slate-600 mt-1">Sessions (This Year)</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-indigo-600">35+</div>
          <div class="text-sm text-slate-600 mt-1">Countries Reached</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-indigo-600">149K</div>
          <div class="text-sm text-slate-600 mt-1">New Users (This Year)</div>
        </div>
      </div>
    </div>
  </div>
</div>
