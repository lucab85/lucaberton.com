---
const blogPosts = [
  {
    title: "Ansible for Kubernetes by Example",
    description: "Explore practical Ansible use cases to automate Kubernetes cluster operations.",
    url: "https://lucaberton.com/blog/ansible-for-kubernetes-by-example/"
  },
  {
    title: "Ansible for VMware by Examples",
    description: "Step-by-step guide on using Ansible to automate VMware environments.",
    url: "https://lucaberton.com/blog/ansible-for-vmware-by-examples/"
  },
  {
    title: "Hands-on Ansible Automation",
    description: "A comprehensive introduction to real-world Ansible automation practices.",
    url: "https://lucaberton.com/blog/hands-on-ansible-automation/"
  },
  {
    title: "Mastering the Red Hat Certified Engineer (RHCE) Exam",
    description: "Tips, tools, and strategies for acing the RHCE certification exam.",
    url: "https://lucaberton.com/blog/mastering-the-red-hat-certified-engineer-rhce-exam/"
  },
  {
    title: "Red Hat Enterprise Linux 9 for SysAdmins",
    description: "Essential skills and commands for managing RHEL 9 like a pro.",
    url: "https://lucaberton.com/blog/red-hat-enterprise-linux-9-for-sysadmins/"
  }
];
---
<!-- Blog Section -->
<section class="bg-white text-center py-12">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-4xl font-extrabold text-gray-900">Read the Latest Blog Posts</h2>
    <p class="text-lg text-gray-700 mt-4">
      Insights and tutorials on Ansible, RHEL, Kubernetes, and DevOps automation.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mx-auto max-w-7xl mt-10">
    {blogPosts.map((post) => (
      <div class="bg-gray-50 shadow-md rounded-xl p-6 border border-gray-200 hover:border-blue-600 transition-all hover:shadow-lg flex flex-col">
        <h3 class="text-xl font-semibold text-gray-900">{post.title}</h3>
        <p class="text-gray-600 mt-2 text-sm flex-grow">{post.description}</p>
        <div class="mt-4">
          <a href={post.url} class="inline-block text-white bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg shadow-md transition-all">
            Read Article
          </a>
        </div>
      </div>
    ))}
  </div>

  <!-- View All Blogs Button -->
  <div class="mt-10 text-center">
    <a href="/blog" class="inline-block text-blue-600 text-lg font-semibold px-6 py-3 hover:underline transition">
      View All Blog Posts
    </a>
  </div>
</section>

<!-- Existing Book Section -->
<section class="bg-gradient-to-b from-gray-100 to-gray-50 text-center py-12">
