---
import { Picture } from "astro:assets";
import book1 from "assets/books/9781484288795-large.jpg";
import book2 from "assets/books/9781484292853-large.jpg";
import book3 from "assets/books/9789355515599-large.jpg";
import book4 from "assets/books/9355518994-large.jpg";
import book5 from "assets/books/RHCE-large.jpg";
import book6 from "assets/books/9365891175-large.jpg";

const books = [
  {
    title: "Ansible for VMware by Examples",
    description: "Automate VMware environments with Ansible. This book covers all you need to manage your VMware infrastructure with Ansible.",
    author: "Luca Berton",
    thumbnail: book1,
    buylink1: "https://amzn.to/3XHeDLd",
    buylink2: "http://www.dpbolvw.net/click-100752797-12898971?url=https%3A%2F%2Flink.springer.com%2Fbook%2F10.1007%2F978-1-4842-8879-5"
  },
  {
    title: "Ansible for Kubernetes by Example",
    description: "Learn how to automate Kubernetes clusters with Ansible. Streamline your container orchestration processes.",
    author: "Luca Berton",
    thumbnail: book2,
    buylink1: "https://amzn.to/3NLCAMB",
    buylink2: "http://www.dpbolvw.net/click-100752797-12898971?url=https%3A%2F%2Flink.springer.com%2Fbook%2F10.1007%2F978-1-4842-9285-3"
  },
  {
    title: "Hands-on Ansible Automation",
    description: "This book provides insights on managing hybrid cloud environments with Ansible, covering multi-cloud orchestration.",
    author: "Luca Berton",
    thumbnail: book3,
    buylink1: "https://amzn.to/43HEMuL",
    buylink2: "https://bpbonline.com/en-gb/products/hands-on-ansible-automation"
  },
  {
    title: "Red Hat Ansible Automation",
    description: "Deep dive into advanced Ansible techniques, covering complex playbooks, modules, and custom integrations.",
    author: "Luca Berton",
    thumbnail: book4,
    buylink1: "https://amzn.to/41K0cbm",
    buylink2: "https://bpbonline.com/en-gb/products/red-hat-ansible-automation-platform"
  },
  {
    title: "Mastering the Red Hat Certified Engineer (RHCE) Exam",
    description: "Your complete guide to Linux administration, automation, and certification.",
    author: "Luca Berton",
    thumbnail: book5,
    buylink1: "https://amzn.to/3ZOJ2IM",
    buylink2: "https://bpbonline.com/products/mastering-the-red-hat-certified-engineer-rhce-exam"
  },
  {
    title: "Red Hat Enterprise Linux 9 for SysAdmins",
    description: "A technical guide for building secure production systems using RHEL 9 administration.",
    author: "Luca Berton",
    thumbnail: book6,
    buylink1: "https://amzn.to/4hRsc3Z",
    buylink2: "https://bpbonline.com/products/red-hat-enterprise-linux-9-for-sysadmins"
  }
];
---

<div class="text-center py-12">
  <h2 class="text-3xl font-extrabold text-gray-800">Discover Luca's Best-Selling Books</h2>
  <p class="text-lg text-slate-600 mt-4">Practical guides on Ansible, Kubernetes, Cloud Automation, and Hybrid IT Infrastructure.</p>
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mx-auto max-w-7xl">
  {books.map((book) => (
    <div class="bg-white shadow-md p-6 rounded-lg text-center">
      <Picture
        src={book.thumbnail}
        alt={book.title}
        widths={[200, 300, 400]}
        sizes="(max-width: 800px) 100vw, 300px"
        loading="lazy"
        format="avif"
        class="mx-auto h-48 mb-4 rounded object-contain"
      />
      <h3 class="text-xl font-bold text-gray-800">{book.title}</h3>
      <p class="text-gray-600 mt-2">{book.description}</p>
      <a href={book.buylink1} class="text-white bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg mt-4 inline-block shadow-md">Buy on Amazon</a>
      {book.buylink2 && (
        <a href={book.buylink2} class="text-white bg-gray-600 hover:bg-gray-700 px-4 py-2 rounded-lg mt-2 inline-block shadow-md">Alternative Shop</a>
      )}
    </div>
  ))}
</div>
