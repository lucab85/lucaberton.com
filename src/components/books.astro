---
import { Picture } from "astro:assets";
import book1 from "assets/books/9781484288795-large.jpg";
import book2 from "assets/books/9781484292853-large.jpg";
import book3 from "assets/books/9789355515599-large.jpg";
import book4 from "assets/books/9355518994-large.jpg";
import book5 from "assets/books/RHCE-large.jpg";
import book6 from "assets/books/9365891175-large.jpg";
import book7 from "assets/books/KubernetesReceipes.webp";
import book8 from "assets/books/LearnAnsible-large.jpg";
import book9 from "assets/books/practical_RHEL_AI-large.jpg";
import fikaWorksDay2025 from "assets/photos/FikaWorksDay2025.jpg";

const books = [
  {
    title: "Practical RHEL AI",
    description: "Designing, Deploying and Scaling AI Solutions with Red Hat Enterprise Linux.",
    author: "Luca Berton",
    thumbnail: book9,
    buylink1: "https://amzn.to/4qjORdC",
    buylink2: "",
    blogUrl: ""
  },
  {
    title: "Kubernetes Recipes",
    description: "Practical Guide for Container Orchestration and Deployment.",
    author: "Luca Berton & Grzegorz Stencel",
    thumbnail: book7,
    buylink1: "https://amzn.to/3DzC8QA",
    buylink2: "https://link.springer.com/book/9798868813245",
    blogUrl: "https://kubernetes.recipes/"
  },
  {
    title: "Red Hat Enterprise Linux 9 for SysAdmins",
    description: "A technical guide for building secure production systems using RHEL 9 administration.",
    author: "Luca Berton",
    thumbnail: book6,
    buylink1: "https://amzn.to/4hRsc3Z",
    buylink2: "https://bpbonline.com/products/red-hat-enterprise-linux-9-for-sysadmins",
    blogUrl: "/blog/red-hat-enterprise-linux-9-for-sysadmins/"
  },
  {
    title: "Mastering the Red Hat Certified Engineer (RHCE) Exam",
    description: "Your complete guide to Linux administration, automation, and certification.",
    author: "Luca Berton",
    thumbnail: book5,
    buylink1: "https://amzn.to/3ZOJ2IM",
    buylink2: "https://bpbonline.com/products/mastering-the-red-hat-certified-engineer-rhce-exam",
    blogUrl: "/blog/mastering-the-red-hat-certified-engineer-rhce-exam/"
  },
  {
    title: "Red Hat Ansible Automation",
    description: "Deep dive into advanced Ansible techniques, covering complex playbooks, modules, and custom integrations.",
    author: "Luca Berton",
    thumbnail: book4,
    buylink1: "https://amzn.to/41K0cbm",
    buylink2: "https://bpbonline.com/en-gb/products/red-hat-ansible-automation-platform",
    blogUrl: "/blog/red-hat-ansible-automation/"
  },
  {
    title: "Hands-on Ansible Automation",
    description: "This book provides insights on managing hybrid cloud environments with Ansible, covering multi-cloud orchestration.",
    author: "Luca Berton",
    thumbnail: book3,
    buylink1: "https://amzn.to/43HEMuL",
    buylink2: "https://bpbonline.com/en-gb/products/hands-on-ansible-automation",
    blogUrl: "/blog/hands-on-ansible-automation/"
  },
  {
    title: "Ansible for Kubernetes by Example",
    description: "Learn how to automate Kubernetes clusters with Ansible. Streamline your container orchestration processes.",
    author: "Luca Berton",
    thumbnail: book2,
    buylink1: "https://amzn.to/3NLCAMB",
    buylink2: "http://www.dpbolvw.net/click-100752797-12898971?url=https%3A%2F%2Flink.springer.com%2Fbook%2F10.1007%2F978-1-4842-9285-3",
    blogUrl: "/blog/ansible-for-kubernetes-by-example/"
  },
  {
    title: "Ansible for VMware by Examples",
    description: "Automate VMware environments with Ansible. This book covers all you need to manage your VMware infrastructure with Ansible.",
    author: "Luca Berton",
    thumbnail: book1,
    buylink1: "https://amzn.to/3XHeDLd",
    buylink2: "http://www.dpbolvw.net/click-100752797-12898971?url=https%3A%2F%2Flink.springer.com%2Fbook%2F10.1007%2F978-1-4842-8879-5",
    blogUrl: "/blog/ansible-for-vmware-by-examples/"
  },
  {
    title: "Learn Ansible 2nd edition",
    description: "Automate your cloud infrastructure, security configuration, and application deployment with Ansible.",
    author: "Russ McKendrick (Technical review: Luca Berton)",
    thumbnail: book8,
    buylink1: "https://amzn.to/3R6l0Wh",
    buylink2: ""
  }
];
---

<section class="bg-gradient-to-b from-gray-100 to-gray-50 text-center py-12">
  <!-- Featured Conference Photo -->
  <div class="max-w-4xl mx-auto mb-8">
    <Picture
      src={fikaWorksDay2025}
      alt="Fika Works Day 2025"
      widths={[400, 800, 1200]}
      sizes="(max-width: 800px) 100vw, 800px"
      loading="eager"
      formats={['avif', 'webp']}
      class="rounded-lg shadow-lg w-full h-auto"
    />
  </div>

  <div class="max-w-4xl mx-auto">
    <h2 class="text-4xl font-extrabold text-gray-900">Discover Luca's Best-Selling Books</h2>
    <p class="text-lg text-gray-700 mt-4">
      Practical guides on Ansible, Kubernetes, Cloud Automation, and Hybrid IT Infrastructure.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mx-auto max-w-7xl mt-10">
    {books.map((book) => (
      <div class="bg-white shadow-lg rounded-xl p-6 border border-gray-200 hover:border-blue-600 transition-all hover:shadow-xl flex flex-col">
        <Picture
          src={book.thumbnail}
          alt={book.title}
          widths={[200, 300, 400]}
          sizes="(max-width: 800px) 100vw, 300px"
          loading="lazy"
          formats={['avif', 'webp']}
          class="mx-auto w-auto h-56 max-w-full mb-4 rounded-lg object-contain"
        />
        <h3 class="text-lg font-bold text-gray-900">{book.title}</h3>
        <p class="text-gray-500 text-sm">by {book.author}</p>
        <p class="text-gray-600 mt-2 text-sm flex-grow">{book.description}</p>

        <!-- Buttons -->
        <div class="mt-4 flex flex-col gap-3">
          <a href={book.buylink1} class="text-white bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg shadow-md transition-all">
            Buy on Amazon
          </a>
          <!--
          {book.buylink2 && (
            <a href={book.buylink2} class="text-white bg-gray-600 hover:bg-gray-700 px-4 py-2 rounded-lg shadow-md transition-all">
              Alternative Shop
            </a>
          )} -->
          {book.blogUrl && (
            <a href={book.blogUrl} class="text-white bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg shadow-md transition-all">
              Read Blog Post
            </a>
          )}
        </div>
      </div>
    ))}
  </div>

  <!-- View All Books Button -->
  <div class="mt-10 text-center">
    <a href="/books" class="inline-block text-blue-600 text-lg font-semibold px-6 py-3 hover:underline transition">
      View All Books
    </a>
  </div>
</section>
