---
import Button from "./ui/button.astro";
---

<!-- Custom Contact Form for Luca Berton -->
<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="contact-form"
  class="needs-validation p-8 bg-gray-900 text-white rounded-lg shadow-lg"
  novalidate>
  
  <!-- Web3Forms Access Key -->
  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
  <input type="checkbox" class="hidden" style="display:none" name="botcheck" />

  <!-- Full Name -->
  <div class="mb-5">
    <input
      type="text"
      name="name"
      placeholder="Your Full Name"
      required
      class="w-full px-4 py-3 bg-gray-800 border-2 border-gray-700 placeholder-gray-400 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
    />
    <div class="invalid-feedback text-red-400 text-sm mt-1">Please enter your full name.</div>
  </div>

  <!-- Email -->
  <div class="mb-5">
    <input
      type="email"
      name="email"
      placeholder="Your Email Address"
      required
      class="w-full px-4 py-3 bg-gray-800 border-2 border-gray-700 placeholder-gray-400 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
    />
    <div class="invalid-feedback text-red-400 text-sm mt-1">Please provide a valid email address.</div>
  </div>

  <!-- Subject -->
  <div class="mb-5">
    <input
      type="text"
      name="subject"
      placeholder="Subject"
      required
      class="w-full px-4 py-3 bg-gray-800 border-2 border-gray-700 placeholder-gray-400 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
    />
    <div class="invalid-feedback text-red-400 text-sm mt-1">Please enter a subject.</div>
  </div>

  <!-- Message -->
  <div class="mb-5">
    <textarea
      name="message"
      required
      placeholder="Your Message"
      class="w-full px-4 py-3 bg-gray-800 border-2 border-gray-700 placeholder-gray-400 rounded-md h-36 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
    ></textarea>
    <div class="invalid-feedback text-red-400 text-sm mt-1">Please enter your message.</div>
  </div>

  <!-- Submit Button -->
  <Button type="submit" size="lg" block>Send Message</Button>
  
  <div id="result" class="mt-3 text-center text-green-400"></div>
</form>

<style>
  .invalid-feedback {
    display: none;
  }
  .was-validated :invalid ~ .invalid-feedback {
    display: block;
  }
</style>

<script is:inline>
  document.getElementById("contact-form").addEventListener("submit", function (e) {
    e.preventDefault();
    this.classList.add("was-validated");

    if (!this.checkValidity()) {
      this.querySelector(":invalid").focus();
      return;
    }

    const formData = new FormData(this);
    const json = JSON.stringify(Object.fromEntries(formData));

    document.getElementById("result").innerText = "Sending...";

    fetch("https://api.web3forms.com/submit", {
      method: "POST",
      headers: { "Content-Type": "application/json", Accept: "application/json" },
      body: json,
    })
    .then(response => response.json())
    .then(data => {
      document.getElementById("result").innerText = data.message;
      this.reset();
      this.classList.remove("was-validated");
    })
    .catch(() => {
      document.getElementById("result").innerText = "Something went wrong!";
    });
  });
</script>
