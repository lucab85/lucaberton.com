---
import { Picture } from "astro:assets";
import coursera1 from "assets/courses-full/Root Cause Analysis.jpg";
import coursera2 from "assets/courses-full/Microsoft SQL Server Performance Tuning Essentials.jpg";
import coursera3 from "assets/courses-full/API Validation with Postman.jpg";
import coursera4 from "assets/courses-full/Introduction to Chip Design with Open-Source EDA Tools.jpg";
import pluralsight1 from "assets/courses-full/Optimizing Azure DevTest Labs.jpg";
import pluralsight2 from "assets/courses-full/Federated Learning and Privacy-preserving RAGs.jpg";
import pluralsight3 from "assets/courses-full/Evaluating RAG Solutions.jpg";
import educative1 from "assets/courses-full/educative-ansible.jpg";
import udemy1 from "assets/courses-full/udemy-ansible.webp";
import udemy2 from "assets/courses-full/udemy-terraform.webp";

const courses = [
  {
    title: "Root Cause Analysis: Principles and Benefits",
    description: "Principles and Benefits.",
    platform: "Coursera",
    thumbnail: coursera1,
    enrollLink: "https://imp.i384100.net/5grP5L"
  },
  {
    title: "Microsoft SQL Server",
    description: "Performance Tuning Essentials",
    platform: "Coursera",
    thumbnail: coursera2,
    enrollLink: "https://imp.i384100.net/4GJqL1"
  },
  {
    title: "API Validation with Postman",
    description: "Master API validation and testing using Postman.",
    platform: "Coursera",
    thumbnail: coursera3,
    enrollLink: "https://imp.i384100.net/55AxLD"
  },
  {
    title: "Introduction to Chip Design with Open-Source EDA Tools",
    description: "Design and simulate digital circuits using open-source tools.",
    platform: "Coursera",
    thumbnail: coursera4,
    enrollLink: "https://imp.i384100.net/rQMoaR"
  },
  {
    title: "Optimizing Azure DevTest Labs",
    description: "Enhance performance, security, and cost efficiency of Azure DevTest Labs.",
    platform: "Pluralsight",
    thumbnail: pluralsight1,
    enrollLink: "https://pluralsight.pxf.io/099PML"
  },
  {
    title: "Federated Learning and Privacy-preserving RAGs",
    description: "Implement secure AI models using federated learning.",
    platform: "Pluralsight",
    thumbnail: pluralsight2,
    enrollLink: "https://pluralsight.pxf.io/5g2o4o"
  },
  {
    title: "Evaluating RAG Solutions",
    description: "Identifying requirements, choosing the right RAG model, setting up and configuring and testing and optimization",
    platform: "Pluralsight",
    thumbnail: pluralsight3,
    enrollLink: "https://www.pluralsight.com/courses/evaluating-rag-solutions"
  },
  {
    title: "Automating IT Infrastructure with Ansible",
    description: "Learn Ansible to automate IT operations and enhance system reliability.",
    platform: "Educative",
    thumbnail: educative1,
    enrollLink: "https://www.educative.io/courses/automating-it-infrastructure-with-ansible/"
  },
  {
    title: "Learn Ansible Automation in 250+ Examples",
    description: "Comprehensive Ansible training with real-world use cases.",
    platform: "Udemy",
    thumbnail: udemy1,
    enrollLink: "https://www.udemy.com/course/ansible-by-examples-devops/"
  },
  {
    title: "Terraform for Beginners",
    description: "Master Terraform to build scalable infrastructure using IaC principles.",
    platform: "Udemy",
    thumbnail: udemy2,
    enrollLink: "https://www.udemy.com/course/terraform-for-beginners-code-deploy-and-scale/"
  }
];
---

<div class="text-center py-12">
  <h2 class="text-3xl font-extrabold text-gray-800">Explore Luca's Professional Courses</h2>
  <p class="text-lg text-slate-600 mt-4">Advance your career with expert-led training in DevOps, AI, Kubernetes, and Cloud Automation.</p>
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mx-auto max-w-7xl">
  {courses.map((course) => (
    <div class="bg-white shadow-md p-6 rounded-lg text-center">
      <Picture
        src={course.thumbnail}
        alt={course.title}
        widths={[200, 300, 400]}
        sizes="(max-width: 800px) 100vw, 300px"
        loading="lazy"
        format="avif"
        class="mx-auto h-48 mb-4 rounded object-contain"
      />
      <h3 class="text-xl font-bold text-gray-800">{course.title}</h3>
      <p class="text-gray-600 mt-2">{course.description}</p>
      <a href={course.enrollLink} class="text-white bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg mt-4 inline-block shadow-md">
        Enroll Now
      </a>
    </div>
  ))}
</div>
