---
import { Picture } from "astro:assets";
import coursera from "assets/courses/coursera.webp";
import pluralsight from "assets/courses/pluralsight.png";
import educative from "assets/courses/educative.png";
import udemy from "assets/courses/udemy.webp";
import skillshare from "assets/courses/skillshare.webp";

const courses = [
  {
    title: "Kubernetes, Terraform, Ansible, and Linux Trainings",
    description: "Comprehensive training for DevOps professionals in IaC, automation, and container orchestration.",
    platform: "Udemy",
    thumbnail: udemy,
    enrollLink: "https://www.udemy.com/user/luca-berton-3/"
  },
  {
    title: "Root Cause, Back-End Security, MLOps and Troubleshooting",
    description: "Enhance your IT expertise with courses on RCA, MLOps, API security, and advanced troubleshooting.",
    platform: "Coursera",
    thumbnail: coursera,
    enrollLink: "https://www.coursera.org/instructor/~152261633"
  },
  {
    title: "AI, Kubernetes & Ansible Hands-on Courses",
    description: "Deep dive into Kubernetes, AI, and Ansible for advanced automation and infrastructure management.",
    platform: "Pluralsight",
    thumbnail: pluralsight,
    enrollLink: "https://app.pluralsight.com/profile/author/luca-berton"
  },
  {
    title: "Automating IT Infrastructure with Ansible",
    description: "Master Ansible for efficient IT automation and infrastructure management with hands-on lessons.",
    platform: "Educative",
    thumbnail: educative,
    enrollLink: "https://www.educative.io/courses/automating-it-infrastructure-with-ansible/"
  },
  {
    title: "IT Automation with Ansible Quickstart",
    description: "Automate IT tasks, deploy apps, secure systems, and streamline workflows in 40 minutes.",
    platform: "Skillshare",
    thumbnail: skillshare,
    enrollLink: "https://skl.sh/4gzJrFB"
  }
];
---

<section class="bg-white py-16">
  <div class="text-center max-w-4xl mx-auto">
    <h2 class="text-4xl font-extrabold text-gray-900">Elevate Your Skills with World-Class Courses</h2>
    <p class="text-lg text-gray-700 mt-4">
      Upskill with professional video courses in AI, Kubernetes, Ansible, Cloud, and DevOps.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 mx-auto max-w-7xl mt-10">
    {courses.map((course) => (
      <div class="bg-white shadow-lg rounded-xl p-5 border border-gray-200 hover:border-blue-600 transition-all hover:shadow-xl flex flex-col">
        <Picture
          src={course.thumbnail}
          alt={course.title}
          widths={[200, 300, 400]}
          sizes="(max-width: 800px) 100vw, 300px"
          width={300}
          height={160}
          loading="lazy"
          formats={['avif', 'webp']}
          class="mx-auto w-auto h-40 max-w-full mb-4 rounded-lg object-contain"
        />
        <h3 class="text-lg font-bold text-gray-900">{course.title}</h3>
        <p class="text-gray-600 mt-2 text-sm flex-grow">{course.description}</p>
        <a href={course.enrollLink} class="text-white bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg mt-4 inline-block shadow-md transition-all">
          Enroll Now on {course.platform}
        </a>
      </div>
    ))}
  </div>

  <!-- View All Courses Button -->
  <div class="mt-10 text-center">
    <a href="/courses/" class="inline-block text-blue-600 text-lg font-semibold px-6 py-3 hover:underline transition">
      View All Courses
    </a>
  </div>
</section>
