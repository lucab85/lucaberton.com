---
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "AI & Machine Learning",
    description: "Custom AI models and automation solutions to optimize business operations.",
    icon: "bx:bxs-brain",
  },
  {
    title: "Cloud & DevOps",
    description: "Infrastructure as Code, CI/CD pipelines, and cloud-native solutions on AWS, GCP, and Azure.",
    icon: "bx:bxs-cloud",
  },
  {
    title: "Kubernetes & Automation",
    description: "Scalable Kubernetes clusters, Terraform, and Ansible automation for seamless deployment.",
    icon: "bx:bxs-cube",
  },
  {
    title: "Security & Compliance",
    description: "SOC2, ISO27001 compliance and cybersecurity best practices for cloud applications.",
    icon: "bx:bxs-lock",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    AI & Cloud Consulting Solutions
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Expert guidance for your cloud infrastructure, AI-driven automation, and DevOps strategy.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-2 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-blue-700 rounded-full p-2 w-10 h-10 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>
