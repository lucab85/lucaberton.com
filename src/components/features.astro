---
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "AI Integration",
    description: "Implement AI-driven solutions for automation, business intelligence, and data processing.",
    icon: "bx:bxs-brain",
    link: "/services/ai-integration/"
  },
  {
    title: "Ansible & Python Training",
    description: "Master automation with expert-led Ansible and Python custom integration training.",
    icon: "bx:bxl-python",
    link: "/services/ansible-python-training/"
  },
  {
    title: "Automation Strategy",
    description: "Streamline operations with a tailored automation roadmap and implementation plan.",
    icon: "bx:bxs-cog",
    link: "/services/automation-strategy/"
  },
  {
    title: "Cloud Infrastructure",
    description: "Design, deploy, and optimize secure and scalable cloud environments.",
    icon: "bx:bxs-cloud",
    link: "/services/cloud-infrastructure/"
  },
  {
    title: "Kubernetes Workshops",
    description: "Deep dive into Kubernetes for efficient container orchestration and management.",
    icon: "bx:bxs-cube",
    link: "/services/kubernetes-workshops/"
  },
  {
    title: "Performance Optimization",
    description: "Enhance system performance through architecture and tuning best practices.",
    icon: "bx:bxs-rocket",
    link: "/services/performance-optimization/"
  }
];
---

<div class="text-center py-12">
  <h2 class="text-3xl font-extrabold text-gray-800">My Services</h2>
  <p class="text-lg text-slate-600 mt-4">Expert guidance for AI, automation, cloud infrastructure, and Kubernetes.</p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-8 mx-auto max-w-7xl">
  {features.map((item) => (
    <a href={item.link} class="block group">
      <div class="flex gap-4 items-start p-4 rounded-lg transition-shadow shadow-sm hover:shadow-md bg-white">
        <div class="mt-1 bg-blue-700 rounded-full p-3 w-12 h-12 shrink-0 flex items-center justify-center">
          <Icon class="text-white w-6 h-6" name={item.icon} />
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-800 group-hover:text-blue-700">{item.title}</h3>
          <p class="text-gray-600 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    </a>
  ))}
</div>
