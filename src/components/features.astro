---
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "AI Platform Readiness Assessment",
    duration: "2–3 weeks",
    items: [
      "Current infrastructure & integration review",
      "Operational AI/ML readiness audit",
      "Gap analysis with prioritized roadmap",
    ],
    link: "/services/ai-integration/",
  },
  {
    title: "Regulated AI Platform Blueprint",
    duration: "4 weeks",
    items: [
      "Reference architecture for governance-first AI",
      "MLOps pipeline design with policy controls",
      "SOC2/ISO 27001 alignment mapping",
    ],
    link: "/services/automation-strategy/",
  },
  {
    title: "AI Platform Delivery Kit",
    duration: "6–12 weeks",
    items: [
      "Platform architecture, deployment & hardening",
      "GPU orchestration & multi-tenant isolation",
      "Runbooks, IaC, and Day-2 operations handoff",
    ],
    link: "/services/cloud-infrastructure/",
  },
  {
    title: "Compliance & Cost Advisory",
    duration: "Ongoing",
    items: [
      "Monthly cost reviews & optimization measures",
      "Continuous governance & compliance monitoring",
      "Audit preparation & evidence pack delivery",
    ],
    link: "/contact/",
  },
];
---

<section class="py-16 px-6">
  <div class="max-w-6xl mx-auto text-center mb-12">
    <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">
      AI Infrastructure Services for Regulated Enterprises
    </h2>
    <p class="text-lg text-gray-600 mt-4 max-w-3xl mx-auto">
      Start with gap analysis and roadmap, end with an AI platform teams can use — fast.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto">
    {services.map((service) => (
      <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-lg transition-shadow duration-200 flex flex-col">
        <div class="flex-1">
          <h3 class="text-lg font-bold text-gray-900 leading-tight">{service.title}</h3>
          <p class="text-sm text-gray-400 mt-1 font-medium">{service.duration}</p>
          <ul class="mt-4 space-y-2.5">
            {service.items.map((item) => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <svg class="w-4 h-4 text-green-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <a
          href={service.link}
          class="mt-6 inline-flex items-center justify-center px-5 py-2.5 border-2 border-gray-800 text-gray-800 font-semibold rounded-lg hover:bg-gray-800 hover:text-white transition-all duration-200 text-sm">
          Learn More
        </a>
      </div>
    ))}
  </div>
</section>
