---
import { Icon } from "astro-icon/components";
import MailerLiteButton from '@components/MailerLiteButton.astro';

const navLinks = [
  { name: "Case Studies", href: "/case-studies/" },
  { name: "Services", href: "/services/" },
  { name: "Why Me", href: "/about/" },
  { name: "About", href: "/about/" },
  { name: "Articles", href: "/blog/" },
];

const socials = [
  { name: "LinkedIn", icon: "bi:linkedin", url: "https://www.linkedin.com/in/lucaberton/" },
  { name: "YouTube", icon: "bi:youtube", url: "https://www.youtube.com/@BertonLuca" },
  { name: "Instagram", icon: "bi:instagram", url: "https://www.instagram.com/lucaberton/" },
  { name: "Bluesky", icon: "bi:clouds", url: "https://bsky.app/profile/lucaberton.bsky.social" },
];
---

<footer class="bg-gray-900 text-white mt-16">
  <!-- Top bar: Logo + Nav + Social -->
  <div class="max-w-7xl mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-6 border-b border-gray-700">
    <!-- Logo -->
    <div class="flex items-center gap-3">
      <Icon name="bx:bxs-cog" class="w-8 h-8 text-amber-500" />
      <span class="text-xl font-bold">Luca Berton</span>
    </div>

    <!-- Nav Links -->
    <nav class="flex flex-wrap gap-6 text-sm font-medium text-gray-300">
      {navLinks.map((link) => (
        <a href={link.href} class="hover:text-white transition">{link.name}</a>
      ))}
    </nav>

    <!-- Social Icons -->
    <div class="flex gap-4">
      {socials.map((s) => (
        <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition" aria-label={s.name}>
          <Icon name={s.icon} class="w-5 h-5" />
        </a>
      ))}
    </div>
  </div>

  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-2 gap-12">
    <!-- Left: CTA -->
    <div>
      <h2 class="text-2xl lg:text-3xl font-bold leading-tight">
        Boost AI Infrastructure with <span class="text-amber-500">ROI</span> & <span class="text-amber-500">Compliance</span>
      </h2>
      <p class="text-gray-400 mt-4 max-w-md leading-relaxed">
        Schedule a strategic consultation to discuss your current infrastructure challenges
        and explore how to make your AI platform cost effective, fast, and audit ready.
      </p>
      <a
        href="https://calendly.com/lucaberton"
        class="inline-flex items-center justify-center mt-6 px-8 py-3.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-lg shadow-red-600/25 transition-all duration-200 text-base uppercase tracking-wide">
        Schedule Assessment →
      </a>
    </div>

    <!-- Right: Contact -->
    <div class="space-y-3 text-sm text-gray-300">
      <h3 class="text-lg font-semibold text-white mb-4">Contact</h3>
      <p class="flex items-center gap-3">
        <Icon name="bi:linkedin" class="w-4 h-4 text-gray-400" />
        <a href="https://www.linkedin.com/in/lucaberton/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition">@LucaBerton</a>
      </p>
      <p class="flex items-center gap-3">
        <Icon name="bi:envelope" class="w-4 h-4 text-gray-400" />
        <a href="mailto:info@lucaberton.com" class="hover:text-white transition">info@lucaberton.com</a>
      </p>
      <p class="flex items-center gap-3">
        <Icon name="bi:geo-alt" class="w-4 h-4 text-gray-400" />
        <span>KvK: 04979500</span>
      </p>
      <p class="flex items-center gap-3">
        <Icon name="bi:receipt" class="w-4 h-4 text-gray-400" />
        <span>BTW: NL560954899B01</span>
      </p>
    </div>
  </div>

  <!-- Luca Berton Network -->
  <div class="border-t-2 border-blue-500 py-6 px-4 text-center">
    <p class="text-slate-400 text-xs uppercase font-semibold tracking-wider mb-4">🌐 Luca Berton Network</p>
    <div class="flex flex-wrap justify-center gap-2.5 max-w-3xl mx-auto">
      <a href="https://lucaberton.com/" title="AI & Cloud Advisor" class="lb-net-link border-blue-500 bg-blue-950/40">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        Luca Berton
      </a>
      <a href="https://www.ansiblepilot.com/" title="772+ Ansible Tutorials" class="lb-net-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Ansible Pilot
      </a>
      <a href="https://www.ansiblebyexample.com/" title="Ansible Books & Resources" class="lb-net-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Ansible by Example
      </a>
      <a href="https://www.openempower.com/" title="AI Platform Engineering Consultancy" class="lb-net-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        Open Empower
      </a>
      <a href="https://kubernetes.recipes/" title="Kubernetes Recipe Book" class="lb-net-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        K8s Recipes
      </a>
      <a href="https://www.terraformpilot.com/" title="Terraform Automation Mastery" class="lb-net-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        Terraform Pilot
      </a>
      <a href="https://www.copypastelearn.com/" title="Learn IT by Doing" class="lb-net-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        CopyPasteLearn
      </a>
      <a href="https://www.proteinlens.com/" title="AI Macro Nutrition Tracker" class="lb-net-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-[18px] h-[18px] shrink-0"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
        ProteinLens
      </a>
    </div>
  </div>

  <style>
    .lb-net-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #1e293b;
      color: #e2e8f0;
      text-decoration: none;
      padding: 8px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      transition: all 0.2s;
      border: 1px solid #334155;
    }
    .lb-net-link:hover {
      background: #3b82f6;
      border-color: #3b82f6;
      color: #fff;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }
  </style>

  <!-- Bottom bar -->
  <div class="border-t border-gray-700 py-6 px-6 text-center text-xs text-gray-500">
    <p>
      © {new Date().getFullYear()} <a href="https://lucaberton.com" class="hover:underline">Luca Berton</a>. All rights reserved.
      · <a href="/privacy-policy/" class="hover:underline">Privacy Policy</a>
      · <a href="/terms/" class="hover:underline">Terms</a>
      · <a href="/rss.xml" class="hover:underline">RSS</a>
      · <MailerLiteButton formId="b2XchW" buttonText="Newsletter" buttonStyle="link" />
    </p>
  </div>
</footer>
