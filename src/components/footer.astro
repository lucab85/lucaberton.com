---
import { Icon } from "astro-icon/components";

const links = [
  { name: "LinkedIn", icon: "bi:linkedin", url: "https://www.linkedin.com/in/lucaberton/" },
  { name: "YouTube", icon: "bi:youtube", url: "https://www.youtube.com/@BertonLuca" },
  { name: "Medium", icon: "bi:medium", url: "https://medium.com/@lucaberton" },
  { name: "Website", icon: "bi:globe", url: "https://lucaberton.com" },
  { name: "Coursera", icon: "bi:book", url: "https://www.coursera.org/instructor/~152261633" },
  { name: "Pluralsight", icon: "bi:play", url: "https://www.pluralsight.com/authors/luca-berton" },
  { name: "Udemy", icon: "bi:mortarboard", url: "https://www.udemy.com/user/luca-berton-3/" },
  { name: "Educative", icon: "bi:journal-bookmark", url: "https://www.educative.io/courses/automating-it-infrastructure-with-ansible/" },
  { name: "Skillshare", icon: "bi:lightbulb", url: "https://www.skillshare.com/en/r/user/luca-berton" }
];
---

<footer class="my-10 text-center text-sm text-slate-500">
  <!-- Social Media & Course Platforms with Accessible Names -->
  <div class="flex justify-center gap-5 mb-3 flex-wrap" aria-label="Follow Luca Berton on social media and learning platforms">
    {links.map((link) => (
      <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-900 transition"
        aria-label={"Follow Luca Berton on " + link.name}>
        <Icon name={link.icon} class="w-6 h-6" />
        <span class="sr-only">{link.name}</span> <!-- Screen reader text -->
      </a>
    ))}
  </div>

  <!-- Footer Links -->
  <p>
    © {new Date().getFullYear()} <a href="https://lucaberton.com" class="hover:underline">Luca Berton</a>. All rights reserved.
  </p>
  <p>
    <a href="/privacy-policy" class="hover:underline">Privacy Policy</a> ·
    <a href="/terms" class="hover:underline">Terms and Conditions</a>
  </p>
</footer>
