---
import { Icon } from "astro-icon/components";
import KitButton from '@components/KitButton.astro';

const socialLinks = [
  { name: "LinkedIn", icon: "bi:linkedin", url: "https://www.linkedin.com/in/lucaberton/" },
  { name: "YouTube", icon: "bi:youtube", url: "https://www.youtube.com/@BertonLuca" },
  { name: "X", icon: "bi:twitter-x", url: "https://x.com/TheLucaBerton" },
  { name: "Instagram", icon: "bi:instagram", url: "https://www.instagram.com/thelucaberton" },
  { name: "TikTok", icon: "bi:tiktok", url: "https://www.tiktok.com/@thelucaberton" },
  { name: "Bluesky", icon: "bi:clouds", url: "https://bsky.app/profile/lucaberton.bsky.social" },
  { name: "Medium", icon: "bi:medium", url: "https://medium.com/@lucaberton" },
  { name: "Spotify", icon: "bi:spotify", url: "https://creators.spotify.com/pod/show/lucaberton" },
];

const learningPlatforms = [
  { name: "Coursera", icon: "bi:book", url: "https://www.coursera.org/instructor/~152261633" },
  { name: "Pluralsight", icon: "bi:play-circle", url: "https://www.pluralsight.com/authors/luca-berton" },
  { name: "Udemy", icon: "bi:mortarboard", url: "https://www.udemy.com/user/luca-berton-3/" },
  { name: "Educative", icon: "bi:journal-bookmark", url: "https://www.educative.io/courses/automating-it-infrastructure-with-ansible/" },
  { name: "Skillshare", icon: "bi:lightbulb", url: "https://www.skillshare.com/en/r/user/luca-berton" },
];
---

<footer class="bg-gray-900 text-gray-400 mt-16">
  <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center md:items-start justify-between gap-8">
    <!-- Brand -->
    <div class="text-center md:text-left">
      <a href="/" class="text-white text-lg font-bold hover:text-blue-400 transition">Luca Berton</a>
      <p class="text-sm mt-1">AI Infrastructure for Regulated Enterprises</p>
    </div>

    <!-- Nav -->
    <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
      <a href="/services/" class="hover:text-white transition">Services</a>
      <a href="/courses/" class="hover:text-white transition">Courses</a>
      <a href="/about/" class="hover:text-white transition">About</a>
      <a href="/blog/" class="hover:text-white transition">Articles</a>
      <a href="/contact/" class="hover:text-white transition">Contact</a>
    </nav>

    <!-- Social & Learning -->
    <div class="flex flex-col items-center md:items-end gap-3">
      <div class="flex gap-3">
        {socialLinks.map((s) => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition" aria-label={s.name} title={s.name}>
            <Icon name={s.icon} class="w-5 h-5" />
          </a>
        ))}
      </div>
      <div class="flex flex-wrap justify-center md:justify-end gap-x-4 gap-y-1 text-[11px]">
        {learningPlatforms.map((s) => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-blue-400 transition flex items-center gap-1" title={s.name}>
            <Icon name={s.icon} class="w-3 h-3" />
            {s.name}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800 py-4 px-6 text-center text-[11px] text-gray-500">
    <p>
      © {new Date().getFullYear()} Luca Berton. All rights reserved.
      <span class="mx-1">·</span>
      <a href="/privacy-policy/" class="hover:text-gray-300 transition">Privacy</a>
      <span class="mx-1">·</span>
      <a href="/terms/" class="hover:text-gray-300 transition">Terms</a>
      <span class="mx-1">·</span>
      <a href="/rss.xml" class="hover:text-gray-300 transition">RSS</a>
      <span class="mx-1">·</span>
      <KitButton formId="ce74a48bfa" buttonText="Newsletter" buttonStyle="link" />
    </p>
  </div>
</footer>

<!-- Luca Berton Network Footer -->
<div class="lb-network">
  <div class="lb-network-grid">
    <a class="lb-active" href="https://lucaberton.com/" title="AI & Cloud Advisor">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      Luca Berton
    </a>
    <a href="https://www.ansiblepilot.com/" title="772+ Ansible Tutorials">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
      Ansible Pilot
    </a>
    <a href="https://www.ansiblebyexample.com/" title="Ansible Books & Resources">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
      Ansible by Example
    </a>
    <a href="https://www.openempower.com/" title="AI Platform Engineering Consultancy">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      Open Empower
    </a>
    <a href="https://kubernetes.recipes/" title="Kubernetes Recipe Book">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      K8s Recipes
    </a>
    <a href="https://www.terraformpilot.com/" title="Terraform Automation Mastery">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
      Terraform Pilot
    </a>
    <a href="https://www.copypastelearn.com/" title="Learn IT by Doing">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      CopyPasteLearn
    </a>
    <a href="https://www.proteinlens.com/" title="AI Macro Nutrition Tracker">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
      ProteinLens
    </a>
    <a href="https://www.techmeout.it/" title="TechMeOut — Professional Web Development">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      TechMeOut
    </a>
  </div>
</div>

<style>
  .lb-network{background:#0f172a;padding:8px 16px;text-align:center}
  .lb-network-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:4px;max-width:900px;margin:0 auto}
  .lb-network a{display:inline-flex;align-items:center;gap:3px;color:#475569;text-decoration:none;padding:2px 5px;font-size:9px;font-weight:400;transition:color .2s}
  .lb-network a:hover{color:#94a3b8}
  .lb-network a svg{width:8px;height:8px;flex-shrink:0}
  .lb-network a.lb-active{color:#64748b}
</style>
