---
import { Picture } from "astro:assets";
import heroImage from "assets/luca-hero.jpg";
---

<section class="relative min-h-[700px] lg:min-h-[800px] flex items-center overflow-hidden">
  <!-- Slideshow background images -->
  <div class="hero-slideshow absolute inset-0 z-0">
    <div class="hero-slide hero-slide-1 absolute inset-0 bg-cover bg-center" style="background-image: url('/hero-stage-1.jpg')"></div>
    <div class="hero-slide hero-slide-2 absolute inset-0 bg-cover bg-center opacity-0" style="background-image: url('/hero-stage-2.jpg')"></div>
  </div>

  <!-- Cinematic overlays -->
  <div class="absolute inset-0 bg-black/60 z-[1]"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/70 z-[1]"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-transparent to-black/40 z-[1]"></div>

  <!-- Subtle grain texture -->
  <div class="absolute inset-0 z-[2] opacity-[0.03] pointer-events-none"
    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 256px;"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 py-20 lg:py-24">
    <div class="grid lg:grid-cols-12 gap-12 items-center">

      <!-- Main content — 8 cols -->
      <div class="lg:col-span-7 xl:col-span-8 animate-fade-in">
        <!-- Live badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-600/20 border border-red-500/30 mb-6 animate-pulse-subtle">
          <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
          <span class="text-red-300 text-sm font-medium tracking-wide uppercase">Speaking at conferences worldwide</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black text-white leading-[1.05] tracking-tight">
          AI Infrastructure
          <br />
          <span class="bg-gradient-to-r from-amber-300 via-orange-400 to-red-500 bg-clip-text text-transparent">Partner</span>
          <br />
          <span class="text-3xl sm:text-4xl lg:text-5xl xl:text-5xl font-bold text-gray-300">for Regulated Enterprises</span>
        </h1>

        <p class="text-lg lg:text-xl text-gray-300 mt-6 max-w-2xl leading-relaxed">
          AI-ready platforms — cloud, MLOps, governance — that reduce costs,
          accelerate production, and pass audits. Without big-consultancy overhead.
        </p>

        <!-- CTAs -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="https://calendly.com/lucaberton"
            class="group inline-flex items-center justify-center px-8 py-4 bg-red-600 hover:bg-red-500 text-white font-bold rounded-xl shadow-2xl shadow-red-600/30 hover:shadow-red-500/40 hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 text-lg">
            Schedule Assessment
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a
            href="/services/"
            class="inline-flex items-center justify-center px-8 py-4 bg-white/10 backdrop-blur-sm border border-white/20 text-white font-semibold rounded-xl hover:bg-white/20 hover:border-white/40 active:scale-[0.98] transition-all duration-200 text-lg">
            View Services
          </a>
        </div>
      </div>

      <!-- Floating speaker card — 4 cols -->
      <div class="lg:col-span-5 xl:col-span-4 flex justify-center lg:justify-end animate-fade-in-up">
        <div class="relative">
          <!-- Glow effect behind card -->
          <div class="absolute -inset-4 bg-gradient-to-br from-amber-500/20 via-red-500/10 to-transparent rounded-3xl blur-2xl"></div>

          <div class="relative bg-white/[0.08] backdrop-blur-xl border border-white/[0.12] rounded-2xl p-6 shadow-2xl max-w-sm">
            <Picture
              src={heroImage}
              alt="Luca Berton — AI Infrastructure Consultant & Speaker"
              widths={[280, 400]}
              sizes="(max-width: 1024px) 280px, 400px"
              width={400}
              height={533}
              loading="eager"
              fetchpriority="high"
              format="avif"
              class="rounded-xl w-full aspect-[3/4] object-cover object-top shadow-lg"
            />

            <div class="mt-4 text-center">
              <h2 class="text-xl font-bold text-white">Luca Berton</h2>
              <p class="text-amber-300 text-sm font-medium mt-1">AI & Cloud Advisor · Docker Captain · Speaker</p>
            </div>

            <!-- Stats row -->
            <div class="grid grid-cols-3 gap-2 mt-4 pt-4 border-t border-white/10">
              <div class="text-center">
                <div class="text-2xl font-black text-white hero-counter" data-target="18">0</div>
                <div class="text-[11px] text-gray-400 uppercase tracking-wider">Years</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-black text-white hero-counter" data-target="8">0</div>
                <div class="text-[11px] text-gray-400 uppercase tracking-wider">Books</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-black text-white hero-counter" data-target="50">0</div>
                <div class="text-[11px] text-gray-400 uppercase tracking-wider">Talks</div>
              </div>
            </div>

            <!-- Recent talk badge -->
            <a href="/kubecon/" class="flex items-center gap-3 mt-4 p-3 rounded-lg bg-white/5 hover:bg-white/10 border border-white/5 hover:border-white/10 transition-all group">
              <span class="text-2xl">🎤</span>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-amber-300 font-semibold">Latest Talk</div>
                <div class="text-sm text-white truncate group-hover:text-amber-200 transition-colors">Multi-Tenant GPUs · KubeCon EU 2026</div>
              </div>
              <svg class="w-4 h-4 text-gray-500 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust strip -->
    <div class="mt-16 pt-8 border-t border-white/10 animate-fade-in-delayed">
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4 text-sm text-gray-400">
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          Pluralsight & Coursera Instructor
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
          KubeCon · Red Hat Summit · Rejekts
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          10,000+ Students Worldwide
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/></svg>
          8 Published Books
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Slideshow */
  .hero-slide {
    transition: opacity 2s ease-in-out;
  }
  .hero-slide-1 {
    animation: hero-crossfade-1 12s ease-in-out infinite;
  }
  .hero-slide-2 {
    animation: hero-crossfade-2 12s ease-in-out infinite;
  }
  @keyframes hero-crossfade-1 {
    0%, 42% { opacity: 1; }
    50%, 92% { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes hero-crossfade-2 {
    0%, 42% { opacity: 0; }
    50%, 92% { opacity: 1; }
    100% { opacity: 0; }
  }

  /* Ken Burns subtle zoom */
  .hero-slide-1 {
    animation: hero-crossfade-1 12s ease-in-out infinite, ken-burns-1 12s ease-in-out infinite;
  }
  .hero-slide-2 {
    animation: hero-crossfade-2 12s ease-in-out infinite, ken-burns-2 12s ease-in-out infinite;
  }
  @keyframes ken-burns-1 {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); }
    100% { transform: scale(1); }
  }
  @keyframes ken-burns-2 {
    0% { transform: scale(1.08); }
    50% { transform: scale(1); }
    100% { transform: scale(1.08); }
  }

  /* Entrance animations */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes fade-in-delayed {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out both;
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.9s ease-out 0.2s both;
  }
  .animate-fade-in-delayed {
    animation: fade-in-delayed 0.7s ease-out 0.5s both;
  }
  .animate-pulse-subtle {
    animation: pulse-subtle 3s ease-in-out infinite;
  }
  @keyframes pulse-subtle {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in, .animate-fade-in-up, .animate-fade-in-delayed {
      animation: none;
      opacity: 1;
    }
    .animate-pulse-subtle {
      animation: none;
    }
    .hero-slide-1, .hero-slide-2 {
      animation: none;
    }
    .hero-slide-1 { opacity: 1; }
    .hero-slide-2 { opacity: 0; }
  }
</style>

<script>
  // Animated counters
  document.addEventListener('DOMContentLoaded', () => {
    const counters = document.querySelectorAll('.hero-counter');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || '0');
          let current = 0;
          const increment = Math.max(1, Math.floor(target / 30));
          const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
              current = target;
              clearInterval(timer);
              el.textContent = target === 50 ? '50+' : target === 18 ? '18+' : target.toString();
            } else {
              el.textContent = current.toString();
            }
          }, 40);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    counters.forEach(c => observer.observe(c));
  });
</script>
