---
import { Picture } from "astro:assets";
import heroImage from "assets/luca-hero.jpg";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main class="grid lg:grid-cols-2 place-items-center pt-16 md:pt-12 pb-0 md:pb-0">
  <div class="py-6 md:order-1 flex justify-center">
    <Picture
      src={heroImage}
      alt="Luca Berton Consulting"
      widths={[150, 300, 450]}
      sizes="(max-width: 640px) 80vw, (max-width: 1024px) 300px, 450px"
      loading="eager"
      fetchpriority="high"
      format="avif"
      class="rounded-2xl shadow-lg w-40 sm:w-48 md:w-64 lg:w-80 xl:w-96"
    />
  </div>
  <div>
    <h1 class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      AI Advisor — Deployable, Governable AI Platforms
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      Luca Berton advises enterprises on AI/ML platform strategy, multi-tenant GPU orchestration on OpenShift AI, and MLOps enablement — with architecture aligned to SOC2/ISO27001 controls. Speaker at <a href="/blog/kubecon-europe-2026/" class="text-blue-500 hover:underline font-semibold">KubeCon EU 2026</a> & <a href="/blog/red-hat-summit-2026/" class="text-blue-500 hover:underline font-semibold">Red Hat Summit 2026</a>.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link size="lg" href="https://calendly.com/lucaberton" class="flex gap-2 items-center justify-center bg-blue-600 text-white px-5 py-3 rounded-lg shadow-md hover:bg-blue-700">
        <Icon class="w-5 h-5 text-white" name="bi:calendar-check" />
        Book a Consultation
      </Link>
      <Link size="lg" style="outline" rel="noopener" href="/contact/" class="flex gap-2 items-center justify-center border border-gray-300 px-5 py-3 rounded-lg hover:bg-gray-100">
        <Icon class="w-4 h-4 text-black" name="bi:envelope" />
        Contact Luca
      </Link>
    </div>
  </div>
</main>
