---
import { Picture } from "astro:assets";
import heroImage from "assets/luca-hero.jpg";
---

<section class="relative min-h-[600px] lg:min-h-[700px] flex items-center overflow-hidden">
  <!-- Dark cinematic background -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-800 to-amber-900/40 z-0"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(180,100,30,0.25),_transparent_60%)] z-0"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-2 gap-12 items-center py-16 lg:py-20">
    <!-- Text Content -->
    <div class="order-2 lg:order-1">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight tracking-tight">
        AI Infrastructure Partner
        <br />for Regulated Enterprises
      </h1>
      <p class="text-lg lg:text-xl text-gray-300 mt-6 max-w-xl leading-relaxed">
        AI-ready platforms (cloud + MLOps + governance)
        that reduce costs, accelerate production,
        and pass audits — without big-consultancy overhead
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <a
          href="https://calendly.com/lucaberton"
          class="inline-flex items-center justify-center px-7 py-3.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-lg shadow-red-600/25 transition-all duration-200 text-base">
          Schedule Assessment
        </a>
        <a
          href="/case-studies/"
          class="inline-flex items-center justify-center px-7 py-3.5 border-2 border-white/80 text-white font-semibold rounded-lg hover:bg-white/10 transition-all duration-200 text-base">
          View Case Studies
        </a>
      </div>
    </div>

    <!-- Hero Image -->
    <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
      <Picture
        src={heroImage}
        alt="Luca Berton — AI Infrastructure Consultant"
        widths={[300, 450, 600]}
        sizes="(max-width: 640px) 80vw, (max-width: 1024px) 350px, 500px"
        loading="eager"
        fetchpriority="high"
        format="avif"
        class="rounded-2xl shadow-2xl w-64 sm:w-72 md:w-80 lg:w-[420px] xl:w-[480px] object-cover"
      />
    </div>
  </div>
</section>
