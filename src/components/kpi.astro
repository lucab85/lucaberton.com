---
---

<!-- KPI / Stats Section with animated counters (derived from Luca Berton CV) -->
<section class="bg-white py-16">
  <div class="grid grid-cols-2 gap-6 md:grid-cols-4 text-center max-w-5xl mx-auto">
    <!-- Years of DevOps experience -->
    <div class="flex flex-col items-center p-6 bg-gray-50 hover:bg-gray-100 transition rounded-2xl shadow-sm border border-gray-200">
      <span class="text-5xl font-extrabold">
        <span class="counter" data-target="18">0</span>
        <span class="suffix">+</span>
      </span>
      <p class="text-sm text-gray-600 mt-2">Years of DevOps experience</p>
    </div>

    <!-- Cloud resources automated -->
    <div class="flex flex-col items-center p-6 bg-gray-50 hover:bg-gray-100 transition rounded-2xl shadow-sm border border-gray-200">
      <span class="text-5xl font-extrabold">
        <span class="counter" data-target="2">0</span>
        <span class="suffix ml-1">M+</span>
      </span>
      <p class="text-sm text-gray-600 mt-2">Cloud resources automated</p>
    </div>

    <!-- Annual cost savings delivered -->
    <div class="flex flex-col items-center p-6 bg-gray-50 hover:bg-gray-100 transition rounded-2xl shadow-sm border border-gray-200">
      <span class="text-5xl font-extrabold">
        <span class="counter" data-target="3">0</span>
        <span class="suffix ml-1">M€</span>
      </span>
      <p class="text-sm text-gray-600 mt-2">Annual cost savings delivered</p>
    </div>

    <!-- Technical books authored -->
    <div class="flex flex-col items-center p-6 bg-gray-50 hover:bg-gray-100 transition rounded-2xl shadow-sm border border-gray-200">
      <span class="text-5xl font-extrabold">
        <span class="counter" data-target="8">0</span>
      </span>
      <p class="text-sm text-gray-600 mt-2">Technical books authored</p>
    </div>
  </div>
</section>

<script is:inline>
  // Locale‑formatted counting animation (runs when KPI section is in view)
  (() => {
    const animateCounter = (el) => {
      const target = +el.dataset.target;
      const duration = 1800; // ms
      const start = performance.now();
      const format = (num) => new Intl.NumberFormat().format(num);
      const step = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const value = Math.floor(progress * target);
        el.textContent = format(value);
        if (progress < 1) {
          requestAnimationFrame(step);
        } else {
          el.textContent = format(target);
        }
      };
      requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            obs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );

    document.querySelectorAll('.counter').forEach((counter) => {
      observer.observe(counter);
    });
  })();
</script>
