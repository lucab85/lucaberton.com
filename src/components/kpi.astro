---
import { Icon } from "astro-icon/components";
---

<!-- KPI Stats Strip -->
<section class="bg-white py-12 border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8 text-center md:text-left">
    <!-- 30% cost reduction -->
    <div class="flex items-center gap-4 justify-center md:justify-start">
      <div class="shrink-0 w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center">
        <Icon name="bx:bxs-cog" class="w-7 h-7 text-gray-700" />
      </div>
      <div>
        <span class="text-3xl lg:text-4xl font-extrabold text-gray-900">30%</span>
        <p class="text-sm text-gray-500 mt-0.5">Average cloud cost reduction</p>
      </div>
    </div>

    <!-- 2-3x faster -->
    <div class="flex items-center gap-4 justify-center md:justify-start">
      <div>
        <span class="text-3xl lg:text-4xl font-extrabold text-gray-900">2-3×</span>
        <p class="text-sm text-gray-500 mt-0.5">Faster deployment to production</p>
      </div>
    </div>

    <!-- Audit-ready -->
    <div class="flex items-start gap-4 justify-center md:justify-start">
      <div>
        <span class="text-2xl lg:text-3xl font-extrabold text-gray-900">Audit-ready</span>
        <p class="text-sm text-gray-500 mt-0.5">Evidence pack (controls, policies, logs, runbooks)</p>
      </div>
    </div>
  </div>
</section>
