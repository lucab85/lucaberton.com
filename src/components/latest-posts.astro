---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);

function formatDate(date: string): string {
  return new Intl.DateTimeFormat('en-US', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  }).format(new Date(date));
}
---

<section class="bg-white py-16">
  <div class="mx-auto max-w-6xl px-5">
    <div class="text-center mb-12">
      <h2 class="font-extrabold text-4xl text-gray-900">Latest from the Blog</h2>
      <p class="text-lg mt-4 text-gray-700">
        Insights on AI, Kubernetes, Ansible, and cloud infrastructure.
      </p>
    </div>
    
    <div class="grid gap-8 md:grid-cols-3">
      {allPosts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="group block">
          <article class="flex flex-col border border-gray-200 bg-white hover:border-blue-600 hover:shadow-xl rounded-xl shadow-lg transition-all p-6 h-full">
            <div class="flex-1">
              <time class="text-sm text-gray-500" datetime={post.data.publishDate}>
                {formatDate(post.data.publishDate)}
              </time>
              <h3 class="font-bold text-gray-900 text-lg mt-2 group-hover:text-blue-700 transition-colors">
                {post.data.title}
              </h3>
              {post.data.snippet && (
                <p class="text-sm mt-2 text-gray-600 line-clamp-3">
                  {post.data.snippet}
                </p>
              )}
              {post.data.category && (
                <span class="inline-block mt-3 text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-1 rounded">
                  {post.data.category}
                </span>
              )}
            </div>
            <span class="text-blue-600 font-semibold text-sm mt-4 inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Read more
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M14 5l7 7m0 0l-7 7m7-7H3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
              </svg>
            </span>
          </article>
        </a>
      ))}
    </div>
    
    <div class="mt-10 text-center">
      <a class="text-lg font-semibold hover:underline inline-block px-6 py-3 text-blue-600 transition" href="/blog/">
        View All Posts
      </a>
    </div>
  </div>
</section>
