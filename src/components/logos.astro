---
import { Picture } from "astro:assets";
import jpmorgan from "assets/logos/jpmorgan.png";
import redhat from "assets/logos/redhat.png";
import aws from "assets/logos/aws.png";
import coursera from "assets/logos/coursera.png";
import udemy from "assets/logos/udemy.png";
---

<div class="mt-12 text-center py-6">
  <h2 class="text-slate-500 mb-6">Trusted by Leading Organizations</h2>
  <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12 px-6">
    <div class="flex justify-center items-center">
      <Picture
        src={jpmorgan}
        alt="JPMorgan Chase & Co."
        widths={[100, 150, 200]}
        sizes="(max-width: 800px) 100vw, 120px"
        loading="lazy"
        format="avif"
        class="h-auto w-32 md:w-40 object-contain"
      />
    </div>
    <div class="flex justify-center items-center">
      <Picture
        src={redhat}
        alt="Red Hat"
        widths={[100, 150, 200]}
        sizes="(max-width: 800px) 100vw, 120px"
        loading="lazy"
        format="avif"
        class="h-auto w-32 md:w-40 object-contain"
      />
    </div>
    <div class="flex justify-center items-center">
      <Picture
        src={aws}
        alt="AWS"
        widths={[100, 150, 200]}
        sizes="(max-width: 800px) 100vw, 120px"
        loading="lazy"
        format="avif"
        class="h-auto w-32 md:w-40 object-contain"
      />
    </div>
    <div class="flex justify-center items-center">
      <Picture
        src={coursera}
        alt="Coursera"
        widths={[100, 150, 200]}
        sizes="(max-width: 800px) 100vw, 120px"
        loading="lazy"
        format="avif"
        class="h-auto w-32 md:w-40 object-contain"
      />
    </div>
    <div class="flex justify-center items-center">
      <Picture
        src={udemy}
        alt="Udemy"
        widths={[100, 150, 200]}
        sizes="(max-width: 800px) 100vw, 120px"
        loading="lazy"
        format="avif"
        class="h-auto w-32 md:w-40 object-contain"
      />
    </div>
  </div>
</div>