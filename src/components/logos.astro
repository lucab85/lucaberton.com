---
import { Picture } from "astro:assets";
import coursera from "assets/logos/coursera.webp";
import kubernetes from "assets/logos/kubernetes.webp";
import redhat from "assets/logos/redhat.webp";
import aws from "assets/logos/aws.webp";
import ansible from "assets/logos/ansible.webp";
import apress from "assets/logos/apress.webp";
import dell from "assets/logos/dell.webp";

const logoImages = [
  { src: coursera, alt: "Coursera" },
  { src: kubernetes, alt: "Kubernetes" },
  { src: redhat, alt: "Red Hat" },
  { src: aws, alt: "AWS" },
  { src: ansible, alt: "Ansible" },
  { src: apress, alt: "Apress" },
  { src: dell, alt: "Dell Technologies" },
];

const textLogos = ["Pluralsight", "Educative"];
---

<div class="py-12 bg-gray-50 border-y border-gray-100">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <h2 class="text-xl font-semibold text-gray-500 mb-8">Trusted by Learners on Leading Platforms</h2>

    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10">
      {logoImages.map((logo) => (
        <div class="w-24 md:w-28 h-10 md:h-12 flex items-center justify-center">
          <Picture
            src={logo.src}
            alt={logo.alt}
            widths={[120, 150]}
            sizes="120px"
            loading="lazy"
            formats={['avif', 'webp']}
            class="max-h-full max-w-full object-contain grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-200"
          />
        </div>
      ))}
      {textLogos.map((name) => (
        <div class="w-24 md:w-28 h-10 md:h-12 flex items-center justify-center">
          <span class="text-base md:text-lg font-bold text-gray-400 hover:text-gray-700 transition-colors duration-200">{name}</span>
        </div>
      ))}
    </div>
  </div>
</div>
