---
import { Picture } from "astro:assets";
import coursera from "assets/logos/coursera.webp";
import udemy from "assets/logos/udemy.webp";
import redhat from "assets/logos/redhat.webp";
import aws from "assets/logos/aws.webp";
import ansible from "assets/logos/ansible.webp";
import apress from "assets/logos/apress.webp";
import dell from "assets/logos/dell.webp";

const logoImages = [
  { src: coursera, alt: "Coursera" },
  { src: udemy, alt: "Udemy" },
  { src: redhat, alt: "Red Hat" },
  { src: aws, alt: "AWS" },
  { src: ansible, alt: "Ansible" },
  { src: apress, alt: "Apress" },
  { src: dell, alt: "Dell Technologies" },
];

const textLogos = ["Pluralsight", "Educative"];
---

<div class="py-12 bg-gray-50 border-y border-gray-100">
  <div class="max-w-6xl mx-auto px-6 text-center">
    <h2 class="text-xl font-semibold text-gray-500 mb-8">Trusted by Learners on Leading Platforms</h2>

    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
      {logoImages.map((logo) => (
        <Picture
          src={logo.src}
          alt={logo.alt}
          widths={[120, 150]}
          sizes="120px"
          loading="lazy"
          formats={['avif', 'webp']}
          class="h-8 md:h-10 w-auto object-contain grayscale hover:grayscale-0 opacity-70 hover:opacity-100 transition-all duration-200"
        />
      ))}
      {textLogos.map((name) => (
        <span class="text-lg md:text-xl font-bold text-gray-400 hover:text-gray-700 transition-colors duration-200">{name}</span>
      ))}
    </div>
  </div>
</div>
