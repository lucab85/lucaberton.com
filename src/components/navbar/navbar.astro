---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import KitButton from '@components/KitButton.astro';

const menuitems = [
  {
    title: "About",
    path: "/about/",
  },
  {
    title: "Books",
    path: "/books/",
  },
  {
    title: "Courses",
    path: "/courses/",
  },
  {
    title: "Conferences",
    path: "/conferences/",
  },
  {
    title: "Services",
    path: "/services/",
  },
  {
    title: "Blog",
    path: "/blog/",
  },
];
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5" role="banner">
    <Astronav>
      <nav aria-label="Main navigation" class="flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="text-lg font-bold text-slate-800">Luca Berton</a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </nav>
      <div class="flex w-full lg:w-auto justify-between lg:justify-start items-center">
        <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
          <ul class="flex flex-col lg:flex-row lg:gap-4">
            {menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class={`flex lg:px-4 py-2 items-center text-gray-600 hover:text-gray-900 transition-colors duration-150 relative ${Astro.url.pathname.startsWith(item.path) ? 'text-gray-900 font-medium' : ''}`}
                  aria-current={Astro.url.pathname.startsWith(item.path) ? "page" : undefined}
                >
                  <span>{item.title}</span>
                </a>
              </li>
            ))}
          </ul>
         <div class="lg:hidden flex items-center mt-3 gap-4">
          <KitButton
            formId="ce74a48bfa"
            buttonText="Newsletter"
            buttonStyle="secondary"
          />
          <Link href="/contact/" size="md">Contact</Link>
        </div>
        </MenuItems>
      </div>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center gap-4">
        <KitButton
          formId="ce74a48bfa"
          buttonText="Newsletter"
          buttonStyle="secondary"
        />
        <Link href="/contact/" size="md">Contact</Link>
      </div>
    </div>
  </header>
</Container>
