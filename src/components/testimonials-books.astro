---
const testimonials = [
  {
    rating: 5,
    review: "Great Book! I definitely recommend this Book!",
    name: "Verified Customer",
    source: "Amazon",
    date: "January 14, 2025"
  },
  {
    rating: 5,
    review: "If you work with Kubernetes - This is a MUST.",
    name: "Erez Kirson",
    source: "Amazon",
    date: "June 8, 2023"
  },
  {
    rating: 5,
    review: "This book will gain you the knowledge to construct scenarios on top of Kubernetes using Ansible.",
    name: "Daniel Kallner",
    source: "Amazon",
    date: "June 2, 2023"
  },
  {
    rating: 5,
    review: "Brilliant! In-depth coverage of all aspects Ansible meeting Kubernetes.",
    name: "Michael K.",
    source: "Amazon",
    date: "June 2, 2023"
  },
  {
    rating: 5,
    review: "Practical Kubernetes AUTOMATED with Ansible.",
    name: "Edward",
    source: "Amazon",
    date: "June 1, 2023"
  }
];
---

<section class="bg-white text-center py-16 overflow-hidden">
  <h2 id="testimonials-section" class="text-4xl font-bold text-gray-900">
    What Readers Say About My Books
  </h2>
  <p class="text-lg text-slate-600 mt-4">
    See how my books have guided professionals in automating complex workflows with Ansible and Kubernetes.
  </p>

  <div class="relative flex w-full overflow-hidden mt-8">
    <div class="flex gap-6 animate-marquee motion-safe:animate-marquee">
      {testimonials.concat(testimonials).map((testimonial, index) => (
        <div
          key={index}
          class="min-w-[300px] max-w-xs bg-white shadow-lg p-6 rounded-xl border border-gray-200 text-center flex flex-col"
        >
          {/* Star Ratings */}
          <div class="flex justify-center gap-1 mb-3">
            {[...Array(testimonial.rating)].map((_, i) => (
              <svg key={i} class="text-yellow-400 w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            ))}
          </div>
          {/* Review Content */}
          <p class="text-lg text-gray-800 font-semibold leading-relaxed break-words whitespace-normal">
            {testimonial.review}
          </p>
          {/* Reviewer Name */}
          <p class="text-gray-700 mt-2 font-medium">{testimonial.name}</p>
          {/* Source */}
          <p class="text-sm text-gray-500 italic">{testimonial.source} - {testimonial.date}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-marquee {
    display: flex;
    white-space: nowrap;
    animation: marquee 20s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-marquee {
      animation: none;
    }
  }
</style>
