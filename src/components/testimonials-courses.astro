<section class="bg-white text-center py-16 overflow-hidden">
  <div class="text-center py-16">
    <h2 id="testimonials-section" class="text-4xl font-bold text-gray-900 flex justify-center items-center">
      What Students Say About My Courses
    </h2>
    <p class="text-lg text-slate-600 mt-4">
      See what professionals and students are saying about my courses.
    </p>
  </div>

  <!-- Marquee Container -->
  <div class="overflow-hidden relative w-full">
    <div class="flex gap-6 animate-marquee hover:[animation-play-state:paused]">
      <!-- Duplicated testimonials for seamless looping -->
      {testimonials.concat(testimonials).map((testimonial, index) => (
        <div key={index} class="min-w-[300px] max-w-[400px] bg-white shadow-lg p-6 rounded-xl text-center border border-gray-200 whitespace-normal">
          <!-- Star Ratings -->
          <div class="flex justify-center gap-1 mb-3">
            {[...Array(testimonial.rating)].map(() => (
              <svg class="text-yellow-400 w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            ))}
          </div>
          <!-- Review Content -->
          <p class="text-lg text-gray-800 font-semibold leading-relaxed">{testimonial.review}</p>
          <!-- Reviewer Name -->
          <p class="text-gray-700 mt-2 font-medium">{testimonial.name}</p>
          <!-- Source -->
          <p class="text-sm text-gray-500 italic">{testimonial.source} - {testimonial.date}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
@keyframes marquee {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

.animate-marquee {
  display: flex;
  width: max-content;
  animation: marquee 20s linear infinite;
}
</style>


<style>
@keyframes marquee {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(-100%);
  }
}

.motion-safe\:animate-marquee {
  animation: marquee 30s linear infinite;
}

.hover\:pause:hover {
  animation-play-state: paused;
}
</style>
