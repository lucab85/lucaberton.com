---
import Container from "@components/container.astro";
import { getFormattedDate } from "@utils/all";
import Layout from "./Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import AuthorBox from "@components/AuthorBox.astro";
import BlogPromoCard from "@components/BlogPromoCard.astro";
import BlogRelatedPosts from "@components/BlogRelatedPosts.astro";
import KitButton from "@components/KitButton.astro";
import ShareButtons from "@components/ShareButtons.astro";
import TableOfContents from "@components/TableOfContents.astro";
import slugify from "slugify";

const { frontmatter } = Astro.props;

// Reading time estimation
const rawContent = frontmatter.rawContent || "";
const wordCount = rawContent.split(/\s+/).filter(Boolean).length || 800;
const readingTime = Math.max(1, Math.ceil(wordCount / 238));

// Current URL for sharing
const currentUrl = `https://lucaberton.com${Astro.url.pathname}`;
const currentSlug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');

// Generate structured data for blog post
const blogStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": frontmatter.title,
  "description": frontmatter.snippet,
  "author": {
    "@type": "Person",
    "name": frontmatter.author || "Luca Berton",
    "url": "https://lucaberton.com/about/",
    "image": "https://lucaberton.com/blog/thumbnails/luca-berton-author.jpg",
    "jobTitle": "AI & Cloud Advisor",
    "description": "Docker Captain, author of 8 technical books, former Red Hat engineer. 18+ years in enterprise AI and cloud infrastructure.",
    "sameAs": [
      "https://www.linkedin.com/in/lucaberton/",
      "https://bsky.app/profile/lucaberton.com",
      "https://www.youtube.com/@BertonLuca",
      "https://github.com/lucab85"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Luca Berton",
    "url": "https://lucaberton.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://lucaberton.com/opengraph.jpg"
    }
  },
  "datePublished": frontmatter.publishDate,
  "dateModified": frontmatter.lastModified || frontmatter.publishDate,
  "image": frontmatter.image?.src ? `https://lucaberton.com${frontmatter.image.src}` : "https://lucaberton.com/opengraph.jpg",
  "url": currentUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": currentUrl
  },
  "articleSection": frontmatter.category,
  "keywords": frontmatter.tags?.join(", ") || "",
  "wordCount": wordCount,
  "timeRequired": `PT${readingTime}M`
};
---

<Layout 
  title={frontmatter.title} 
  description={frontmatter.snippet}
  image={frontmatter.image?.src}
>
  <!-- Blog Post Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(blogStructuredData)}></script>
  
  <Breadcrumb items={[
    { name: "Blog", url: "/blog/" },
    { name: frontmatter.category, url: `/blog/categories/${slugify(frontmatter.category, { lower: true, strict: true })}/` },
    { name: frontmatter.title }
  ]} />

  <!-- Full-width Hero Image -->
  {frontmatter.image?.src && (
    <div class="w-full max-w-5xl mx-auto px-4 mt-4">
      <img
        src={frontmatter.image.src}
        alt={frontmatter.image.alt || frontmatter.title}
        width="1024"
        height="538"
        loading="eager"
        class="w-full rounded-2xl object-cover aspect-[16/8.4] shadow-lg"
      />
    </div>
  )}

  <Container>
    <article class="mx-auto max-w-[735px] mt-8">
      <!-- Category Badge -->
      <a 
        href={`/blog/categories/${slugify(frontmatter.category, { lower: true, strict: true })}/`}
        class="inline-block bg-blue-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded hover:bg-blue-700 transition-colors"
      >
        {frontmatter.category}
      </a>
      
      <!-- Headline -->
      <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold leading-tight mt-4 text-gray-900">
        {frontmatter.title}
      </h1>

      <!-- Author Row -->
      <div class="flex items-center gap-3 mt-6 pb-6 border-b border-gray-200">
        <img 
          src="/blog/thumbnails/luca-berton-author.jpg"
          alt="Luca Berton"
          width="44"
          height="44"
          loading="eager"
          class="rounded-full w-11 h-11 object-cover"
          onerror="this.style.display='none'"
        />
        <div class="flex flex-col">
          <a href="/about/" class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition-colors leading-tight">
            {frontmatter.author || "Luca Berton"}
          </a>
          <div class="flex items-center gap-2 text-xs text-gray-500 mt-0.5 flex-wrap">
            <time datetime={frontmatter.publishDate}>
              {getFormattedDate(frontmatter.publishDate)}
            </time>
            {frontmatter.lastModified && frontmatter.lastModified !== frontmatter.publishDate && (
              <>
                <span>·</span>
                <span class="text-green-600 font-medium">Updated <time datetime={frontmatter.lastModified}>{getFormattedDate(frontmatter.lastModified)}</time></span>
              </>
            )}
            <span>·</span>
            <span>{readingTime} min read</span>
          </div>
        </div>
        <!-- Share icons inline -->
        <div class="ml-auto flex items-center gap-2">
          <a 
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(frontmatter.title)}&url=${encodeURIComponent(currentUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-gray-600 transition-colors"
            aria-label="Share on X"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a 
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-gray-600 transition-colors"
            aria-label="Share on LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
          </a>
        </div>
      </div>

      <!-- Key Highlights Box (from snippet) -->
      {frontmatter.snippet && (
        <div class="mt-6 bg-gray-50 border-l-4 border-blue-600 rounded-r-lg p-4">
          <p class="text-[0.95rem] text-gray-700 leading-relaxed font-medium italic m-0">
            {frontmatter.snippet}
          </p>
        </div>
      )}
      
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-5">
        {frontmatter.tags.map((tag: string) => (
          <a 
            href={`/blog/categories/${slugify(frontmatter.category, { lower: true, strict: true })}/`}
            class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full hover:bg-blue-50 hover:text-blue-700 transition-colors font-medium"
          >
            #{tag}
          </a>
        ))}
      </div>
    </article>

    <!-- Article Body -->
    <div class="mx-auto prose prose-lg mt-8 max-w-[735px] prose-headings:font-extrabold prose-headings:tracking-tight prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-xl prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-blue-600 prose-a:font-medium prose-img:rounded-xl prose-img:shadow-md">
      <TableOfContents />
      <slot />
    </div>

    <div class="mx-auto max-w-[735px]">
      <!-- Share Buttons -->
      <ShareButtons title={frontmatter.title} url={currentUrl} />
      
      <!-- Book/Course Promo -->
      <BlogPromoCard />
      
      <!-- Author Box -->
      <AuthorBox />
      
      <!-- Consultation CTA -->
      <div class="mt-8 p-8 bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 rounded-2xl text-center">
        <h3 class="text-xl font-bold text-white">Need help implementing this?</h3>
        <p class="text-sm text-slate-300 mt-2 mb-5 max-w-lg mx-auto">I help enterprises design AI infrastructure, Kubernetes platforms, and automation strategies. 30-minute free discovery call.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://calendly.com/lucaberton/" class="inline-block bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 text-sm shadow-lg shadow-red-900/30">Schedule Assessment</a>
          <a href="/services/" class="inline-block border border-slate-500 hover:border-slate-300 text-slate-300 hover:text-white font-semibold py-3 px-8 rounded-lg transition-all text-sm">View Services</a>
        </div>
      </div>

      <!-- Newsletter CTA -->
      <div class="mt-6 p-8 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl border border-blue-100 text-center">
        <h3 class="text-xl font-bold text-gray-900">Get AI & Cloud insights in your inbox</h3>
        <p class="text-sm text-gray-600 mt-2 mb-5">Weekly insights on Kubernetes, AI infrastructure, and platform engineering. No spam.</p>
        <KitButton formId="ce74a48bfa" buttonText="Subscribe Free" />
      </div>

      <!-- Related Posts -->
      <BlogRelatedPosts 
        currentSlug={currentSlug}
        category={frontmatter.category}
        tags={frontmatter.tags}
      />

      <!-- Back to Blog -->
      <div class="text-center mt-8 mb-12">
        <a
          href="/blog/"
          class="bg-gray-100 px-5 py-3 rounded-md hover:bg-gray-200 transition font-medium text-gray-700"
        >← Back to Blog</a>
      </div>
    </div>
  </Container>
</Layout>
