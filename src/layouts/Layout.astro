---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import AnnouncementBanner from "@components/AnnouncementBanner.astro";
import WebVitals from "@components/WebVitals.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

// ============================================
// ANNOUNCEMENT BANNER CONFIGURATION
// Set enabled to false to hide a banner
// ============================================
const kubeconBanner = {
  enabled: true,
  emoji: "🎤",
  headline: "Speaking at KubeCon EU 2026",
  description: "Lessons Learned Orchestrating Multi-Tenant GPUs on OpenShift AI",
  linkText: "View Session",
  linkUrl: "https://kccnceu2026.sched.com/event/2CVzs/lessons-learned-orchestrating-multi-tenant-gpus-on-openshift-ai-with-nvidia-kai-gh200-luca-berton-dell-technologies",
  gradientFrom: "cyan-600",
  gradientVia: "blue-600",
  gradientTo: "purple-600",
};

const redHatSummitBanner = {
  enabled: true,
  emoji: "🎤",
  headline: "Speaking at Red Hat Summit 2026",
  description: "GPUs take flight: Safety-first multi-tenant Platform Engineering with NVIDIA and OpenShift AI",
  linkText: "Learn More",
  linkUrl: "/blog/red-hat-summit-2026/",
  gradientFrom: "red-600",
  gradientVia: "red-700",
  gradientTo: "red-800",
};
// ============================================

const siteName = "Luca Berton | AI & Cloud Advisor";
const shortSuffix = "Luca Berton"; // Shorter suffix for SEO (keeps titles under 60 chars)
const maxTitleLength = 60; // Google truncates titles longer than ~60 characters

// Force HTTPS and ensure trailing slash for canonical URL (matches how Astro serves pages)
let canonicalURL = new URL(Astro.url.pathname, "https://lucaberton.com").toString();
// Ensure trailing slash for all URLs (Astro serves pages as /path/index.html → /path/)
if (!canonicalURL.endsWith('/')) {
  canonicalURL = canonicalURL + '/';
}

const resolvedImageWithDomain = new URL("/opengraph.jpg", "https://lucaberton.com").toString();
const { title, description: customDescription, image: customImage } = Astro.props;

// Use custom image if provided (e.g. blog post hero), otherwise default
const ogImage = customImage 
  ? (customImage.startsWith('http') ? customImage : new URL(customImage, "https://lucaberton.com").toString())
  : resolvedImageWithDomain;

// Smart title: use short suffix to keep under 60 chars, or no suffix if still too long
const makeTitle = (() => {
  if (!title) return siteName;
  const withShortSuffix = `${title} | ${shortSuffix}`;
  if (withShortSuffix.length <= maxTitleLength) {
    return withShortSuffix;
  }
  // If still too long, just use the title alone
  return title;
})();

const metaDescription = customDescription 
  ? customDescription
  : (title === "Home" || !title
    ? "Luca Berton — AI & Cloud Advisor. 18+ years, 8 books, KubeCon & Red Hat Summit speaker. Consulting in AI platforms, GPU orchestration & Kubernetes."
    : "Expert AI, Kubernetes, and Cloud Consulting by Luca Berton. Automation, GPU orchestration, and platform engineering insights from 18+ years of experience.");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Luca Berton Blog" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- www/http redirect handled at Cloudflare level (no client-side JS needed) -->

    <!-- Preconnect to critical third-party origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://f.convertkit.com" />
    
    <!-- Additional SEO meta tags -->
    <meta http-equiv="Strict-Transport-Security" content="max-age=31536000; includeSubDomains" />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <SEO
      title={makeTitle}
      description={metaDescription}
      canonical={canonicalURL}
      twitter={{
        creator: "@lucaberton",
        site: "@lucaberton",
        card: "summary_large_image",
        title: makeTitle,
        description: metaDescription,
        image: ogImage,
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: ogImage,
        },
        image: {
          alt: `Luca Berton - ${title}`,
        },
        optional: {
          description: metaDescription,
          locale: "en_US",
          siteName: siteName,
        },
      }}
    />

    <!-- opengraph.jpg only used by social crawlers, no need to preload -->

    <!-- Structured Data for SEO -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Luca Berton",
      "url": "https://lucaberton.com",
      "jobTitle": "AI & Cloud Advisor",
      "sameAs": [
        "https://www.linkedin.com/in/lucaberton/",
        "https://www.ansiblepilot.com/",
        "https://www.terraformpilot.com/",
        "https://github.com/lucab85"
      ]
    }
    </script>

    <!-- FAQ Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What AI and cloud consulting services does Luca Berton offer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Luca Berton provides expert consulting in AI/ML platform strategy, multi-tenant GPU orchestration on OpenShift AI, MLOps enablement, cloud infrastructure design, Kubernetes workshops, and Ansible & Python training."
          }
        },
        {
          "@type": "Question",
          "name": "What is Ansible Pilot?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ansible Pilot is the leading resource for Ansible automation learning, featuring a YouTube channel with 6.1K subscribers and 1M+ views, plus AnsiblePilot.com with 648K total users."
          }
        },
        {
          "@type": "Question",
          "name": "How can I book a consultation with Luca Berton?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Schedule a free consultation through Calendly at calendly.com/lucaberton or visit lucaberton.com/contact."
          }
        }
      ]
    }
    </script>

    <!-- WebSite Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Luca Berton | AI & Cloud Advisor",
      "url": "https://lucaberton.com",
      "description": "Expert AI, Kubernetes, and Cloud Consulting. 18+ years of experience, 8 technical books, speaker at KubeCon and Red Hat Summit."
    }
    </script>

    <!-- ProfessionalService Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Luca Berton AI & Cloud Consulting",
      "url": "https://lucaberton.com",
      "description": "AI platform strategy, GPU orchestration, MLOps, cloud infrastructure, and automation consulting.",
      "founder": { "@type": "Person", "name": "Luca Berton" },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Amsterdam",
        "addressCountry": "NL"
      },
      "areaServed": "Worldwide",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Consulting Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Integration & GPU Platforms", "url": "https://lucaberton.com/services/ai-integration/" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ansible & Python Training", "url": "https://lucaberton.com/services/ansible-python-training/" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kubernetes Workshops", "url": "https://lucaberton.com/services/kubernetes-workshops/" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cloud Infrastructure", "url": "https://lucaberton.com/services/cloud-infrastructure/" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Automation Strategy", "url": "https://lucaberton.com/services/automation-strategy/" } }
        ]
      }
    }
    </script>

    <link
      rel="stylesheet"
      href="/styles/cookieconsent.css"
      media="print"
      onload="this.media='all'"
    />
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      type="text/partytown"
      src="https://www.googletagmanager.com/gtag/js?id=G-M9Q5F672JT"
    ></script>

    <script data-category="analytics" is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-M9Q5F672JT");
    </script>

    <!-- Kit.com (formerly ConvertKit) -->
    <script async src="https://f.convertkit.com/9153490/ce74a48bfa.js" data-uid="ce74a48bfa"></script>
    <!-- End Kit.com -->

    <!-- Microsoft Clarity (deferred until user interaction) -->
    <script type="text/javascript">
        (function() {
          var loaded = false;
          function loadClarity() {
            if (loaded) return;
            loaded = true;
            (function(c,l,a,r,i,t,y){
              c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
              t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
              y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window, document, "clarity", "script", "v5mr11qsni");
          }
          ['scroll','click','touchstart','mousemove'].forEach(function(evt) {
            document.addEventListener(evt, loadClarity, { once: true, passive: true });
          });
        })();
    </script>
    <!-- End Microsoft Clarity -->
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-blue-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-md">
      Skip to main content
    </a>
    <AnnouncementBanner {...kubeconBanner} />
    <AnnouncementBanner {...redHatSummitBanner} />
    <Navbar />
    <script type="module" src="/scripts/cookieconsent-config.js"></script>
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <WebVitals />
    <style is:global>
      /* Improve Page Speed */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
