---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import AnnouncementBanner from "@components/AnnouncementBanner.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

// ============================================
// ANNOUNCEMENT BANNER CONFIGURATION
// Set enabled to false to hide the banner
// ============================================
const announcementConfig = {
  enabled: true,
  emoji: "🎤",
  headline: "Speaking at KubeCon EU 2026",
  description: "Lessons Learned Orchestrating Multi-Tenant GPUs on OpenShift AI",
  linkText: "View Session",
  linkUrl: "https://kccnceu2026.sched.com/event/2CVzs/lessons-learned-orchestrating-multi-tenant-gpus-on-openshift-ai-with-nvidia-kai-gh200-luca-berton-dell-technologies",
  gradientFrom: "cyan-600",
  gradientVia: "blue-600",
  gradientTo: "purple-600",
};
// ============================================

const siteName = "Luca Berton | AI & Cloud Consultant";

// Force HTTPS and ensure trailing slash for canonical URL (matches how Astro serves pages)
let canonicalURL = new URL(Astro.url.pathname, "https://lucaberton.com").toString();
// Ensure trailing slash for all URLs (Astro serves pages as /path/index.html → /path/)
if (!canonicalURL.endsWith('/')) {
  canonicalURL = canonicalURL + '/';
}

const resolvedImageWithDomain = new URL("/opengraph.jpg", "https://lucaberton.com").toString();
const { title } = Astro.props;
const makeTitle = title ? `${title} | ${siteName}` : siteName;

const metaDescription = title === "Home"
  ? "Luca Berton provides AI & Cloud solutions, consulting, and automation services. Specializing in Kubernetes, Ansible, and DevOps."
  : "Expert AI, Kubernetes, and Cloud Consulting by Luca Berton. Get cutting-edge automation solutions today.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Client-side redirect for www and http variants to canonical URL -->
    <script is:inline>
      (function() {
        var host = window.location.host;
        var protocol = window.location.protocol;
        // Skip redirect for localhost development
        if (host.indexOf('localhost') !== -1 || host.indexOf('127.0.0.1') !== -1) {
          return;
        }
        // Redirect www to non-www and http to https
        if (host.indexOf('www.') === 0 || protocol === 'http:') {
          var newUrl = 'https://lucaberton.com' + window.location.pathname + window.location.search;
          window.location.replace(newUrl);
        }
      })();
    </script>
    
    <!-- Explicit canonical link tag - this is the most important SEO signal -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Additional SEO meta tags -->
    <meta http-equiv="Strict-Transport-Security" content="max-age=31536000; includeSubDomains" />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <SEO
      title={makeTitle}
      description={metaDescription}
      canonical={canonicalURL}
      twitter={{
        creator: "@lucaberton",
        site: "@lucaberton",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: makeTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: `Luca Berton - ${title}`,
        },
      }}
    />

    <!-- Preload critical images -->
    <link rel="preload" as="image" href="/opengraph.jpg" />

    <!-- Structured Data for SEO -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Luca Berton",
      "url": "https://lucaberton.com",
      "jobTitle": "AI & Cloud Consultant",
      "sameAs": [
        "https://www.linkedin.com/in/lucaberton/",
        "https://www.ansiblepilot.com/",
        "https://www.terraformpilot.com/",
        "https://github.com/lucab85"
      ]
    }
    </script>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.0.1/dist/cookieconsent.css"
    />
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      type="text/partytown"
      src="https://www.googletagmanager.com/gtag/js?id=G-M9Q5F672JT"
    ></script>

    <script data-category="analytics" is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-M9Q5F672JT");
    </script>

    <!-- MailerLite Universal -->
    <script type="text/javascript">
        (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
        .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
        n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
        (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
        ml('account', '746041');
    </script>
    <!-- End MailerLite Universal -->
  </head>
  <body>
    <AnnouncementBanner {...announcementConfig} />
    <Navbar />
    <script type="module" src="/scripts/cookieconsent-config.js"></script>
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page Speed */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
