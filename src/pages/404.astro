---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";

export const prerender = true;
export const lastModified = '2026-02-26';
---

<Layout title="404 Not Found">
  <Container>
    <div class="min-h-[calc(100vh-16rem)] flex items-center justify-center">
      <div class="mt-16 text-center max-w-lg">
        <h1 class="text-6xl lg:text-7xl font-bold lg:tracking-tight text-blue-600">404</h1>
        <p class="text-2xl mt-4 font-semibold text-gray-900">Page not found</p>
        <p class="text-lg mt-2 text-slate-600">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition font-semibold">
            Go Home
          </a>
          <a href="/blog/" class="border border-gray-300 px-6 py-3 rounded-lg hover:bg-gray-100 transition font-semibold text-gray-700">
            Browse Blog
          </a>
          <a href="/contact/" class="border border-gray-300 px-6 py-3 rounded-lg hover:bg-gray-100 transition font-semibold text-gray-700">
            Contact
          </a>
        </div>
      </div>
    </div>
  </Container>
</Layout>
