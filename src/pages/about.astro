---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { Picture } from "astro:assets";
import Cta from "@components/cta.astro"
import Breadcrumb from "@components/Breadcrumb.astro";

export const prerender = true;
export const lastModified = '2026-02-19';

import cfgMgmtCamp2025 from "assets/photos/CfgMgmtCamp2025.jpg";
import cloudNativeLondon from "assets/photos/CloudNativeLondon.jpg";
import ansibleCommunityDayBerlin from "assets/photos/AnsibleCommunityDay2023.jpg";
import ansibleMeetupLondon from "assets/photos/AnsibleMeetupLondon2024.jpg";

const photos = [
  { src: cfgMgmtCamp2025, alt: "Luca Berton speaking at CfgMgmtCamp 2025 in Ghent" },
  { src: cloudNativeLondon, alt: "Luca Berton at Cloud Native London meetup" },
  { src: ansibleCommunityDayBerlin, alt: "Luca Berton at Ansible Community Day Berlin 2023" },
  { src: ansibleMeetupLondon, alt: "Luca Berton presenting at Ansible Meetup London 2024" },
];
---

<Layout title="About Luca Berton">
  <Breadcrumb items={[{ name: "About" }]} />
  <Container>
    <Sectionhead>
      <Fragment slot="title">About Luca</Fragment>
      <Fragment slot="desc">AI Advisor | AI Platform Strategy (OpenShift AI, GPUs) | MLOps & RAG Enablement | Secure-by-Design (SOC2/ISO27001) | Speaker: KubeCon EU 2026 & Red Hat Summit 2026</Fragment>
    </Sectionhead>

    <!-- Image Gallery -->
    <section class="bg-white">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
        {photos.map((photo) => (
          <Picture
            src={photo.src}
            alt={photo.alt}
            widths={[200, 300, 400]}
            sizes="(max-width: 800px) 100vw, 300px"
            loading="lazy"
            formats={['avif', 'webp']}
            class="mx-auto h-64 w-full rounded-lg shadow-md object-cover"
          />
        ))}
      </div>

      <!-- Read More Testimonials Button -->
      <div class="mt-6 text-center flex justify-center">
        <a href="/conferences/" class="inline-block text-blue-600 text-lg font-semibold px-6 py-3 hover:underline transition">
          More Conferences Stories ->
        </a>
      </div>
    </section>

    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-gray-800">AI Advisor — Deployable, Governable AI Platforms</h2>
      <p class="text-lg leading-relaxed text-slate-500">
        AI Advisor helping enterprises translate AI ambition into <strong>deployable, governable platforms</strong>. I advise and design <strong>AI/ML and LLM-ready environments</strong> across hybrid cloud, with deep hands-on experience in <strong>OpenShift AI, multi-tenant GPU orchestration, and MLOps operating models</strong> (guardrails, quotas, cost control, day-2 operations). I work in regulated contexts with architecture aligned to <strong>SOC2/ISO27001</strong> controls. I also communicate at global scale: <strong>speaker at <a href="/blog/kubecon-europe-2026/" class="text-blue-500 hover:underline">KubeCon + CloudNativeCon Europe 2026 (Amsterdam)</a></strong> on multi-tenant GPUs on OpenShift AI, and <strong>speaker at <a href="/blog/red-hat-summit-2026/" class="text-blue-500 hover:underline">Red Hat Summit 2026 (Atlanta)</a></strong> on safety-first GPU multi-tenancy and platform engineering.
      </p>
      <p class="text-lg leading-relaxed text-slate-500 mt-4">
        Luca is the creator of the popular <a href="https://www.ansiblepilot.com/" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-lg font-semibold">Ansible Pilot</a> project and author of several best-selling technical books, including <a href="/blog/ansible-for-kubernetes-by-example/" class="text-blue-500 hover:underline">Ansible for Kubernetes by Example</a> and <a href="/blog/hands-on-ansible-automation/" class="text-blue-500 hover:underline">Hands-On Ansible Automation</a>. A former Red Hat engineer, he has made significant contributions to the open-source ecosystem, particularly in enhancing Ansible's capabilities for cloud and AI workloads.
      </p>
    </div>

    <!-- Conference Credibility -->
    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-12">
      <h2 class="font-bold text-2xl text-gray-800">Conference Speaking</h2>
      <ul class="list-disc list-inside text-lg text-slate-500 space-y-2">
        <li><strong><a href="/blog/kubecon-europe-2026/" class="text-blue-500 hover:underline">KubeCon + CloudNativeCon Europe 2026 (Amsterdam)</a></strong> — session: <em>"Lessons Learned Orchestrating Multi-Tenant GPUs on OpenShift AI with NVIDIA KAI (G/H200)"</em>, <strong>Tue Mar 24, 2026</strong>.</li>
        <li><strong><a href="/blog/red-hat-summit-2026/" class="text-blue-500 hover:underline">Red Hat Summit 2026 (Atlanta)</a></strong> — lightning talk: <em>"GPUs take flight: Safety-first multi-tenant Platform Engineering with NVIDIA and Red Hat OpenShift AI"</em>, <strong>Tue May 12, 2026</strong>.</li>
      </ul>
    </div>

    <!-- Core Specialties -->
    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-12">
      <h2 class="font-bold text-2xl text-gray-800">Core Specialties</h2>
      <ol class="list-decimal list-inside text-lg text-slate-500 space-y-2">
        <li><strong>AI Platform Strategy & Reference Architectures</strong> — build vs buy, governance, operating model</li>
        <li><strong>Multi-tenant GPU Platforms on OpenShift AI</strong> — isolation, scheduling, cost/chargeback, day-2 ops</li>
        <li><strong>MLOps / LLM & RAG Enablement</strong> — guardrails, productionization, security posture</li>
      </ol>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Bio</h3>
        <p class="text-slate-500 mt-2">
          From an early career in IT support to leading AI and cloud automation at global enterprises, I have always been passionate about
          technology innovation. My journey started with infrastructure optimization, leading to cloud and machine learning automation.
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Career Highlights</h3>
        <ul class="list-disc list-inside text-slate-500 mt-2">          <li>Speaker at KubeCon EU 2026 & Red Hat Summit 2026</li>          <li>Led AI-driven ESG solutions impacting 100+ SMEs</li>
          <li>Managed Automation & CI/CD pipelines at JPMorgan Chase & Co.</li>
          <li>Designed automation strategies for Red Hat’s Ansible</li>
          <li>Authored <a href="/books/" class="text-blue-500 hover:underline">books on Kubernetes & Ansible automation</a></li>
        </ul>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Certifications</h3>
        <ul class="list-disc list-inside text-slate-500 mt-2">
          <li>Architecting on AWS - AWS Training</li>
          <li>Red Hat Certified System Administrator</li>
          <li>Google IT Support Professional Certificate</li>
          <li>Linux Foundation Certified Engineer (LFCE)</li>
        </ul>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Publications</h3>
        <ul class="list-disc list-inside text-slate-500 mt-2">
          <li>Author of <a href="/blog/ansible-for-kubernetes-by-example/" class="text-blue-500 hover:underline">"Ansible for Kubernetes by Example"</a></li>
          <li><a href="/blog/hands-on-ansible-automation/" class="text-blue-500 hover:underline">Hands-on Ansible Automation</a> (BPB Publications)</li>
          <li>Courses on Pluralsight, Coursera, and Udemy</li>
        </ul>
      </div>
    </div>

    <div class="text-center mt-12">
      <h3 class="text-2xl font-semibold text-gray-700">Awards</h3>
      <p class="text-slate-500 mt-2">
        Honored to receive the <a href="https://cert.eccouncil.org/advisory-group.html" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline font-semibold">EC-Council award</a> for excellence in information security and cloud architecture. I'm also proud to serve as an Advisory Group Member for the 2025–2028 term, contributing to the advancement of global cybersecurity standards and practices.
      </p>
    </div>

    <div class="text-center mt-12">
      <h3 class="text-2xl font-semibold text-gray-700">Volunteering & Open Source Contributions</h3>
      <p class="text-slate-500 mt-2">
        As a co-founder of Free Software Users Group Padova, I actively support the Open Source community and mentor professionals in AI,
        DevOps, and automation best practices.
      </p>
    </div>

    <div class="text-center mt-12">
      <h3 class="text-2xl font-semibold text-gray-700">Publications & Courses</h3>
      <p class="text-slate-500 mt-2">
        I’ve authored multiple books and created online courses on AI, Kubernetes, and automation.<br />
        Explore my courses on:
      </p>
      <div class="flex justify-center gap-4 mt-4">
        <a href="https://www.udemy.com/user/luca-berton-3/" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-lg font-semibold">Udemy</a>
        <a href="https://app.pluralsight.com/profile/author/luca-berton" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-lg font-semibold">Pluralsight</a>
        <a href="https://www.coursera.org/instructor/~152261633" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-lg font-semibold">Coursera</a>
        <a href="https://orcid.org/0009-0009-6336-3670" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-lg font-semibold">ORCID</a>
      </div>
    </div>
    <Cta />
  </Container>
</Layout>
