---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { Picture } from "astro:assets";
import Cta from "@components/cta.astro"

export const prerender = true;
export const lastModified = '2025-03-25';

import cfgMgmtCamp2025 from "assets/photos/CfgMgmtCamp2025.jpg";
import cloudNativeLondon from "assets/photos/CloudNativeLondon.jpg";
import ansibleCommunityDayBerlin from "assets/photos/AnsibleCommunityDay2023.jpg";
import ansibleMeetupLondon from "assets/photos/AnsibleMeetupLondon2024.jpg";

const photos = [
  cfgMgmtCamp2025,
  cloudNativeLondon,
  ansibleCommunityDayBerlin,
  ansibleMeetupLondon
];
---

<Layout title="About Luca Berton">
  <Container>
    <Sectionhead>
      <Fragment slot="title">About Luca</Fragment>
      <Fragment slot="desc">AI & Cloud Advisor with 18+ years of expertise</Fragment>
    </Sectionhead>

    <!-- Image Gallery -->
    <section class="bg-white">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
        {photos.map((src, index) => (
          <Picture
            src={src}
            alt={`Conference Photo ${index + 1}`}
            widths={[200, 300, 400]}
            sizes="(max-width: 800px) 100vw, 300px"
            loading={index < 6 ? "eager" : "lazy"} 
            formats={['avif', 'webp']}
            class="mx-auto h-64 w-full rounded-lg shadow-md object-cover"
          />
        ))}
      </div>

      <!-- Read More Testimonials Button -->
      <div class="mt-6 text-center flex justify-center">
        <a href="/conferences/" class="inline-block text-blue-600 text-lg font-semibold px-6 py-3 hover:underline transition">
          More Conferences Stories ->
        </a>
      </div>
    </section>

    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-gray-800">Transforming Infrastructure with AI & Automation</h2>
      <p class="text-lg leading-relaxed text-slate-500">
        Luca Berton is a seasoned AI Automation and DevOps expert with over 18 years of experience in IT, specializing in cloud infrastructure, machine learning platforms, and enterprise-scale automation. He has led major AI and automation initiatives for financial institutions such as JPMorgan Chase, Société Générale, ABN Ambro and BPCE, designing GPU-accelerated Kubernetes/OpenShift AI clusters and optimizing CI/CD pipelines for regulated environments.
        Luca is the creator of the popular <a href="https://www.ansiblepilot.com/" class="text-blue-500 hover:underline text-lg font-semibold">Ansible Pilot</a> project and author of several best-selling technical books, including Ansible for Kubernetes by Example and Hands-On Ansible Automation. A former Red Hat engineer, he has made significant contributions to the open-source ecosystem, particularly in enhancing Ansible's capabilities for cloud and AI workloads.
        Widely recognized for his teaching and community leadership, Luca regularly shares his expertise through courses on Coursera, Pluralsight, and Educative, and speaks at global tech conferences on topics ranging from MLOps to infrastructure automation.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Bio</h3>
        <p class="text-slate-500 mt-2">
          From an early career in IT support to leading AI and cloud automation at global enterprises, I have always been passionate about
          technology innovation. My journey started with infrastructure optimization, leading to cloud and machine learning automation.
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Career Highlights</h3>
        <ul class="list-disc list-inside text-slate-500 mt-2">
          <li>Led AI-driven ESG solutions impacting 100+ SMEs</li>
          <li>Managed Automation & CI/CD pipelines at JPMorgan Chase & Co.</li>
          <li>Designed automation strategies for Red Hat’s Ansible</li>
          <li>Authored books on Kubernetes & Ansible automation</li>
        </ul>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Certifications</h3>
        <ul class="list-disc list-inside text-slate-500 mt-2">
          <li>Architecting on AWS - AWS Training</li>
          <li>Red Hat Certified System Administrator</li>
          <li>Google IT Support Professional Certificate</li>
          <li>Linux Foundation Certified Engineer (LFCE)</li>
        </ul>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Publications</h3>
        <ul class="list-disc list-inside text-slate-500 mt-2">
          <li>Author of "Ansible for Kubernetes by Example"</li>
          <li>Hands-on Ansible Automation (BPB Publications)</li>
          <li>Courses on Pluralsight, Coursera, and Udemy</li>
        </ul>
      </div>
    </div>

    <div class="text-center mt-12">
      <h3 class="text-2xl font-semibold text-gray-700">Awards</h3>
      <p class="text-slate-500 mt-2">
        Honored to receive the <a href="https://cert.eccouncil.org/advisory-group.html" class="text-blue-500 hover:underline font-semibold">EC-Council award</a> for excellence in information security and cloud architecture. I'm also proud to serve as an Advisory Group Member for the 2025–2028 term, contributing to the advancement of global cybersecurity standards and practices.
      </p>
    </div>

    <div class="text-center mt-12">
      <h3 class="text-2xl font-semibold text-gray-700">Volunteering & Open Source Contributions</h3>
      <p class="text-slate-500 mt-2">
        As a co-founder of Free Software Users Group Padova, I actively support the Open Source community and mentor professionals in AI,
        DevOps, and automation best practices.
      </p>
    </div>

    <div class="text-center mt-12">
      <h3 class="text-2xl font-semibold text-gray-700">Publications & Courses</h3>
      <p class="text-slate-500 mt-2">
        I’ve authored multiple books and created online courses on AI, Kubernetes, and automation.<br />
        Explore my courses on:
      </p>
      <div class="flex justify-center gap-4 mt-4">
        <a href="https://www.udemy.com/user/luca-berton-3/" class="text-blue-500 hover:underline text-lg font-semibold">Udemy</a>
        <a href="https://app.pluralsight.com/profile/author/luca-berton" class="text-blue-500 hover:underline text-lg font-semibold">Pluralsight</a>
        <a href="https://www.coursera.org/instructor/~152261633" class="text-blue-500 hover:underline text-lg font-semibold">Coursera</a>
        <a href="https://orcid.org/0009-0009-6336-3670" class="text-blue-500 hover:underline text-lg font-semibold">ORCID</a>
      </div>
    </div>
    <Cta />
  </Container>
</Layout>
