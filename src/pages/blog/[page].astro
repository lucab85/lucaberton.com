---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import BlogSearch from "@components/BlogSearch.astro";
import Pagination from "@components/Pagination.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import slugify from "slugify";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => {
    return !data.draft && data.publishDate < new Date();
  });
  const POSTS_PER_PAGE = 12;
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return [
    ...Array.from({ length: totalPages - 1 }, (_, i) => ({
      params: { page: String(i + 2) },
    })),
    // Redirect out-of-range legacy pagination pages to last valid page
    ...Array.from({ length: 20 }, (_, i) => totalPages + i + 1)
      .map((p) => ({ params: { page: String(p) }, props: { outOfRange: true } })),
  ];
}

const currentPage = Number(Astro.params.page);

if (Astro.props.outOfRange) {
  return Astro.redirect("/blog/", 301);
}

const POSTS_PER_PAGE = 12;

const allPosts = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const start = (currentPage - 1) * POSTS_PER_PAGE;
const end = start + POSTS_PER_PAGE;
const posts = sortedPosts.slice(start, end);

// Category stats for pills
const categoryMap = new Map<string, number>();
allPosts.forEach(p => {
  const cat = p.data.category;
  categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
});
const topCategories = [...categoryMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);
---

<Layout title={`Blog — Page ${currentPage} — AI, Kubernetes & Cloud Articles`} description={`Page ${currentPage} of ${lastPage}: Expert articles on AI, Kubernetes, Ansible, Platform Engineering, and cloud infrastructure by Luca Berton — AI & Cloud Advisor.`}>
  <meta name="robots" content="noindex, follow" slot="head" />
  {currentPage > 1 && <link rel="prev" href={currentPage === 2 ? "/blog/" : `/blog/${currentPage - 1}/`} slot="head" />}
  {currentPage < totalPages && <link rel="next" href={`/blog/${currentPage + 1}/`} slot="head" />}
  <Breadcrumb items={[{ name: "Blog", url: "/blog/" }, { name: `Page ${currentPage}` }]} />
  <Container>
    <div class="mt-16 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">Blog</h1>
      <p class="text-lg mt-4 text-slate-500 mx-auto max-w-xl">
        {allPosts.length}+ articles — Page {currentPage} of {totalPages}
      </p>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <BlogSearch />
      <div class="flex gap-4">
        <a href="/blog/search/" class="text-blue-600 hover:text-blue-800 font-medium text-sm">🔍 Search</a>
        <a href="/blog/categories/" class="text-blue-600 hover:text-blue-800 font-medium text-sm">📂 Categories</a>
      </div>
    </div>

    <!-- Category filter pills -->
    <div class="mt-6 flex flex-wrap gap-2 justify-center">
      <a href="/blog/" class="px-4 py-1.5 rounded-full text-sm font-medium bg-blue-600 text-white">
        All ({allPosts.length})
      </a>
      {topCategories.map(([cat, count]) => (
        <a
          href={`/blog/categories/${slugify(cat, { lower: true, strict: true })}/`}
          class="px-4 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-blue-50 hover:text-blue-700 transition"
        >
          {cat} ({count})
        </a>
      ))}
    </div>

    <main class="mt-12">
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post, index) => (
          <li class="group">
            <a href={`/blog/${post.slug}/`} class="block h-full">
              <div class="bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-blue-200 hover:shadow-md transition-all h-full flex flex-col">
                <div class="relative overflow-hidden">
                  <Picture
                    src={post.data.image.src}
                    alt={post.data.image.alt}
                    sizes="(max-width: 800px) 100vw, 400px"
                    width={800}
                    height={420}
                    loading={index <= 2 ? "eager" : "lazy"}
                    decoding={index <= 2 ? "sync" : "async"}
                    class="w-full object-cover aspect-video group-hover:scale-105 transition-transform duration-300"
                  />
                  <span class="absolute top-3 left-3 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-white/90 text-gray-700 backdrop-blur-sm">
                    {post.data.category}
                  </span>
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <h2 class="text-lg font-semibold leading-snug tracking-tight group-hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-gray-500 text-sm mt-2 line-clamp-2 flex-1">
                    {post.data.snippet}
                  </p>
                  <div class="flex items-center gap-2 mt-4 pt-3 border-t border-gray-50 text-xs text-gray-400">
                    <span>{post.data.author}</span>
                    <span>•</span>
                    <time datetime={post.data.publishDate.toISOString()}>
                      {post.data.publishDate.toDateString()}
                    </time>
                  </div>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <Pagination currentPage={currentPage} totalPages={totalPages} />
    </main>
  </Container>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
