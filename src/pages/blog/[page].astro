---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

// Get static paths for pagination
export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => {
    return !data.draft && data.publishDate < new Date();
  });
  const POSTS_PER_PAGE = 6;
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
  }));
}

// Dynamic route param
const page = Number(Astro.params.page);
const POSTS_PER_PAGE = 6;

// Fetch + sort all posts
const allPosts = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const start = (page - 1) * POSTS_PER_PAGE;
const end = start + POSTS_PER_PAGE;
const posts = sortedPosts.slice(start, end);
---

<Layout title="Blog">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Our Blog</Fragment>
      <Fragment slot="desc">
        We write about building startups and thoughts going on our mind.
      </Fragment>
    </Sectionhead>

    <main class="mt-16">
      <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-10 lg:gap-16">
        {posts.map((post, index) => (
          <li>
            <a href={`/blog/${post.slug}`}>
              <div>
                <Picture
                  src={post.data.image.src}
                  alt={post.data.image.alt}
                  sizes="(max-width: 800px) 100vw, 800px"
                  width={800}
                  height={600}
                  loading={index <= 2 ? "eager" : "lazy"}
                  decoding={index <= 2 ? "sync" : "async"}
                  class="w-full rounded-md object-cover"
                />
                <div class="mt-4">
                  <span class="text-blue-400 uppercase tracking-wider text-xs font-medium">
                    {post.data.category}
                  </span>
                  <h2 class="text-xl font-semibold leading-snug tracking-tight mt-1">
                    {post.data.title}
                  </h2>
                  <div class="flex gap-2 mt-3 text-sm">
                    <span class="text-gray-400">{post.data.author}</span>
                    <span class="text-gray-400">•</span>
                    <time
                      class="text-gray-400"
                      datetime={post.data.publishDate.toISOString()}>
                      {post.data.publishDate.toDateString()}
                    </time>
                  </div>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <div class="flex justify-center items-center mt-12 gap-2 flex-wrap text-sm">
        {page > 1 && (
          <a
            href={page - 1 === 1 ? `/blog` : `/blog/${page - 1}`}
            rel="prev"
            class="px-3 py-1 rounded-md bg-gray-100 hover:bg-gray-200 transition"
          >
            ← Prev
          </a>
        )}

        {Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) => {
          const isCurrent = pageNum === page;
          return (
            <a
              href={pageNum === 1 ? `/blog` : `/blog/${pageNum}`}
              aria-current={isCurrent ? "page" : undefined}
              class={`px-3 py-1 rounded-md transition ${
                isCurrent
                  ? "bg-blue-500 text-white"
                  : "bg-gray-100 hover:bg-gray-200"
              }`}
            >
              {pageNum}
            </a>
          );
        })}

        {page < totalPages && (
          <a
            href={`/blog/${page + 1}`}
            rel="next"
            class="px-3 py-1 rounded-md bg-gray-100 hover:bg-gray-200 transition"
          >
            Next →
          </a>
        )}
      </div>
    </main>
  </Container>
</Layout>
