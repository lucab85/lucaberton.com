---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import ShareButtons from "@components/ShareButtons.astro";
import RelatedServices from "@components/RelatedServices.astro";
import AuthorBox from "@components/AuthorBox.astro";
import ReadingProgress from "@components/ReadingProgress.astro";
import TableOfContents from "@components/TableOfContents.astro";
import BlogPromoCard from "@components/BlogPromoCard.astro";
import { getReadingTime } from "@utils/readingTime";

// Generate a new path for every collection entry
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  const paths = blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
  
  // Add fallback redirects for legacy URLs that are causing 404s
  const legacyRedirects = [
    { params: { slug: "complete-guide-fullstack-development" }, props: { redirect: "/blog/" } },
    { params: { slug: "how-to-become-frontend-master" }, props: { redirect: "/blog/" } },
    { params: { slug: "coursera_google-cloud-platform-fundamentals.it" }, props: { redirect: "/blog/" } },
    { params: { slug: "kubernetes.it" }, props: { redirect: "/blog/categories/kubernetes/" } },
    { params: { slug: "responsivedesign" }, props: { redirect: "/blog/responsive-design-snippets/" } },
    { params: { slug: "siteimprovement.it" }, props: { redirect: "/blog/" } },
    { params: { slug: "redhat_do280" }, props: { redirect: "/blog/categories/automation/" } },
    { params: { slug: "kcs_googletags" }, props: { redirect: "/blog/" } },
    { params: { slug: "bitcoin" }, props: { redirect: "/blog/" } },
    { params: { slug: "webfundamentals" }, props: { redirect: "/blog/" } },
    { params: { slug: "coursera_google-it-support" }, props: { redirect: "/blog/" } },
    { params: { slug: "languagecert_international_esol_selt_b1" }, props: { redirect: "/blog/" } },
    { params: { slug: "services" }, props: { redirect: "/services/" } },
    { params: { slug: "5" }, props: { redirect: "/blog/" } },
    { params: { slug: "4" }, props: { redirect: "/blog/" } },
  ];
  
  return [...paths, ...legacyRedirects];
}

// Handle redirects for legacy URLs
const { entry, redirect } = Astro.props;
if (redirect) {
  return Astro.redirect(redirect, 301);
}

// Get the entry directly from the prop on render
const { Content, headings } = await entry.render();

// Calculate reading time from raw body
const readingTime = getReadingTime(entry.body || '');

// Get related posts (same category, excluding current)
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p => p.slug !== entry.slug && p.data.category === entry.data.category)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 4);

// BlogPosting structured data
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": entry.data.title,
  "description": entry.data.snippet,
  "author": { "@type": "Person", "name": entry.data.author || "Luca Berton", "url": "https://lucaberton.com" },
  "publisher": { "@type": "Organization", "name": "Luca Berton", "url": "https://lucaberton.com", "logo": { "@type": "ImageObject", "url": "https://lucaberton.com/opengraph.jpg" } },
  "datePublished": entry.data.publishDate,
  "dateModified": entry.data.lastModified || entry.data.publishDate,
  "image": entry.data.image?.src ? `https://lucaberton.com${entry.data.image.src}` : "https://lucaberton.com/opengraph.jpg",
  "url": `https://lucaberton.com/blog/${entry.slug}/`,
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://lucaberton.com/blog/${entry.slug}/` },
  "articleSection": entry.data.category,
  "keywords": entry.data.tags?.join(", ") || ""
};

const postUrl = `https://lucaberton.com/blog/${entry.slug}/`;
const hasImage = entry.data.image?.src;
---

<Layout 
  title={entry.data.seoTitle || entry.data.title}
  description={entry.data.snippet}
  image={entry.data.image?.src}
>
<ReadingProgress />
<script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
<Breadcrumb items={[{ name: "Blog", url: "/blog/" }, { name: entry.data.title }]} />

<!-- Hero Image (full-bleed like XDA) -->
{hasImage && (
  <div class="w-full max-w-5xl mx-auto mt-6 px-4 sm:px-6">
    <img
      src={entry.data.image.src}
      alt={entry.data.image.alt || entry.data.title}
      class="w-full rounded-2xl object-cover max-h-[420px]"
      loading="eager"
      decoding="async"
    />
  </div>
)}

<Container>
  <article class="mx-auto max-w-3xl">
    <!-- Article Header -->
    <header class="mt-8 mb-8">
      <a
        href={`/blog/categories/${entry.data.category?.toLowerCase().replace(/\s+/g, '-')}/`}
        class="inline-block text-blue-600 uppercase tracking-wider text-xs font-bold hover:text-blue-800 transition-colors"
      >
        {entry.data.category}
      </a>
      <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold text-gray-900 mt-2 leading-tight tracking-tight">
        {entry.data.title}
      </h1>
      <p class="text-lg text-gray-500 mt-3 leading-relaxed">
        {entry.data.snippet}
      </p>

      <!-- Author mini-row (XDA style) -->
      <div class="flex items-center gap-3 mt-5 pt-5 border-t border-gray-100">
        <a href="/about/" class="flex-shrink-0">
          <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold">
            LB
          </div>
        </a>
        <div class="flex flex-col">
          <a href="/about/" class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition-colors">
            {entry.data.author || "Luca Berton"}
          </a>
          <div class="flex items-center gap-2 text-xs text-gray-400">
            <time datetime={entry.data.publishDate.toISOString()}>
              {entry.data.publishDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
            <span>·</span>
            <span>{readingTime}</span>
          </div>
        </div>
        <!-- Share icons inline (XDA style) -->
        <div class="ml-auto flex items-center gap-2">
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-300 hover:text-blue-700 transition-colors"
            aria-label="Share on LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(postUrl)}&via=TheLucaBerton`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-300 hover:text-black transition-colors"
            aria-label="Share on X"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </header>

    <!-- Table of Contents -->
    <TableOfContents headings={headings} />

    <!-- Article Body with mid-article promos -->
    <div class="prose prose-lg prose-gray max-w-none
      prose-headings:font-extrabold prose-headings:tracking-tight
      prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:border-b prose-h2:border-gray-100 prose-h2:pb-2
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:leading-[1.8] prose-p:text-gray-700
      prose-li:leading-[1.8] prose-li:text-gray-700
      prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-a:font-medium
      prose-img:rounded-xl prose-img:shadow-sm
      prose-code:text-sm prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none
      prose-pre:rounded-xl prose-pre:bg-[#1e293b] prose-pre:shadow-lg
      prose-blockquote:border-blue-500 prose-blockquote:bg-blue-50/30 prose-blockquote:rounded-r-lg prose-blockquote:py-1 prose-blockquote:not-italic
      prose-table:text-sm
      prose-th:bg-gray-50 prose-th:font-semibold
    " id="article-content">
      <Content />
    </div>

    <!-- Mid-article promo cards (injected via JS after render) -->
    <div id="promo-newsletter" class="hidden">
      <BlogPromoCard variant="newsletter" />
    </div>
    <div id="promo-book" class="hidden">
      <BlogPromoCard variant="book" />
    </div>
    <div id="promo-course" class="hidden">
      <BlogPromoCard variant="course" />
    </div>

    <!-- Bottom section -->
    <footer class="mt-12">
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-6">
        {entry.data.tags.map((tag) => (
          <span class="text-xs font-medium text-gray-500 bg-gray-100 px-3 py-1 rounded-full hover:bg-gray-200 transition-colors">
            #{tag}
          </span>
        ))}
      </div>

      <!-- Share bar (bottom) -->
      <ShareButtons title={entry.data.title} url={postUrl} />

      <!-- Service promotion -->
      <RelatedServices category={entry.data.category} tags={entry.data.tags || []} />

      <!-- Newsletter CTA -->
      <div class="my-10 rounded-2xl bg-gradient-to-br from-blue-600 to-blue-800 text-white p-8 text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-200 mb-2">📬 Don't miss the next one</p>
        <h3 class="text-xl font-bold mb-2">Get AI & Cloud insights delivered weekly</h3>
        <p class="text-blue-100 text-sm mb-5 max-w-md mx-auto">
          Join engineers getting practical tips on AI, Kubernetes, Ansible, and Platform Engineering.
        </p>
        <a
          href="https://luca-berton.kit.com/ce74a48bfa"
          target="_blank"
          rel="noopener"
          class="inline-block bg-white text-blue-700 font-bold text-sm px-6 py-3 rounded-lg hover:bg-blue-50 transition-colors"
        >
          Subscribe Free →
        </a>
      </div>

      <!-- Author box (full, bottom) -->
      <AuthorBox />
    </footer>
  </article>

  <!-- Related Articles (wider grid like XDA) -->
  {relatedPosts.length > 0 && (
    <div class="mx-auto max-w-5xl mt-16 mb-8">
      <h2 class="text-xl font-extrabold text-gray-900 mb-6 uppercase tracking-wider text-center">Related Articles</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {relatedPosts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="group block">
            <article class="rounded-xl overflow-hidden border border-gray-100 hover:border-blue-400 hover:shadow-xl transition-all h-full flex flex-col bg-white">
              {post.data.image?.src && (
                <img
                  src={post.data.image.src}
                  alt={post.data.image.alt || post.data.title}
                  class="w-full h-36 object-cover"
                  loading="lazy"
                />
              )}
              <div class="p-4 flex flex-col flex-1">
                <span class="text-blue-500 uppercase tracking-wider text-[10px] font-bold">
                  {post.data.category}
                </span>
                <h3 class="font-bold text-gray-900 mt-1 text-sm leading-snug group-hover:text-blue-700 transition-colors line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="text-xs text-gray-500 mt-2 line-clamp-2 flex-1">
                  {post.data.snippet}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="text-center mt-6 mb-12">
    <a
      href="/blog/"
      class="inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-blue-600 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      All Articles
    </a>
  </div>
</Container>
</Layout>

<!-- Mid-article promo injection script -->
<script is:inline>
(function() {
  const article = document.getElementById('article-content');
  if (!article) return;

  const h2s = article.querySelectorAll('h2');
  if (h2s.length < 3) return; // Only inject promos in longer articles

  const promos = [
    { id: 'promo-newsletter', insertAfterH2: 1 },
    { id: 'promo-book', insertAfterH2: Math.floor(h2s.length / 2) },
    { id: 'promo-course', insertAfterH2: h2s.length - 1 },
  ];

  promos.forEach(({ id, insertAfterH2 }) => {
    const source = document.getElementById(id);
    const targetH2 = h2s[insertAfterH2];
    if (!source || !targetH2) return;

    // Find the next sibling paragraph/element after the h2
    let insertPoint = targetH2;
    // Skip past the h2's content to find a good break point
    let count = 0;
    let sibling = targetH2.nextElementSibling;
    while (sibling && count < 2) {
      if (sibling.tagName === 'H2' || sibling.tagName === 'H3') break;
      insertPoint = sibling;
      sibling = sibling.nextElementSibling;
      count++;
    }

    const clone = source.firstElementChild?.cloneNode(true);
    if (clone) {
      insertPoint.parentNode.insertBefore(clone, insertPoint.nextSibling);
    }
  });

  // Clean up hidden source divs
  ['promo-newsletter', 'promo-book', 'promo-course'].forEach(id => {
    document.getElementById(id)?.remove();
  });
})();
</script>

<!-- Mermaid.js for diagrams -->
<script>
  import mermaid from 'mermaid';
  
  mermaid.initialize({
    startOnLoad: false,
    theme: 'neutral',
    securityLevel: 'loose',
    fontFamily: 'inherit',
  });

  async function renderMermaidDiagrams() {
    const mermaidDivs = document.querySelectorAll('.mermaid[data-chart]');
    for (const div of mermaidDivs) {
      const chart = div.getAttribute('data-chart');
      if (chart) {
        try {
          const { svg } = await mermaid.render(`mermaid-svg-${Math.random().toString(36).substr(2, 9)}`, chart);
          div.innerHTML = svg;
        } catch (e) {
          console.error('Mermaid rendering error:', e);
        }
      }
    }

    const selectors = [
      'pre > code.language-mermaid',
      'pre > code.astro-code-mermaid', 
      'pre code[class*="mermaid"]',
      '.astro-code.language-mermaid',
      'pre[data-language="mermaid"] > code',
      'pre.astro-code[data-language="mermaid"]'
    ];
    
    const codeBlocks = document.querySelectorAll(selectors.join(', '));
    
    for (const element of codeBlocks) {
      const pre = element.tagName === 'PRE' ? element : element.closest('pre');
      if (!pre || pre.dataset.mermaidProcessed) continue;
      pre.dataset.mermaidProcessed = 'true';
      
      const code = element.tagName === 'CODE' ? element : pre.querySelector('code');
      const chart = (code?.textContent || element.textContent || '').trim();
      
      if (!chart || !chart.includes('flowchart') && !chart.includes('graph') && !chart.includes('sequenceDiagram') && !chart.includes('classDiagram') && !chart.includes('stateDiagram') && !chart.includes('erDiagram') && !chart.includes('journey') && !chart.includes('gantt') && !chart.includes('pie') && !chart.includes('mindmap')) {
        continue;
      }
      
      const wrapper = document.createElement('div');
      wrapper.className = 'mermaid-wrapper my-8 flex flex-col items-center w-full';
      
      const mermaidDiv = document.createElement('div');
      mermaidDiv.className = 'mermaid bg-slate-50 rounded-lg p-6 overflow-x-auto w-full';
      
      try {
        const { svg } = await mermaid.render(`mermaid-svg-${Math.random().toString(36).substr(2, 9)}`, chart);
        mermaidDiv.innerHTML = svg;
        wrapper.appendChild(mermaidDiv);
        pre.replaceWith(wrapper);
      } catch (e) {
        console.error('Mermaid rendering error for chart:', chart.substring(0, 50), e);
      }
    }
    
    const allPres = document.querySelectorAll('pre:not([data-mermaid-processed])');
    for (const pre of allPres) {
      const text = pre.textContent || '';
      if (text.trim().startsWith('flowchart') || text.trim().startsWith('graph') || 
          text.trim().startsWith('sequenceDiagram') || text.trim().startsWith('classDiagram')) {
        pre.dataset.mermaidProcessed = 'true';
        
        const wrapper = document.createElement('div');
        wrapper.className = 'mermaid-wrapper my-8 flex flex-col items-center w-full';
        
        const mermaidDiv = document.createElement('div');
        mermaidDiv.className = 'mermaid bg-slate-50 rounded-lg p-6 overflow-x-auto w-full';
        
        try {
          const { svg } = await mermaid.render(`mermaid-svg-${Math.random().toString(36).substr(2, 9)}`, text.trim());
          mermaidDiv.innerHTML = svg;
          wrapper.appendChild(mermaidDiv);
          pre.replaceWith(wrapper);
        } catch (e) {
          console.error('Mermaid fallback rendering error:', e);
        }
      }
    }
  }

  document.addEventListener('DOMContentLoaded', renderMermaidDiagrams);
  document.addEventListener('astro:page-load', renderMermaidDiagrams);
</script>

<style is:global>
  .mermaid-wrapper {
    width: 100%;
    max-width: none !important;
    margin: 2rem -2rem;
    padding: 0 2rem;
  }
  
  .mermaid-wrapper .mermaid {
    min-width: 100%;
    width: max-content;
    max-width: 100vw;
  }
  
  .mermaid svg {
    max-width: none !important;
    width: auto !important;
    min-width: 600px;
    height: auto;
    font-size: 14px;
  }
  
  .mermaid .node rect,
  .mermaid .node circle,
  .mermaid .node ellipse,
  .mermaid .node polygon {
    stroke-width: 2px;
  }
  
  .mermaid .edgeLabel {
    font-size: 12px;
  }
  
  .mermaid .label {
    font-size: 14px;
  }
  
  @media (max-width: 768px) {
    .mermaid-wrapper {
      margin: 2rem -1rem;
      padding: 0 1rem;
      overflow-x: auto;
    }
    
    .mermaid svg {
      min-width: 500px;
    }
  }
</style>
