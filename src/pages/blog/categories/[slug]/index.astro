---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import { Picture } from "astro:assets";
import { SITE } from "../../../../config.mjs";
import getUniqueCategories from "@utils/getUniqueCategories";

// Generate static paths
export const getStaticPaths = async () => {
  const categories = await getUniqueCategories();

  return categories.map(category => ({
    params: { slug: category.slug },
    props: { category: category.category },
  }));
};

const { category } = Astro.props;

// Get all blog posts
const allPosts = await getCollection("blog");
const categoryPosts = allPosts
  .filter(post => {
    const cats = post.data.categories ?? post.data.category;
    return Array.isArray(cats) ? cats.includes(category) : cats === category;
  })
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Generate SEO-friendly meta description
const metaDescription = `Browse ${categoryPosts.length} articles about ${category}. Expert insights on ${category} by Luca Berton.`;

// Structured data for category page
const categoryStructuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${category} Articles`,
  "description": metaDescription,
  "url": `https://lucaberton.com/blog/categories/${category.toLowerCase().replace(/\s+/g, "-")}/`,
  "author": {
    "@type": "Person",
    "name": "Luca Berton",
    "url": "https://lucaberton.com/"
  },
  "publisher": {
    "@type": "Organization", 
    "name": "Luca Berton",
    "url": "https://lucaberton.com/"
  },
  "numberOfItems": categoryPosts.length,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": categoryPosts.length,
    "itemListElement": categoryPosts.slice(0, 10).map((post, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "BlogPosting",
        "headline": post.data.title,
        "url": `https://lucaberton.com/blog/${post.slug}/`,
        "datePublished": post.data.publishDate,
        "author": {
          "@type": "Person",
          "name": post.data.author || "Luca Berton"
        }
      }
    }))
  }
};
---

<Layout title={category}>
  <!-- Category Page Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(categoryStructuredData)}></script>
  
  <!-- Additional SEO meta tags -->
  <meta name="description" content={metaDescription} slot="head" />
  <meta property="og:description" content={metaDescription} slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta name="robots" content="index, follow" slot="head" />
  <Container>
    <div class="mt-16 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">{category}</h1>
      <p class="text-lg mt-4 text-slate-500 mx-auto max-w-xl">
        All posts in the "{category}" category
      </p>
    </div>

    <main class="mt-16">
      {categoryPosts.length > 0 ? (
        <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-10 lg:gap-16">
          {categoryPosts.map((post, index) => (
            <li>
              <a href={`/blog/${post.slug}/`}>
                <div>
                  {post.data.image?.src && (
                    <Picture
                      src={post.data.image.src}
                      alt={post.data.image.alt}
                      sizes="(max-width: 800px) 100vw, 800px"
                      width={800}
                      height={600}
                      loading={index <= 2 ? "eager" : "lazy"}
                      decoding={index <= 2 ? "sync" : "async"}
                      class="w-full rounded-md object-cover"
                    />
                  )}
                  <div class="mt-4">
                    {post.data.category && (
                      <span class="text-blue-400 uppercase tracking-wider text-xs font-medium">
                        {post.data.category}
                      </span>
                    )}
                    <h2 class="text-xl font-semibold leading-snug tracking-tight mt-1">
                      {post.data.title}
                    </h2>
                    <div class="flex gap-2 mt-3 text-sm text-gray-400">
                      <span>{post.data.author}</span>
                      <span>•</span>
                      <time datetime={post.data.publishDate.toISOString()}>
                        {post.data.publishDate.toDateString()}
                      </time>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="text-center py-12">
          <h2 class="text-xl font-semibold mb-4">No posts found.</h2>
          <p class="text-gray-500">We’re still working on adding content for this category.</p>
        </div>
      )}
    </main>
  </Container>
</Layout>
