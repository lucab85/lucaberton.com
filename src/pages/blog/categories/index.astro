---
import Layout from "@layouts/Layout.astro";
import getUniqueCategories from "@utils/getUniqueCategories";
import Category from "@components/Category";
import Breadcrumb from "@components/Breadcrumb.astro";

let categories = await getUniqueCategories();
---

<Layout title="Blog Categories — AI, Cloud & DevOps Topics" description="Browse all blog categories covering AI, Kubernetes, Ansible, platform engineering, DevOps, cloud security, and more by Luca Berton.">
<Breadcrumb items={[{ name: "Blog", url: "/blog/" }, { name: "Categories" }]} />
<main class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-2">Categories</h1>
  <p class="mb-6 text-gray-500">All categories and areas our blog cover.</p>

  {
    categories.length ? (
      <ul>
        {categories.map(({ category, lastPost }) => (
          <Category
            client:load
            title={category}
            {lastPost}
          />
        ))}
      </ul>
    ) : (
      <div class="flex flex-col items-center justify-center gap-6">
        <h2 class="text-xl font-bold tracking-wide">
          Empty categories list!
        </h2>
        <p>We're working to add new content and cover different categories</p>
        <p class="block text-lg font-medium text-gray-500">
          Stay tuned!
        </p>
      </div>
    )
  }
</main>
</Layout>
