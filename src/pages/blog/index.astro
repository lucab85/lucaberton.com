---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";

import Pagination from "@components/Pagination.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import { Picture } from "astro:assets";
import slugify from "slugify";

export const prerender = true;

const POSTS_PER_PAGE = 12;
const currentPage = 1;
const allPosts = await getCollection("blog", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});
const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const posts = sortedPosts.slice(0, POSTS_PER_PAGE);
const featuredPost = posts[0];
const gridPosts = posts.slice(1);

// Category stats
const categoryMap = new Map<string, number>();
allPosts.forEach(p => {
  const cat = p.data.category;
  categoryMap.set(cat, (categoryMap.get(cat) || 0) + 1);
});
const topCategories = [...categoryMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

// Popular tags
const tagMap = new Map<string, number>();
allPosts.forEach(p => {
  (p.data.tags || []).forEach((t: string) => {
    tagMap.set(t, (tagMap.get(t) || 0) + 1);
  });
});
const topTags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20);
---

<Layout title="Blog — AI, Kubernetes & Cloud Articles" description="Expert articles on AI, Kubernetes, Ansible, Platform Engineering, and cloud infrastructure by Luca Berton. Practical guides and industry insights.">
  <Breadcrumb items={[{ name: "Blog" }]} />
  <Container>
    <!-- Hero header -->
    <div class="mt-16 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">Blog</h1>
      <p class="text-lg mt-4 text-slate-500 mx-auto max-w-xl">
        {allPosts.length}+ articles on AI, Kubernetes, Platform Engineering, and Cloud Infrastructure
      </p>
    </div>

    <!-- Instant search -->
    <div class="mt-10 max-w-2xl mx-auto">
      <div class="relative">
        <input
          type="text"
          id="blog-instant-search"
          placeholder="Search 800+ articles by keyword, topic, or technology..."
          class="w-full px-5 py-4 pl-14 rounded-2xl border-2 border-gray-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 outline-none transition text-lg"
          autocomplete="off"
        />
        <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <kbd class="absolute right-5 top-1/2 -translate-y-1/2 hidden sm:inline-block px-2 py-1 text-xs text-gray-400 bg-gray-100 rounded border border-gray-200">/</kbd>
      </div>
      <div id="instant-results" class="hidden mt-4 bg-white border border-gray-200 rounded-xl shadow-xl max-h-[70vh] overflow-y-auto z-50 relative"></div>
    </div>
    <div class="mt-4 flex gap-4 justify-center">
      <a href="/blog/search/" class="text-blue-600 hover:text-blue-800 font-medium text-sm">🔍 Advanced Search</a>
      <a href="/blog/categories/" class="text-blue-600 hover:text-blue-800 font-medium text-sm">📂 Categories</a>
    </div>

    <!-- Category filter pills -->
    <div class="mt-6 flex flex-wrap gap-2 justify-center">
      <a
        href="/blog/"
        class="px-4 py-1.5 rounded-full text-sm font-medium bg-blue-600 text-white"
      >
        All ({allPosts.length})
      </a>
      {topCategories.map(([cat, count]) => (
        <a
          href={`/blog/categories/${slugify(cat, { lower: true, strict: true })}/`}
          class="px-4 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-blue-50 hover:text-blue-700 transition"
        >
          {cat} ({count})
        </a>
      ))}
    </div>

    <main class="mt-12">
      <!-- Featured / hero post -->
      <a href={`/blog/${featuredPost.slug}/`} class="block group mb-12">
        <div class="grid md:grid-cols-2 gap-8 items-center bg-gradient-to-br from-slate-50 to-slate-100 rounded-2xl p-6 md:p-8 hover:shadow-lg transition-shadow">
          <Picture
            src={featuredPost.data.image.src}
            alt={featuredPost.data.image.alt}
            sizes="(max-width: 800px) 100vw, 600px"
            width={800}
            height={420}
            loading="eager"
            decoding="sync"
            class="w-full rounded-xl object-cover aspect-video"
          />
          <div>
            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 uppercase tracking-wider">
              {featuredPost.data.category}
            </span>
            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 ml-2">
              Latest
            </span>
            <h2 class="text-2xl md:text-3xl font-bold mt-3 group-hover:text-blue-600 transition-colors leading-tight">
              {featuredPost.data.title}
            </h2>
            <p class="text-gray-500 mt-3 line-clamp-3 text-base">
              {featuredPost.data.snippet}
            </p>
            <div class="flex items-center gap-3 mt-4 text-sm text-gray-400">
              <span>{featuredPost.data.author}</span>
              <span>•</span>
              <time datetime={featuredPost.data.publishDate.toISOString()}>
                {featuredPost.data.publishDate.toDateString()}
              </time>
            </div>
            <span class="inline-flex items-center gap-1 mt-4 text-blue-600 font-medium text-sm group-hover:gap-2 transition-all">
              Read article
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>
      </a>

      <!-- Post grid (remaining posts) -->
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {gridPosts.map((post, index) => (
          <li class="group">
            <a href={`/blog/${post.slug}/`} class="block h-full">
              <div class="bg-white rounded-xl overflow-hidden border border-gray-100 hover:border-blue-200 hover:shadow-md transition-all h-full flex flex-col">
                <div class="relative overflow-hidden">
                  <Picture
                    src={post.data.image.src}
                    alt={post.data.image.alt}
                    sizes="(max-width: 800px) 100vw, 400px"
                    width={800}
                    height={420}
                    loading={index <= 2 ? "eager" : "lazy"}
                    decoding={index <= 2 ? "sync" : "async"}
                    class="w-full object-cover aspect-video group-hover:scale-105 transition-transform duration-300"
                  />
                  <span class="absolute top-3 left-3 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-white/90 text-gray-700 backdrop-blur-sm">
                    {post.data.category}
                  </span>
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <h2 class="text-lg font-semibold leading-snug tracking-tight group-hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-gray-500 text-sm mt-2 line-clamp-2 flex-1">
                    {post.data.snippet}
                  </p>
                  <div class="flex items-center gap-2 mt-4 pt-3 border-t border-gray-50 text-xs text-gray-400">
                    <span>{post.data.author}</span>
                    <span>•</span>
                    <time datetime={post.data.publishDate.toISOString()}>
                      {post.data.publishDate.toDateString()}
                    </time>
                  </div>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <Pagination currentPage={currentPage} totalPages={totalPages} />
    </main>

    <!-- Popular tags section -->
    <section class="mt-16 mb-12 text-center">
      <h2 class="text-xl font-bold mb-4">Popular Topics</h2>
      <div class="flex flex-wrap gap-2 justify-center max-w-3xl mx-auto">
        {topTags.map(([tag, count]) => (
          <a
            href={`/blog/search/?q=${encodeURIComponent(tag)}`}
            class="px-3 py-1 rounded-lg text-sm bg-slate-100 text-slate-600 hover:bg-blue-50 hover:text-blue-700 transition"
          >
            #{tag} <span class="text-slate-400 text-xs">({count})</span>
          </a>
        ))}
      </div>
    </section>
  </Container>
</Layout>

<script define:vars={{ searchData: sortedPosts.map(p => ({ s: p.slug, t: p.data.title, n: p.data.snippet, c: p.data.category, g: (p.data.tags || []).join(' '), i: p.data.image?.src || '', d: p.data.publishDate.toDateString() })) }}>
  const input = document.getElementById('blog-instant-search');
  const resultsDiv = document.getElementById('instant-results');
  if (input && resultsDiv) {
    // "/" keyboard shortcut
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== input && !['INPUT','TEXTAREA'].includes(document.activeElement?.tagName)) {
        e.preventDefault();
        input.focus();
      }
      if (e.key === 'Escape') {
        resultsDiv.classList.add('hidden');
        input.blur();
      }
    });
    let timer;
    input.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => {
        const q = input.value.trim().toLowerCase();
        if (q.length < 2) { resultsDiv.classList.add('hidden'); return; }
        const words = q.split(/\s+/);
        const hits = searchData.filter(p => {
          const hay = (p.t + ' ' + p.n + ' ' + p.c + ' ' + p.g).toLowerCase();
          return words.every(w => hay.includes(w));
        }).slice(0, 15);
        if (hits.length === 0) {
          resultsDiv.innerHTML = '<div class="p-6 text-center text-gray-500">No results found. Try different keywords.</div>';
        } else {
          resultsDiv.innerHTML = hits.map(p => `<a href="/blog/${p.s}/" class="flex items-start gap-4 p-4 hover:bg-blue-50 transition border-b border-gray-100 last:border-0"><img src="${p.i}" alt="" class="w-20 h-14 rounded object-cover flex-shrink-0" loading="lazy"/><div class="min-w-0"><div class="font-semibold text-sm leading-tight line-clamp-1">${esc(p.t)}</div><div class="text-xs text-gray-500 mt-1 line-clamp-1">${esc(p.n)}</div><div class="text-xs text-gray-400 mt-1"><span class="text-blue-500">${esc(p.c)}</span> · ${p.d}</div></div></a>`).join('') + `<div class="p-3 text-center border-t"><a href="/blog/search/?q=${encodeURIComponent(input.value)}" class="text-blue-600 text-sm font-medium hover:underline">See all results →</a></div>`;
        }
        resultsDiv.classList.remove('hidden');
      }, 150);
    });
    input.addEventListener('focus', () => { if (input.value.trim().length >= 2) resultsDiv.classList.remove('hidden'); });
    document.addEventListener('click', (e) => { if (!e.target.closest('#blog-instant-search') && !e.target.closest('#instant-results')) resultsDiv.classList.add('hidden'); });
    function esc(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
  }
</script>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
