---
export async function getStaticPaths() {
  return [
    { params: { slug: "educational-technology" } },
    { params: { slug: "kubernetes" } },
    { params: { slug: "automation" } },
    { params: { slug: "books" } },
    { params: { slug: "open-source" } },
    { params: { slug: "conferences" } },
  ];
}

const { slug } = Astro.params;

// Redirect to the correct blog category URL
return Astro.redirect(`/blog/categories/${slug}`, 301);
---