---

<Layout title="Conferences - Global Tech Speaker">

  <!-- Hero Section with Gradient -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-blue-900 to-indigo-900 text-white">
    <!-- Animated Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-sm font-medium mb-6">
          <Icon name="bi:globe2" class="w-4 h-4" />
          Speaking Across the Globe
        </span>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight">
          <span class="block">Global Conferences</span>
          <span class="block mt-2 bg-gradient-to-r from-cyan-400 via-blue-400 to-purple-400 bg-clip-text text-transparent">
            Featuring Luca Berton
          </span>
        </h1>
        
        <p class="mt-6 text-lg sm:text-xl text-blue-100 max-w-3xl mx-auto">
          From KubeCon to FOSDEM, sharing insights on AI, Cloud Native, Ansible automation, 
          and DevOps practices at the world's most prestigious tech events.
        </p>
      </div>
      
      <!-- Stats Grid -->
      <div class="mt-16 grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-8">
        {stats.map((stat) => (
          <div class="group relative bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:scale-105">
            <div class="flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <Icon name={stat.icon} class="w-6 h-6 text-white" />
              </div>
              <span class="text-3xl sm:text-4xl font-bold text-white">{stat.number}</span>
              <span class="text-sm text-blue-200 mt-1">{stat.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Wave Divider -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Photo Gallery Section -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-3 py-1 text-sm font-semibold text-blue-600 bg-blue-100 rounded-full mb-4">
          On Stage & Behind the Scenes
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Conference Moments
        </h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Capturing the energy and connections from events around the world
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6">
        {photos.map((photo, index) => (
          <div class={`group relative overflow-hidden rounded-2xl shadow-lg ${index === 0 ? 'md:col-span-2 md:row-span-2' : ''}`}>
            <Picture
              src={photo.src}
              alt={photo.title}
              widths={index === 0 ? [400, 600, 800] : [200, 300, 400]}
              sizes={index === 0 ? "(max-width: 768px) 100vw, 66vw" : "(max-width: 768px) 50vw, 33vw"}
              loading={index < 4 ? "eager" : "lazy"}
              formats={['avif', 'webp']}
              class={`w-full object-cover transition-transform duration-500 group-hover:scale-110 ${index === 0 ? 'h-64 md:h-full' : 'h-48 lg:h-64'}`}
            />
            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-4 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                <p class="font-semibold text-lg">{photo.title}</p>
                <p class="text-sm text-gray-300 flex items-center gap-1">
                  <Icon name="bi:geo-alt" class="w-3 h-3" />
                  {photo.location}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Talks Section -->
  <section class="py-16 lg:py-24 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-3 py-1 text-sm font-semibold text-purple-600 bg-purple-100 rounded-full mb-4">
          Featured Content
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Talks & Presentations
        </h2>
        <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
          Deep-dives into AI, automation, and cloud-native technologies
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {Object.keys(details).map((key, index) => {
          const detail = details[key];
          const isUpcoming = new Date(detail.date) > new Date();
          const colors = [
            { border: "border-blue-500", bg: "bg-blue-500", text: "text-blue-600", light: "bg-blue-50" },
            { border: "border-purple-500", bg: "bg-purple-500", text: "text-purple-600", light: "bg-purple-50" },
            { border: "border-cyan-500", bg: "bg-cyan-500", text: "text-cyan-600", light: "bg-cyan-50" },
            { border: "border-emerald-500", bg: "bg-emerald-500", text: "text-emerald-600", light: "bg-emerald-50" },
            { border: "border-orange-500", bg: "bg-orange-500", text: "text-orange-600", light: "bg-orange-50" },
            { border: "border-pink-500", bg: "bg-pink-500", text: "text-pink-600", light: "bg-pink-50" },
          ];
          const color = colors[index % colors.length];
          
          return (
            <div class="group relative bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 overflow-hidden hover:-translate-y-1">
              {/* Top Accent Bar */}
              <div class={`h-1.5 ${color.bg}`}></div>
              
              <div class="p-6">
                {/* Header */}
                <div class="flex items-start justify-between mb-4">
                  <div>
                    {isUpcoming && (
                      <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-green-700 bg-green-100 rounded-full mb-2">
                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
                        Upcoming
                      </span>
                    )}
                    <h3 class={`text-xl font-bold ${color.text} group-hover:underline decoration-2 underline-offset-4`}>
                      {key}
                    </h3>
                  </div>
                  <div class={`p-2 rounded-lg ${color.light}`}>
                    <Icon name="bi:calendar-event" class={`w-5 h-5 ${color.text}`} />
                  </div>
                </div>
                
                {/* Date & Location */}
                <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 mb-4">
                  <span class="flex items-center gap-1">
                    <Icon name="bi:calendar3" class="w-4 h-4" />
                    {detail.date}
                  </span>
                  <span class="flex items-center gap-1">
                    <Icon name="bi:geo-alt" class="w-4 h-4" />
                    {detail.location}
                  </span>
                </div>
                
                {/* Description */}
                <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3">
                  {detail.description}
                </p>
                
                {/* Presentation Title */}
                <div class={`${color.light} rounded-lg p-3 mb-4`}>
                  <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Presentation</p>
                  <p class={`text-sm font-medium ${color.text}`}>{detail.presentation}</p>
                </div>
                
                {/* Links */}
                <div class="flex flex-wrap gap-2">
                  {detail.links.map((link) => (
                    <a 
                      href={link.url} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-100 rounded-full hover:bg-gray-200 transition-colors"
                    >
                      <Icon name="bi:box-arrow-up-right" class="w-3 h-3" />
                      {link.text}
                    </a>
                  ))}
                  {detail.blog && (
                    <a 
                      href={detail.blog}
                      class={`inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-white ${color.bg} rounded-full hover:opacity-90 transition-opacity`}
                    >
                      <Icon name="bi:journal-text" class="w-3 h-3" />
                      Read Recap
                    </a>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="py-16 lg:py-24 bg-slate-900 text-white relative overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-block px-3 py-1 text-sm font-semibold text-cyan-400 bg-cyan-400/10 rounded-full border border-cyan-400/20 mb-4">
          Complete History
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold">
          Conference Timeline
        </h2>
        <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
          Every event, meetup, and summit from 2022 to 2026
        </p>
      </div>

      <!-- Year Filters (Visual Only) -->
      <div class="flex flex-wrap justify-center gap-2 mb-10">
        {["2026", "2025", "2024", "2023", "2022"].map((year, i) => (
          <span class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${i === 0 ? 'bg-cyan-500 text-white' : 'bg-white/10 text-gray-300 hover:bg-white/20'}`}>
            {year}
          </span>
        ))}
      </div>

      <!-- Timeline Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {conferences.map((conf, index) => {
          const isUpcoming = conf.date.includes("2026") || (conf.date.includes("2025") && !["Jan", "Feb"].includes(conf.date.split(" ")[0]));
          const hasTalk = details[conf.name];
          
          return (
            <div class={`group relative bg-white/5 backdrop-blur-sm rounded-xl p-5 border border-white/10 hover:border-cyan-500/50 hover:bg-white/10 transition-all duration-300 ${isUpcoming ? 'ring-1 ring-cyan-500/30' : ''}`}>
              {/* Upcoming Badge */}
              {isUpcoming && (
                <div class="absolute -top-2 -right-2">
                  <span class="flex h-5 w-5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-5 w-5 bg-cyan-500 items-center justify-center">
                      <Icon name="bi:star-fill" class="w-2.5 h-2.5 text-white" />
                    </span>
                  </span>
                </div>
              )}
              
              {/* Date Badge */}
              <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-white/10 text-xs font-medium text-cyan-400 mb-3">
                <Icon name="bi:calendar3" class="w-3 h-3" />
                {conf.date}
              </div>
              
              {/* Conference Name */}
              {conf.url ? (
                <a 
                  href={conf.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="block text-lg font-semibold text-white hover:text-cyan-400 transition-colors mb-2 group-hover:underline decoration-cyan-400 underline-offset-4"
                >
                  {conf.name}
                </a>
              ) : (
                <h3 class="text-lg font-semibold text-white mb-2">{conf.name}</h3>
              )}
              
              {/* Location */}
              <p class="flex items-center gap-1.5 text-sm text-gray-400 mb-3">
                <Icon name="bi:geo-alt-fill" class="w-3.5 h-3.5 text-gray-500" />
                {conf.location}
              </p>
              
              {/* Organizer */}
              {conf.organizer && (
                <p class="text-xs text-gray-500 mb-3">
                  by {conf.organizer}
                </p>
              )}
              
              {/* Speaker/Blog Links */}
              <div class="flex items-center gap-2 mt-auto pt-2 border-t border-white/5">
                {hasTalk && (
                  <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-purple-400 bg-purple-400/10 rounded-md">
                    <Icon name="bi:mic-fill" class="w-3 h-3" />
                    Speaker
                  </span>
                )}
                {hasTalk?.blog && (
                  <a 
                    href={hasTalk.blog}
                    class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium text-cyan-400 bg-cyan-400/10 rounded-md hover:bg-cyan-400/20 transition-colors"
                  >
                    <Icon name="bi:arrow-right" class="w-3 h-3" />
                    Recap
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-20 bg-gradient-to-r from-blue-600 to-indigo-700 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Looking for a Speaker?
      </h2>
      <p class="text-lg text-blue-100 mb-8 max-w-2xl mx-auto">
        Invite Luca to speak at your next event about AI, Cloud Native, Kubernetes, or DevOps automation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact/" 
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-blue-600 bg-white rounded-xl hover:bg-blue-50 transition-colors shadow-lg"
        >
          <Icon name="bi:envelope" class="w-5 h-5" />
          Get in Touch
        </a>
        <a 
          href="https://calendly.com/lucaberton" 
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-white/20 backdrop-blur-sm rounded-xl hover:bg-white/30 transition-colors border border-white/30"
        >
          <Icon name="bi:calendar-check" class="w-5 h-5" />
          Book a Call
        </a>
      </div>
    </div>
  </section>

</Layout>
