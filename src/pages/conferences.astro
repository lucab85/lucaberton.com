---
import Layout from "@layouts/Layout.astro";
import { Picture } from "astro:assets";
export const prerender = true;
export const lastModified = '2025-03-25';

import cfgMgmtCamp2025 from "assets/photos/CfgMgmtCamp2025.jpg";
import cloudNativeLondon from "assets/photos/CloudNativeLondon.jpg";
import ansibleCommunityDayBerlin from "assets/photos/AnsibleCommunityDay2023.jpg";
import ansibleMeetupLondon from "assets/photos/AnsibleMeetupLondon2024.jpg";

const photos = [
  cfgMgmtCamp2025,
  cloudNativeLondon,
  ansibleCommunityDayBerlin,
  ansibleMeetupLondon
];

const conferences = [
  { date: "Apr 2025", name: "KubeCon EU", location: "London 🇬🇧", url: "https://kubecon.io/" },
  { date: "Mar 2025", name: "Dev World", location: "Amsterdam 🇳🇱", url: "https://www.developerweek.com/" },
  { date: "Feb 2025", name: "CfgMgmtCamp & Ansible Contributor Summit", location: "Ghent 🇧🇪", url: "https://cfgmgmtcamp.org/" },
  { date: "Feb 2025", name: "Fosdem", location: "Brussels 🇧🇪", url: "https://fosdem.org/2025/" },
  { date: "Sep 2024", name: "Ansible Meetup", location: "London 🇬🇧", url: "https://www.meetup.com/ansible-london/events/303113460/" },
  { date: "Jun 2024", name: "DevConf.cz", location: "Brno 🇨🇿", url: "https://www.devconf.info/cz/" },
  { date: "Apr 2024", name: "London Book Fair", location: "London 🇬🇧", url: "https://www.londonbookfair.co.uk/" },
  { date: "Feb 2024", name: "New Delhi World Book Fair", location: "New Delhi 🇮🇳", url: "https://www.newdelhiworldbookfair.gov.in/" },
  { date: "Dec 2023", name: "Cloud Native London", location: "London 🇬🇧", url: "https://www.meetup.com/cloud-native-london/events/293022845/" },
  { date: "Sep 2023", name: "Ansible Community Day", location: "Berlin 🇩🇪", url: "https://forum.ansible.com/t/agenda-for-ansible-community-day-berlin-2023/734" },
  { date: "Jul 2023", name: "Ansible Automates", location: "London 🇬🇧", url: "https://www.redhat.com/en/events/ansible-automates-london" },
  { date: "Jun 2023", name: "DevConf.cz", location: "Brno 🇨🇿", url: "https://www.devconf.info/cz/" },
  { date: "Jun 2022", name: "PGMeetUp Bari", location: "Bari 🇮🇹", url: "https://www.itpug.org/" },
  { date: "Feb 2022", name: "Ansible Anwendertreffen", location: "Germany 🇩🇪", url: "https://www.ansible-anwender.de/" },
];


const details = {
  "KubeCon EU": {
    description: "A flagship conference for Kubernetes and cloud native computing. Luca Berton attended KubeCon Europe 2025 in London, exploring innovations in cloud automation and DevOps.",
    date: "April 2025",
    location: "London 🇬🇧",
    links: [
      { text: "KubeCon Official Site", url: "https://kubecon.io/" }
    ],
    presentation: "Panel Participation: The Future of Infrastructure as Code in Kubernetes Environments",
    blog: "/blog/kubecon-europe-2025"
  },
  "Ansible Contributor Summit": {
    description: "A gathering of Ansible maintainers, contributors, and users to discuss the latest developments in Ansible.",
    date: "February 5, 2025",
    location: "Ghent 🇧🇪",
    links: [
      { text: "Event Agenda", url: "https://forum.ansible.com/t/ansible-contributor-summit-at-cfgmgmtcamp-2025/" }
    ],
    presentation: "Building a Community Around Ansible Pilot"
  },
  "CfgMgmtCamp Ghent": {
    description: "Join Luca Berton at CfgMgmtCamp 2025 as he presents a case study on automating Neo4j GenAI environments with Ansible for advanced AI-powered graph databases.",
    date: "February 3-5, 2025",
    location: "Ghent 🇧🇪",
    links: [
      { text: "Event Details", url: "https://cfgmgmtcamp.org/" }
    ],
    presentation: "Automating AI-Powered Graph Databases with Ansible: A Neo4j GenAI Case Study"
  },
  "Fosdem": {
    description: "Europe’s biggest open-source conference featuring talks on DevOps, automation, and Linux.",
    date: "February 1-2, 2025",
    location: "Brussels 🇧🇪",
    links: [
      { text: "FOSDEM Website", url: "https://fosdem.org/2025/" },
      { text: "BGE On the Road 5 - FOSDEM 2025", url: "https://youtu.be/TrBXTM_C50s" }
    ],
    presentation: "Live from FOSDEM 2025: My Experience with La Brigata dei Geek Estinti",
    blog: "/blog/fosdem-2025"
  },
  "Ansible London Meetup": {
    description: "A community meetup focusing on Ansible automation, community engagement, and new DevOps tools.",
    date: "September 23, 2024",
    location: "London 🇬🇧",
    links: [
      { text: "Meetup Details", url: "https://www.meetup.com/ansible-london/events/303113460/" }
    ],
    presentation: "From Zero to Hero: How to Build the Ansible Pilot Community"
  },
  "London Book Fair": {
    description: "One of the world's largest book fairs where Luca Berton attended as an author.",
    date: "March 12-14, 2024",
    location: "London 🇬🇧",
    links: [
      { text: "London Book Fair", url: "https://www.londonbookfair.co.uk/" }
    ],
    presentation: "Meet the Author Session"
  },
  "New Delhi World Book Fair": {
    description: "A global event celebrating literature, where Luca Berton was present as a published author.",
    date: "February 10-18, 2024",
    location: "New Delhi 🇮🇳",
    links: [
      { text: "NDWBF Details", url: "https://www.newdelhiworldbookfair.gov.in/" }
    ],
    presentation: "Book Signing & Author Meet",
    blog: "/blog/new-delhi-international-book-fair-2024"
  },
  "Cloud Native London": {
    description: "A meetup for cloud-native enthusiasts to discuss Kubernetes, automation, and cloud technologies.",
    date: "December 6, 2023",
    location: "London 🇬🇧",
    links: [
      { text: "Meetup Details", url: "https://www.meetup.com/cloud-native-london/events/293022845/" }
    ],
    presentation: "From Zero to Hero: How to Build the Ansible Pilot Community"
  },
  "Ansible Community Day": {
    description: "A full-day event featuring Ansible experts, users, and contributors discussing automation best practices.",
    date: "September 20, 2023",
    location: "Berlin 🇩🇪",
    links: [
      { text: "Event Agenda", url: "https://forum.ansible.com/t/agenda-for-ansible-community-day-berlin-2023/734" }
    ],
    presentation: "From Zero to Hero: How to Build the Ansible Pilot Community"
  },
};


---

<Layout title="Conferences">
  <!-- Image Gallery -->
  <section class="py-12 bg-gray-100">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-extrabold text-gray-800 text-center">Conferences Attended by Luca Berton</h1>
      <p class="text-lg text-gray-600 mt-4 text-center">Showcasing Luca Berton's contributions to global tech conferences.</p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
        {photos.map((src, index) => (
          <Picture
            src={src}
            alt={`Conference Photo ${index + 1}`}
            widths={[200, 300, 400]}
            sizes="(max-width: 800px) 100vw, 300px"
            loading={index < 6 ? "eager" : "lazy"} 
            formats={['avif', 'webp']}
            class="mx-auto h-64 w-full rounded-lg shadow-md object-cover"
          />
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-white text-center">
    <h2 class="text-3xl font-bold text-gray-800">Featured Conferences</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mt-8 mx-auto max-w-6xl">
      {Object.keys(details).map((key) => (
        <div key={key} class="bg-gray-100 shadow-md p-6 rounded-lg text-left border-l-4 border-blue-500">
          <h3 class="text-lg font-bold text-blue-600">{key}</h3>
          <p class="text-gray-600 italic mt-1">{details[key].date}</p>
          <p class="text-gray-500 text-sm">{details[key].location}</p>
          <p class="text-sm mt-3">{details[key].description}</p>
          <h4 class="mt-4 font-semibold text-gray-700">Presentation:</h4>
          <p class="text-sm text-gray-600">{details[key].presentation}</p>
          {details[key].links.length > 0 && (
            <div class="mt-4">
              <h4 class="font-semibold text-gray-700">Links:</h4>
              <ul class="text-blue-600">
                {details[key].links.map((link) => (
                  <li key={link.url}>
                    <a href={link.url} class="hover:underline">{link.text}</a>
                  </li>
                ))}
              </ul>
              {details[key].blog && (
                <div class="mt-4">
                  <h4 class="font-semibold text-gray-700">Blog Recap:</h4>
                  <a href={details[key].blog} class="text-blue-600 hover:underline">
                    Read the full blog post →
                  </a>
                </div>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="py-12 text-center bg-gray-100">
  <h2 class="text-3xl font-bold text-gray-800">Technical Conferences</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8 mx-auto max-w-6xl">
    {conferences.map((conf) => (
      <div key={`${conf.date}-${conf.name}`} class="bg-white shadow-md p-6 rounded-lg text-center border border-gray-200 hover:shadow-lg transition">
        <strong class="block text-xl font-semibold text-gray-700">{conf.date}</strong>
        {conf.url ? (
          <a href={conf.url} target="_blank" rel="noopener noreferrer" class="text-blue-600 font-bold hover:underline mt-2 block">
            {conf.name}
          </a>
        ) : (
          <h3 class="text-gray-600 mt-2 font-bold">{conf.name}</h3>
        )}
        <p class="text-gray-500 text-sm">{conf.location}</p>
        {details[conf.name]?.blog && (
          <a href={details[conf.name].blog} class="text-blue-600 text-sm mt-2 inline-block hover:underline">
            Blog Post →
          </a>
        )}
      </div>
    ))}
  </div>
  </section>
</Layout>
