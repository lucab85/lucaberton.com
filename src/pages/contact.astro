---
import Contactform from "@components/contactform.astro";
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Breadcrumb from "@components/Breadcrumb.astro";
export const prerender = true;
export const lastModified = '2026-04-05';
---

<Layout title="Contact Luca Berton — AI & Cloud Consulting" description="Get in touch with Luca Berton for AI, cloud, and automation consulting. Based in Amsterdam, serving enterprises worldwide with expert guidance.">
  <Breadcrumb items={[{ name: "Contact" }]} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-12">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-bold text-white">Let's Talk</h1>
        <p class="text-slate-300 mt-3 text-lg">Have a project in mind? Need help with AI, Kubernetes, or automation? Pick the option that works best for you.</p>
      </div>
    </Container>
  </section>

  <Container>
    <!-- Quick action cards -->
    <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto -mt-8 relative z-10">
      <a href="https://calendly.com/lucaberton/" class="bg-white rounded-xl p-6 border border-slate-200 shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 text-center group">
        <div class="text-3xl mb-3">📅</div>
        <h2 class="font-bold text-gray-900 group-hover:text-blue-700 transition-colors">Schedule a Call</h2>
        <p class="text-sm text-gray-500 mt-2">Free 30-minute discovery call. Pick a time that works for you.</p>
        <span class="inline-block mt-3 text-blue-600 font-semibold text-sm">Open Calendly →</span>
      </a>
      <a href="mailto:luca@lucaberton.com" class="bg-white rounded-xl p-6 border border-slate-200 shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 text-center group">
        <div class="text-3xl mb-3">✉️</div>
        <h2 class="font-bold text-gray-900 group-hover:text-blue-700 transition-colors">Send an Email</h2>
        <p class="text-sm text-gray-500 mt-2">luca@lucaberton.com — I reply within 24 hours on business days.</p>
        <span class="inline-block mt-3 text-blue-600 font-semibold text-sm">Compose Email →</span>
      </a>
      <a href="tel:+31612255399" class="bg-white rounded-xl p-6 border border-slate-200 shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 text-center group">
        <div class="text-3xl mb-3">📱</div>
        <h2 class="font-bold text-gray-900 group-hover:text-blue-700 transition-colors">Call Directly</h2>
        <p class="text-sm text-gray-500 mt-2">+31 612255399 — Amsterdam, CET timezone.</p>
        <span class="inline-block mt-3 text-blue-600 font-semibold text-sm">Call Now →</span>
      </a>
    </div>

    <!-- Form section -->
    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-bold text-2xl text-gray-900">Or send a message</h2>
        <p class="text-gray-500 mt-3">
          Tell me about your project and I will get back to you with ideas and next steps.
        </p>

        <div class="mt-8 space-y-4">
          <h3 class="font-semibold text-gray-900 text-sm uppercase tracking-wider">What I help with</h3>
          <div class="space-y-2 text-sm text-gray-600">
            <div class="flex items-start gap-2"><span class="text-blue-600 mt-0.5">✓</span> AI infrastructure & GPU platform design</div>
            <div class="flex items-start gap-2"><span class="text-blue-600 mt-0.5">✓</span> Kubernetes platform engineering</div>
            <div class="flex items-start gap-2"><span class="text-blue-600 mt-0.5">✓</span> Ansible automation strategy</div>
            <div class="flex items-start gap-2"><span class="text-blue-600 mt-0.5">✓</span> Cloud migration & cost optimization</div>
            <div class="flex items-start gap-2"><span class="text-blue-600 mt-0.5">✓</span> Team training & workshops</div>
            <div class="flex items-start gap-2"><span class="text-blue-600 mt-0.5">✓</span> Conference speaking engagements</div>
          </div>
        </div>

        <div class="mt-8 p-4 bg-blue-50 rounded-xl border border-blue-100">
          <p class="text-sm text-blue-800 font-medium">💡 Not sure where to start?</p>
          <p class="text-sm text-blue-600 mt-1">Book a free discovery call — no commitment, just a conversation about what you are trying to achieve.</p>
          <a href="https://calendly.com/lucaberton/" class="inline-block mt-2 text-sm text-blue-700 font-bold hover:underline">Schedule on Calendly →</a>
        </div>
      </div>
      <div>
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
