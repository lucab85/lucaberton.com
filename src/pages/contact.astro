---
import Contactform from "@components/contactform.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import Breadcrumb from "@components/Breadcrumb.astro";
export const prerender = true;
export const lastModified = '2025-03-25';
---

<Layout title="Contact">
  <Breadcrumb items={[{ name: "Contact" }]} />
  <Container>
    <Sectionhead>
      <Fragment slot="title">Contact</Fragment>
      <Fragment slot="desc">Let's talk AI, cloud, or automation.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-gray-800">Contact Luca Berton</h2>
        <p class="text-lg leading-relaxed text-slate-500 mt-3">
          Have a project in mind or want to discuss AI, cloud, or automation? 
          Fill out the form, send an email, or give me a call.
        </p>
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:map-marker" />
            <span>Amsterdam, The Netherlands</span>
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" /><a
              href="mailto:luca&#64;lucaberton.com"
              >luca&#64;lucaberton.com</a
            >
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:phone" /><a
              href="tel:+31612255399">+31 612255399</a
            >
          </div>
        </div>
      </div>
      <div>
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
