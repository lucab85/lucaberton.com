---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";

export const prerender = true;
---

<Layout title="GPU Cost Calculator — Cloud vs On-Prem vs RHEL AI" description="Compare the true cost of GPU infrastructure: cloud instances, on-premise hardware, and RHEL AI deployments. Interactive calculator for AI/ML teams.">
  <Breadcrumb items={[{ name: "GPU Cost Calculator" }]} />
  <Container>
    <div class="max-w-4xl mx-auto py-8">
      <div class="text-center mb-10">
        <span class="inline-block px-3 py-1 text-xs font-semibold tracking-wider text-blue-600 uppercase bg-blue-50 rounded-full mb-4">Free Tool</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">GPU Cost Calculator</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Compare the true cost of GPU infrastructure across cloud, on-premise, and RHEL AI deployments. Stop overpaying for AI compute.
        </p>
      </div>

      <!-- Calculator -->
      <div id="calculator" class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6 md:p-8">

        <!-- Step 1: Workload Profile -->
        <div class="mb-8">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-7 h-7 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold">1</span>
            Your Workload
          </h2>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">GPU Type Needed</label>
              <select id="gpuType" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border">
                <option value="a100-40">NVIDIA A100 40GB</option>
                <option value="a100-80" selected>NVIDIA A100 80GB</option>
                <option value="h100" >NVIDIA H100 80GB</option>
                <option value="l40s">NVIDIA L40S 48GB</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Number of GPUs</label>
              <select id="gpuCount" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border">
                <option value="1">1 GPU</option>
                <option value="2">2 GPUs</option>
                <option value="4" selected>4 GPUs</option>
                <option value="8">8 GPUs</option>
                <option value="16">16 GPUs (2 nodes)</option>
                <option value="32">32 GPUs (4 nodes)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Daily Usage (hours)</label>
              <input type="range" id="dailyHours" min="1" max="24" value="12" class="w-full accent-blue-600" />
              <div class="flex justify-between text-xs text-gray-500 mt-1">
                <span>1h</span>
                <span id="dailyHoursLabel" class="font-semibold text-blue-600">12h/day</span>
                <span>24h</span>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Time Horizon</label>
              <select id="months" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border">
                <option value="6">6 months</option>
                <option value="12" selected>1 year</option>
                <option value="24">2 years</option>
                <option value="36">3 years</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Step 2: Your Team -->
        <div class="mb-8">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-7 h-7 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold">2</span>
            Your Team
          </h2>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">ML Engineers / Data Scientists</label>
              <input type="number" id="teamSize" min="1" max="100" value="5" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Dedicated GPU/Infra Engineer?</label>
              <select id="hasGpuEngineer" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border">
                <option value="0">No — team self-manages</option>
                <option value="1" selected>Yes — 1 engineer</option>
                <option value="2">Yes — 2+ engineers</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Calculate Button -->
        <div class="text-center mb-8">
          <button id="calcBtn" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold text-lg hover:bg-blue-700 transition shadow-lg hover:shadow-xl cursor-pointer">
            Calculate Costs →
          </button>
        </div>

        <!-- Results -->
        <div id="results" class="hidden">
          <div class="border-t border-gray-200 pt-8 mb-6">
            <h2 class="text-lg font-bold text-gray-900 mb-6 text-center">Cost Comparison</h2>
          </div>

          <div class="grid md:grid-cols-3 gap-4 mb-8">
            <!-- Cloud -->
            <div class="rounded-xl border-2 border-gray-200 p-5 text-center relative">
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-1">☁️ Cloud On-Demand</div>
              <div id="cloudCost" class="text-3xl font-bold text-gray-900 mb-1"></div>
              <div id="cloudMonthly" class="text-sm text-gray-500 mb-3"></div>
              <div class="text-xs text-gray-400 space-y-1">
                <div>AWS/Azure/GCP on-demand</div>
                <div>No upfront cost</div>
                <div>Pay per hour</div>
              </div>
            </div>

            <!-- On-Prem -->
            <div class="rounded-xl border-2 border-gray-200 p-5 text-center relative">
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-1">🏢 On-Premise</div>
              <div id="onpremCost" class="text-3xl font-bold text-gray-900 mb-1"></div>
              <div id="onpremMonthly" class="text-sm text-gray-500 mb-3"></div>
              <div class="text-xs text-gray-400 space-y-1">
                <div>Hardware + power + cooling</div>
                <div>Staff overhead</div>
                <div id="onpremCapex" class="font-medium text-gray-600"></div>
              </div>
            </div>

            <!-- RHEL AI -->
            <div id="rhelCard" class="rounded-xl border-2 border-green-400 bg-green-50 p-5 text-center relative">
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-green-600 text-white text-xs font-bold px-3 py-0.5 rounded-full">BEST VALUE</div>
              <div class="text-sm font-semibold text-green-700 uppercase tracking-wider mb-1">🐧 RHEL AI + On-Prem</div>
              <div id="rhelCost" class="text-3xl font-bold text-green-800 mb-1"></div>
              <div id="rhelMonthly" class="text-sm text-green-600 mb-3"></div>
              <div class="text-xs text-green-700 space-y-1">
                <div>Optimized InstructLab + vLLM</div>
                <div>MIG multi-tenancy</div>
                <div id="rhelSavings" class="font-bold"></div>
              </div>
            </div>
          </div>

          <!-- Savings Highlight -->
          <div id="savingsBar" class="bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl p-5 text-center mb-8">
            <div class="text-sm font-semibold uppercase tracking-wider opacity-80 mb-1">Potential Savings with RHEL AI</div>
            <div id="savingsAmount" class="text-3xl font-bold"></div>
            <div id="savingsPercent" class="text-sm opacity-80 mt-1"></div>
          </div>

          <!-- Breakdown Table -->
          <details class="mb-8">
            <summary class="cursor-pointer text-sm font-semibold text-blue-600 hover:text-blue-800">Show detailed breakdown</summary>
            <div class="mt-4 overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="text-left py-2 text-gray-600">Cost Component</th>
                    <th class="text-right py-2 text-gray-600">Cloud</th>
                    <th class="text-right py-2 text-gray-600">On-Prem</th>
                    <th class="text-right py-2 text-gray-600">RHEL AI</th>
                  </tr>
                </thead>
                <tbody id="breakdownBody"></tbody>
              </table>
            </div>
          </details>

          <!-- CTA -->
          <div class="bg-gray-50 rounded-xl p-6 text-center border border-gray-200">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Want a precise estimate for your environment?</h3>
            <p class="text-sm text-gray-600 mb-4">This calculator uses industry averages. I can model your exact infrastructure, vendor quotes, and workload patterns.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/contact/" class="inline-block bg-blue-600 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition">Book a Free Assessment →</a>
              <a href="/blog/ansible-gpu-cluster-provisioning/" class="inline-block border border-gray-300 text-gray-700 px-6 py-2.5 rounded-lg font-semibold hover:bg-gray-100 transition">Read: GPU Cluster Provisioning</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="mt-8 text-center text-sm text-gray-500">
        <p>Used by platform engineering teams at enterprises worldwide. Based on real-world pricing data from AWS, Azure, GCP, and hardware vendors.</p>
        <p class="mt-2">
          Built by <a href="/about/" class="text-blue-600 hover:underline">Luca Berton</a> — 
          <a href="https://www.openempower.com/" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">AI & Cloud Advisor</a> | 
          Speaker at <a href="/conferences/" class="text-blue-600 hover:underline">KubeCon EU & Red Hat Summit 2026</a>
        </p>
      </div>
    </div>
  </Container>
</Layout>

<script is:inline>
(function() {
  // GPU pricing data (per GPU per hour, on-demand)
  const CLOUD_HOURLY = {
    'a100-40': 3.67,   // avg across AWS p4d, Azure ND, GCP a2
    'a100-80': 5.12,
    'h100':    8.40,
    'l40s':    2.85,
  };

  // Hardware purchase cost per GPU
  const HW_COST = {
    'a100-40': 12000,
    'a100-80': 18000,
    'h100':    32000,
    'l40s':    8000,
  };

  // Server cost per 8 GPUs (networking, CPU, RAM, NVMe, chassis)
  const SERVER_COST_PER_8 = {
    'a100-40': 25000,
    'a100-80': 30000,
    'h100':    45000,
    'l40s':    20000,
  };

  // Power per GPU (watts)
  const GPU_POWER = {
    'a100-40': 250,
    'a100-80': 300,
    'h100':    700,
    'l40s':    350,
  };

  const ELECTRICITY_KWH = 0.15;       // €/kWh avg EU
  const PUE = 1.4;                     // Power Usage Effectiveness
  const RHEL_AI_PER_NODE_YEAR = 15000; // RHEL AI subscription per node/year
  const ENGINEER_YEARLY = 95000;       // loaded cost
  const RHEL_EFFICIENCY = 0.80;        // MIG + vLLM optimization: need 20% fewer GPUs

  function fmt(n) {
    if (n >= 1000000) return '€' + (n / 1000000).toFixed(2) + 'M';
    if (n >= 1000) return '€' + (n / 1000).toFixed(0) + 'K';
    return '€' + n.toFixed(0);
  }

  const $ = (id) => document.getElementById(id);
  const slider = $('dailyHours');
  slider.addEventListener('input', () => {
    $('dailyHoursLabel').textContent = slider.value + 'h/day';
  });

  $('calcBtn').addEventListener('click', calculate);

  function calculate() {
    const gpu = $('gpuType').value;
    const count = parseInt($('gpuCount').value);
    const hours = parseInt($('dailyHours').value);
    const months = parseInt($('months').value);
    const team = parseInt($('teamSize').value);
    const engCount = parseInt($('hasGpuEngineer').value);

    const days = months * 30.44;

    // ---- CLOUD ----
    const cloudCompute = CLOUD_HOURLY[gpu] * count * hours * days;
    const cloudTotal = cloudCompute;
    const cloudMonthly = cloudTotal / months;

    // ---- ON-PREM ----
    const nodes = Math.ceil(count / 8);
    const hwGpus = HW_COST[gpu] * count;
    const hwServers = SERVER_COST_PER_8[gpu] * nodes;
    const hwTotal = hwGpus + hwServers;
    const powerMonthly = (GPU_POWER[gpu] * count * PUE * hours / 1000) * 30.44 * ELECTRICITY_KWH;
    const powerTotal = powerMonthly * months;
    const staffTotal = engCount * ENGINEER_YEARLY * (months / 12);
    const onpremTotal = hwTotal + powerTotal + staffTotal;
    const onpremMonthly = onpremTotal / months;

    // ---- RHEL AI ----
    const rhelGpuCount = Math.ceil(count * RHEL_EFFICIENCY);
    const rhelNodes = Math.ceil(rhelGpuCount / 8) || 1;
    const rhelHwGpus = HW_COST[gpu] * rhelGpuCount;
    const rhelHwServers = SERVER_COST_PER_8[gpu] * rhelNodes;
    const rhelHw = rhelHwGpus + rhelHwServers;
    const rhelPower = (GPU_POWER[gpu] * rhelGpuCount * PUE * hours / 1000) * 30.44 * ELECTRICITY_KWH * months;
    const rhelSub = RHEL_AI_PER_NODE_YEAR * rhelNodes * (months / 12);
    const rhelStaff = Math.max(engCount - 0.5, 0) * ENGINEER_YEARLY * (months / 12); // RHEL AI reduces ops overhead
    const rhelTotal = rhelHw + rhelPower + rhelSub + rhelStaff;
    const rhelMonthly = rhelTotal / months;

    // Determine best value
    const costs = [cloudTotal, onpremTotal, rhelTotal];
    const minCost = Math.min(...costs);
    const bestLabel = rhelTotal <= minCost * 1.01 ? 'rhel' : (onpremTotal <= minCost * 1.01 ? 'onprem' : 'cloud');

    // Display
    $('cloudCost').textContent = fmt(cloudTotal);
    $('cloudMonthly').textContent = fmt(cloudMonthly) + '/mo';
    $('onpremCost').textContent = fmt(onpremTotal);
    $('onpremMonthly').textContent = fmt(onpremMonthly) + '/mo';
    $('onpremCapex').textContent = 'Upfront: ' + fmt(hwTotal);
    $('rhelCost').textContent = fmt(rhelTotal);
    $('rhelMonthly').textContent = fmt(rhelMonthly) + '/mo';

    const savingsVsCloud = cloudTotal - rhelTotal;
    const savingsPct = ((savingsVsCloud / cloudTotal) * 100).toFixed(0);
    $('rhelSavings').textContent = 'Save ' + fmt(savingsVsCloud) + ' vs cloud';
    $('savingsAmount').textContent = fmt(savingsVsCloud) + ' saved vs cloud';
    $('savingsPercent').textContent = savingsPct + '% less than cloud on-demand over ' + months + ' months';

    // Highlight best card
    const cards = ['cloud', 'onprem', 'rhel'];
    document.querySelectorAll('#results > div:first-of-type ~ .grid > div').forEach((card, i) => {
      // Reset all
    });

    // Breakdown table
    const tbody = $('breakdownBody');
    tbody.innerHTML = '';
    const rows = [
      ['GPU Hardware (CapEx)', '—', fmt(hwTotal), fmt(rhelHw)],
      ['Compute / Hourly', fmt(cloudCompute), '—', '—'],
      ['Power & Cooling', '—', fmt(powerTotal), fmt(rhelPower)],
      ['RHEL AI Subscription', '—', '—', fmt(rhelSub)],
      ['Staff / Ops', '—', fmt(staffTotal), fmt(rhelStaff)],
      ['Total', fmt(cloudTotal), fmt(onpremTotal), fmt(rhelTotal)],
    ];
    rows.forEach((row, i) => {
      const tr = document.createElement('tr');
      tr.className = i === rows.length - 1 ? 'border-t-2 border-gray-300 font-bold' : 'border-b border-gray-100';
      row.forEach((cell, j) => {
        const td = document.createElement(j === 0 ? 'td' : 'td');
        td.className = j === 0 ? 'py-2 text-gray-700' : 'py-2 text-right text-gray-900';
        td.textContent = cell;
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });

    $('results').classList.remove('hidden');
    $('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
})();
</script>
