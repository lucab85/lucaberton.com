---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";

export const prerender = true;
---

<Layout title="GPU Cost Calculator — Training + Inference Cost Model" description="Estimate monthly GPU compute cost for training and inference workloads. Compare scenarios: spot pricing, scaling, utilization changes. Free tool by Luca Berton.">
  <Breadcrumb items={[{ name: "GPU Cost Calculator" }]} />
  <Container>
    <div class="max-w-5xl mx-auto py-8">
      <div class="text-center mb-10">
        <span class="inline-block px-3 py-1 text-xs font-semibold tracking-wider text-blue-600 uppercase bg-blue-50 rounded-full mb-4">Free Tool</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">GPU Cost Calculator</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Estimate your monthly GPU spend across training and inference workloads. Compare scenarios to optimize cost.
        </p>
      </div>

      <div id="calculator" class="space-y-6">

        <!-- General Settings -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-7 h-7 bg-gray-700 text-white rounded-full flex items-center justify-center text-sm">⚙</span>
            General
          </h2>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Currency</label>
              <select id="currency" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border">
                <option value="$">$ USD</option>
                <option value="€">€ EUR</option>
                <option value="£">£ GBP</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Hours per month</label>
              <input type="number" id="hoursMonth" value="730" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
              <span class="text-xs text-gray-400">Default: 365×24÷12</span>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Overhead multiplier</label>
              <input type="number" id="overhead" value="1.1" step="0.05" min="1" max="2" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
              <span class="text-xs text-gray-400">Non-GPU infra overhead (e.g. 1.1 = +10%)</span>
            </div>
          </div>
        </div>

        <!-- Training Cluster -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-7 h-7 bg-purple-600 text-white rounded-full flex items-center justify-center text-sm">🧠</span>
            Training Cluster
          </h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">GPU type</label>
              <select id="trainGpu" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border">
                <option value="NVIDIA H100 SXM" selected>NVIDIA H100 SXM</option>
                <option value="NVIDIA H100 PCIe">NVIDIA H100 PCIe</option>
                <option value="NVIDIA A100 80GB">NVIDIA A100 80GB</option>
                <option value="NVIDIA A100 40GB">NVIDIA A100 40GB</option>
                <option value="NVIDIA L40S">NVIDIA L40S</option>
                <option value="NVIDIA L4">NVIDIA L4</option>
                <option value="NVIDIA T4">NVIDIA T4</option>
                <option value="AMD MI300X">AMD MI300X</option>
                <option value="AMD MI250">AMD MI250</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Hourly price per GPU</label>
              <div class="relative">
                <span id="trainCurrLabel" class="absolute left-3 top-2.5 text-gray-500">$</span>
                <input type="number" id="trainPrice" value="4.50" step="0.10" min="0" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 pl-7 border" />
              </div>
              <span class="text-xs text-gray-400">On-demand or blended effective rate</span>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Number of GPUs</label>
              <input type="number" id="trainGpus" value="8" min="1" max="1024" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Utilization %</label>
              <input type="range" id="trainUtil" min="0.1" max="1" step="0.05" value="0.7" class="w-full accent-purple-600" />
              <div class="flex justify-between text-xs text-gray-500 mt-1">
                <span>10%</span>
                <span id="trainUtilLabel" class="font-semibold text-purple-600">70%</span>
                <span>100%</span>
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Hours per training run</label>
              <input type="number" id="trainHours" value="72" min="1" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Runs per month</label>
              <input type="number" id="trainRuns" value="2" min="0" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
            </div>
          </div>
        </div>

        <!-- Inference -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-7 h-7 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm">⚡</span>
            Inference
          </h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">GPU type</label>
              <select id="inferGpu" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border">
                <option value="NVIDIA H100 SXM">NVIDIA H100 SXM</option>
                <option value="NVIDIA A100 80GB">NVIDIA A100 80GB</option>
                <option value="NVIDIA L40S" selected>NVIDIA L40S</option>
                <option value="NVIDIA L4">NVIDIA L4</option>
                <option value="NVIDIA T4">NVIDIA T4</option>
                <option value="AMD MI300X">AMD MI300X</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Hourly price per GPU</label>
              <div class="relative">
                <span id="inferCurrLabel" class="absolute left-3 top-2.5 text-gray-500">$</span>
                <input type="number" id="inferPrice" value="1.20" step="0.10" min="0" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 pl-7 border" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Number of GPUs</label>
              <input type="number" id="inferGpus" value="4" min="0" max="256" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Utilization %</label>
              <input type="range" id="inferUtil" min="0.1" max="1" step="0.05" value="0.4" class="w-full accent-blue-600" />
              <div class="flex justify-between text-xs text-gray-500 mt-1">
                <span>10%</span>
                <span id="inferUtilLabel" class="font-semibold text-blue-600">40%</span>
                <span>100%</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Storage & Network -->
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
          <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-7 h-7 bg-green-600 text-white rounded-full flex items-center justify-center text-sm">💾</span>
            Storage & Network
          </h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Storage cost / TB-month</label>
              <div class="relative">
                <span id="storageCurrLabel" class="absolute left-3 top-2.5 text-gray-500">$</span>
                <input type="number" id="storageCost" value="20" min="0" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 pl-7 border" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Storage used (TB)</label>
              <input type="number" id="storageTB" value="50" min="0" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Egress cost / GB</label>
              <div class="relative">
                <span id="egressCurrLabel" class="absolute left-3 top-2.5 text-gray-500">$</span>
                <input type="number" id="egressCost" value="0.09" step="0.01" min="0" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 pl-7 border" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Egress volume (GB/mo)</label>
              <input type="number" id="egressGB" value="2000" min="0" class="w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 border" />
            </div>
          </div>
        </div>

        <!-- Calculate Button -->
        <div class="text-center">
          <button id="calcBtn" class="bg-blue-600 text-white px-10 py-3.5 rounded-xl font-semibold text-lg hover:bg-blue-700 transition shadow-lg hover:shadow-xl cursor-pointer">
            Calculate Monthly Cost →
          </button>
        </div>

        <!-- Results -->
        <div id="results" class="hidden space-y-6">

          <!-- Total Cost Card -->
          <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-6 md:p-8 text-white text-center shadow-xl">
            <div class="text-sm font-semibold uppercase tracking-wider opacity-80 mb-1">Estimated Monthly Cost</div>
            <div id="totalCost" class="text-5xl md:text-6xl font-bold mb-2"></div>
            <div id="annualCost" class="text-lg opacity-80"></div>
          </div>

          <!-- Breakdown Cards -->
          <div class="grid md:grid-cols-4 gap-4">
            <div class="bg-white rounded-xl border border-gray-200 p-5 text-center">
              <div class="text-xs font-semibold text-purple-600 uppercase tracking-wider mb-1">🧠 Training</div>
              <div id="trainCostDisplay" class="text-2xl font-bold text-gray-900"></div>
              <div id="trainDetail" class="text-xs text-gray-500 mt-2 space-y-0.5"></div>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-5 text-center">
              <div class="text-xs font-semibold text-blue-600 uppercase tracking-wider mb-1">⚡ Inference</div>
              <div id="inferCostDisplay" class="text-2xl font-bold text-gray-900"></div>
              <div id="inferDetail" class="text-xs text-gray-500 mt-2 space-y-0.5"></div>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-5 text-center">
              <div class="text-xs font-semibold text-green-600 uppercase tracking-wider mb-1">💾 Storage</div>
              <div id="storageCostDisplay" class="text-2xl font-bold text-gray-900"></div>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-5 text-center">
              <div class="text-xs font-semibold text-orange-600 uppercase tracking-wider mb-1">🌐 Egress</div>
              <div id="egressCostDisplay" class="text-2xl font-bold text-gray-900"></div>
            </div>
          </div>

          <!-- Cost Pie (text-based) -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h3 class="text-sm font-bold text-gray-700 mb-4 text-center">Cost Distribution</h3>
            <div id="costBars" class="space-y-3"></div>
          </div>

          <!-- Scenarios -->
          <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Quick Scenarios</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-gray-200 text-left">
                    <th class="py-2 text-gray-600 font-medium">Scenario</th>
                    <th class="py-2 text-right text-gray-600 font-medium">Monthly Cost</th>
                    <th class="py-2 text-right text-gray-600 font-medium">vs Baseline</th>
                  </tr>
                </thead>
                <tbody id="scenarioBody"></tbody>
              </table>
            </div>
          </div>

          <!-- CTA -->
          <div class="bg-gray-50 rounded-2xl p-6 md:p-8 text-center border border-gray-200">
            <h3 class="text-xl font-bold text-gray-900 mb-2">Want a precise model for your infrastructure?</h3>
            <p class="text-gray-600 mb-5 max-w-xl mx-auto">This calculator uses your inputs. I can model reserved pricing, spot strategies, MIG partitioning, and multi-cloud arbitrage for your exact workloads.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/contact/" class="inline-block bg-blue-600 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition">Book a Free Assessment →</a>
              <a href="/blog/ansible-gpu-cluster-provisioning/" class="inline-block border border-gray-300 text-gray-700 px-6 py-2.5 rounded-lg font-semibold hover:bg-gray-100 transition">GPU Cluster Provisioning Guide</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Trust -->
      <div class="mt-8 text-center text-sm text-gray-500">
        <p>
          Built by <a href="/about/" class="text-blue-600 hover:underline">Luca Berton</a> — 
          <a href="https://www.openempower.com/" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">AI & Cloud Advisor</a> | 
          Speaker at <a href="/conferences/" class="text-blue-600 hover:underline">KubeCon EU & Red Hat Summit 2026</a>
        </p>
      </div>
    </div>
  </Container>
</Layout>

<script is:inline>
(function() {
  const $ = id => document.getElementById(id);

  // Slider labels
  $('trainUtil').addEventListener('input', function() {
    $('trainUtilLabel').textContent = Math.round(this.value * 100) + '%';
  });
  $('inferUtil').addEventListener('input', function() {
    $('inferUtilLabel').textContent = Math.round(this.value * 100) + '%';
  });

  // Currency sync
  $('currency').addEventListener('change', function() {
    const c = this.value;
    ['trainCurrLabel','inferCurrLabel','storageCurrLabel','egressCurrLabel'].forEach(id => {
      $(id).textContent = c;
    });
  });

  $('calcBtn').addEventListener('click', calculate);

  function fmt(n, curr) {
    curr = curr || $('currency').value;
    if (n >= 1000000) return curr + (n / 1000000).toFixed(2) + 'M';
    return curr + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function calcCost(trainPrice, trainGpus, trainUtil, trainHrs, trainRuns, inferPrice, inferGpus, inferUtil, hoursMonth, overhead, storageCostPerTB, storageTB, egressCostPerGB, egressGB) {
    // Training: GPU-hours = runs × hours_per_run × gpus
    const trainGpuHours = trainRuns * trainHrs * trainGpus;
    const trainEffective = trainGpuHours * trainUtil;
    const trainCompute = trainEffective * trainPrice;
    const trainWithOverhead = trainCompute * overhead;

    // Inference: always-on GPUs × utilization
    const inferGpuHours = hoursMonth * inferGpus;
    const inferEffective = inferGpuHours * inferUtil;
    const inferCompute = inferEffective * inferPrice;
    const inferWithOverhead = inferCompute * overhead;

    const storageMo = storageCostPerTB * storageTB;
    const egressMo = egressCostPerGB * egressGB;

    const total = trainWithOverhead + inferWithOverhead + storageMo + egressMo;

    return {
      trainGpuHours, trainEffective, trainWithOverhead,
      inferGpuHours, inferEffective, inferWithOverhead,
      storageMo, egressMo, total
    };
  }

  function getInputs() {
    return {
      hoursMonth: parseFloat($('hoursMonth').value) || 730,
      overhead: parseFloat($('overhead').value) || 1.1,
      trainPrice: parseFloat($('trainPrice').value) || 0,
      trainGpus: parseInt($('trainGpus').value) || 0,
      trainUtil: parseFloat($('trainUtil').value) || 0.7,
      trainHrs: parseFloat($('trainHours').value) || 0,
      trainRuns: parseInt($('trainRuns').value) || 0,
      inferPrice: parseFloat($('inferPrice').value) || 0,
      inferGpus: parseInt($('inferGpus').value) || 0,
      inferUtil: parseFloat($('inferUtil').value) || 0.4,
      storageCostPerTB: parseFloat($('storageCost').value) || 0,
      storageTB: parseFloat($('storageTB').value) || 0,
      egressCostPerGB: parseFloat($('egressCost').value) || 0,
      egressGB: parseFloat($('egressGB').value) || 0,
    };
  }

  function calculate() {
    const inp = getInputs();
    const r = calcCost(inp.trainPrice, inp.trainGpus, inp.trainUtil, inp.trainHrs, inp.trainRuns,
                        inp.inferPrice, inp.inferGpus, inp.inferUtil,
                        inp.hoursMonth, inp.overhead,
                        inp.storageCostPerTB, inp.storageTB, inp.egressCostPerGB, inp.egressGB);
    const c = $('currency').value;

    // Total
    $('totalCost').textContent = fmt(r.total);
    $('annualCost').textContent = fmt(r.total * 12) + ' / year';

    // Breakdown cards
    $('trainCostDisplay').textContent = fmt(r.trainWithOverhead);
    $('trainDetail').innerHTML =
      '<div>' + r.trainGpuHours.toLocaleString() + ' GPU-hours/mo</div>' +
      '<div>' + r.trainEffective.toLocaleString() + ' effective (billable)</div>';

    $('inferCostDisplay').textContent = fmt(r.inferWithOverhead);
    $('inferDetail').innerHTML =
      '<div>' + r.inferGpuHours.toLocaleString() + ' GPU-hours/mo</div>' +
      '<div>' + r.inferEffective.toLocaleString() + ' effective (billable)</div>';

    $('storageCostDisplay').textContent = fmt(r.storageMo);
    $('egressCostDisplay').textContent = fmt(r.egressMo);

    // Bars
    const parts = [
      { label: 'Training', value: r.trainWithOverhead, color: 'bg-purple-500' },
      { label: 'Inference', value: r.inferWithOverhead, color: 'bg-blue-500' },
      { label: 'Storage', value: r.storageMo, color: 'bg-green-500' },
      { label: 'Egress', value: r.egressMo, color: 'bg-orange-500' },
    ];
    const barsEl = $('costBars');
    barsEl.innerHTML = '';
    parts.forEach(p => {
      const pct = r.total > 0 ? (p.value / r.total * 100) : 0;
      barsEl.innerHTML +=
        '<div class="flex items-center gap-3">' +
          '<span class="w-20 text-xs text-gray-600 text-right">' + p.label + '</span>' +
          '<div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">' +
            '<div class="' + p.color + ' h-full rounded-full transition-all duration-500" style="width:' + pct + '%"></div>' +
          '</div>' +
          '<span class="w-24 text-xs text-gray-700 font-medium">' + fmt(p.value) + ' (' + pct.toFixed(0) + '%)</span>' +
        '</div>';
    });

    // Scenarios
    const scenarios = [
      { name: 'Baseline (your inputs)', changes: {} },
      { name: 'More training GPUs (+50%)', changes: { trainGpus: Math.ceil(inp.trainGpus * 1.5) } },
      { name: 'Lower utilization (−20%)', changes: { trainUtil: Math.max(0.1, inp.trainUtil - 0.2) } },
      { name: 'Spot pricing (−60%)', changes: { trainPrice: inp.trainPrice * 0.4, inferPrice: inp.inferPrice * 0.6 } },
      { name: 'Double inference GPUs', changes: { inferGpus: inp.inferGpus * 2 } },
      { name: 'Reserved instances (−40%)', changes: { trainPrice: inp.trainPrice * 0.6, inferPrice: inp.inferPrice * 0.6 } },
    ];
    const tbody = $('scenarioBody');
    tbody.innerHTML = '';
    const baseline = r.total;
    scenarios.forEach(s => {
      const si = Object.assign({}, inp, s.changes);
      const sr = calcCost(si.trainPrice, si.trainGpus, si.trainUtil, si.trainHrs, si.trainRuns,
                          si.inferPrice, si.inferGpus, si.inferUtil,
                          si.hoursMonth, si.overhead,
                          si.storageCostPerTB, si.storageTB, si.egressCostPerGB, si.egressGB);
      const diff = sr.total - baseline;
      const diffPct = baseline > 0 ? (diff / baseline * 100).toFixed(0) : 0;
      const diffStr = diff === 0 ? '—' : (diff > 0 ? '+' : '') + fmt(diff) + ' (' + (diff > 0 ? '+' : '') + diffPct + '%)';
      const diffClass = diff < 0 ? 'text-green-600' : (diff > 0 ? 'text-red-600' : 'text-gray-400');
      tbody.innerHTML +=
        '<tr class="border-b border-gray-100">' +
          '<td class="py-2.5 text-gray-800">' + s.name + '</td>' +
          '<td class="py-2.5 text-right font-medium text-gray-900">' + fmt(sr.total) + '</td>' +
          '<td class="py-2.5 text-right font-medium ' + diffClass + '">' + diffStr + '</td>' +
        '</tr>';
    });

    $('results').classList.remove('hidden');
    $('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
})();
</script>
