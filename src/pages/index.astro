---
import Container from "@components/container.astro";
import Cta from "@components/cta.astro";
import Features from "@components/features.astro";
import Hero from "@components/hero.astro";
import Kpi from "@components/kpi.astro";
import Courses from "@components/courses.astro";
import Books from "@components/books.astro";
import Logos from "@components/logos.astro";
import AnsiblePilot from "@components/ansiblepilot.astro";
import Testimonials from "@components/testimonials-home.astro";
import LatestPosts from "@components/latest-posts.astro";
import Layout from "@layouts/Layout.astro";
export const prerender = true;
export const lastModified = '2026-02-19';
---

<Layout title="">
  <Container>
    <Hero />
    <Kpi />
  </Container>
  <Container class="relative overflow-hidden w-full max-w-full mx-auto">
    <Logos />
    <Features />
    <AnsiblePilot />
    <Courses />
    <Books />
    <Testimonials />
    <LatestPosts />
    <Cta />
  </Container>
</Layout>
