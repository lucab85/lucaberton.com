---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
export const prerender = true;

const title = "Multi-tenant GPUs on Bare Metal OpenShift AI | KubeCon Europe 2026";
const description = "Luca Berton's KubeCon Europe 2026 talk — A GitOps Blueprint from the Trenches for multi-tenant GPU platforms on bare metal OpenShift AI.";
---

<Layout title={title}>
  <meta slot="head" name="description" content={description} />
  <meta slot="head" property="og:title" content={title} />
  <meta slot="head" property="og:description" content={description} />
  <meta slot="head" property="og:type" content="website" />
  <meta slot="head" property="og:image" content="https://lucaberton.com/blog/thumbnails/kubecon-2026-stage-presenting-wide.jpg" />
  <meta slot="head" property="og:image:width" content="1200" />
  <meta slot="head" property="og:image:height" content="630" />
  <meta slot="head" name="twitter:card" content="summary_large_image" />
  <meta slot="head" name="twitter:image" content="https://lucaberton.com/blog/thumbnails/kubecon-2026-stage-presenting-wide.jpg" />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-950 via-blue-950 to-slate-900 py-20 md:py-28">
    <Container>
      <div class="max-w-4xl mx-auto text-center">
        <span class="inline-block px-4 py-1.5 mb-6 text-sm font-semibold text-amber-300 bg-amber-900/30 rounded-full border border-amber-700/40 tracking-wide uppercase">
          KubeCon + CloudNativeCon Europe 2026 · Amsterdam
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Multi-tenant GPUs on<br />
          <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
            Bare Metal OpenShift AI
          </span>
        </h1>

        <p class="text-xl md:text-2xl text-blue-200/80 mb-4 font-light">
          A GitOps Blueprint from the Trenches
        </p>

        <p class="text-lg text-slate-400 mb-10">
          by <strong class="text-white">Luca Berton</strong> · AI &amp; Cloud Advisor
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://calendly.com/lucaberton/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 rounded-xl shadow-lg shadow-blue-600/25 transition-all duration-200 hover:scale-105"
          >
            📅 Book a Conversation
          </a>
          <a
            href="/slides/kubecon-europe-2026-multi-tenant-gpus-bare-metal.pdf"
            download
            class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-blue-300 border-2 border-blue-500/40 hover:border-blue-400 rounded-xl transition-all duration-200 hover:bg-blue-900/30"
          >
            ⬇️ Download Slides (PDF)
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Talk Recording -->
  <section class="bg-slate-950 py-16 border-b border-slate-800">
    <Container>
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-8">🎬 Watch the Talk</h2>
        <div class="relative w-full max-w-3xl mx-auto aspect-video rounded-2xl overflow-hidden shadow-2xl shadow-blue-900/20 border border-slate-800">
          <iframe
            src="https://www.youtube.com/embed/nABVTFBmV2M?rel=0"
            title="Multi-tenant GPUs on Bare Metal OpenShift AI — KubeCon Europe 2026"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            class="absolute inset-0 w-full h-full"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </Container>
  </section>

  <!-- Talk Summary -->
  <section class="bg-slate-950 py-16">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="flex justify-center mb-6"><span class="inline-flex items-center px-4 py-2 bg-green-900/40 border border-green-500/30 rounded-full text-green-400 font-semibold text-sm">🎯 780 attendees saved this session in the KubeCon agenda</span></div>
        <h2 class="text-3xl font-bold text-white mb-8 text-center">What This Talk Covers</h2>
        <p class="text-lg text-slate-300 mb-10 text-center max-w-3xl mx-auto">
          Running GPU workloads on bare metal is hard. Sharing them across teams without chaos is harder.
          This talk shares a battle-tested framework for building a <strong class="text-white">safe, fair, and efficient</strong> multi-tenant GPU platform — everything managed through GitOps.
        </p>

        <div class="grid md:grid-cols-3 gap-6 mb-12">
          <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3">🛡️</div>
            <h3 class="text-xl font-bold text-white mb-2">Safety</h3>
            <p class="text-slate-400 text-sm">Blast radius = zero. RBAC, NetworkPolicy, quotas — all in Git. One team can never break another.</p>
          </div>
          <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3">⚖️</div>
            <h3 class="text-xl font-bold text-white mb-2">Fairness</h3>
            <p class="text-slate-400 text-sm">Deterministic contention. PriorityClasses, preemption rules, and GPU caps — no more "random wins."</p>
          </div>
          <div class="bg-slate-900/60 border border-slate-800 rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3">⚡</div>
            <h3 class="text-xl font-bold text-white mb-2">Efficiency</h3>
            <p class="text-slate-400 text-sm">Outcomes per GPU-hour. Time slicing, MIG, GPUDirect RDMA — measured and optimized per tenant.</p>
          </div>
        </div>

        <!-- Key Topics -->
        <div class="bg-slate-900/40 border border-slate-800 rounded-2xl p-8">
          <h3 class="text-xl font-bold text-white mb-6">Key Topics</h3>
          <div class="grid md:grid-cols-2 gap-4 text-slate-300">
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>GitOps-first with Argo CD + Kustomize — everything auditable</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>Bare metal bootstrap: Ansible → GitOps → Day 2 ops</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>SR-IOV with NVIDIA Network Operator vs OpenShift SR-IOV</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>Open kernel modules + DMA-BUF for safer GPU upgrades</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>Multi-tenant networking: HAProxy + Keepalived + per-tenant VIPs</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>KAI Scheduler for GPU-aware scheduling + visibility</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>Per-tenant monitoring, chargeback, and self-service dashboards</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-green-400 mt-0.5">✓</span>
              <span>7 guardrails you can apply today</span>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- The Stack -->
  <section class="bg-slate-900 py-16">
    <Container>
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-8">The Stack</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {["OpenShift AI", "NVIDIA H200", "GPU Operator", "Network Operator", "SR-IOV", "Argo CD", "Kustomize", "HAProxy", "Keepalived", "Run:AI", "KAI Scheduler", "GPUDirect RDMA", "DMA-BUF", "InfiniBand", "Dell PowerEdge", "PowerScale NAS", "Ansible", "Quay", "Prometheus", "GitOps"].map(tech => (
            <span class="px-3 py-1.5 text-sm font-medium text-blue-300 bg-blue-900/30 border border-blue-800/40 rounded-full">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- About Speaker -->
  <section class="bg-slate-950 py-16">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-6">About the Speaker</h2>
        <p class="text-lg text-slate-300 mb-4">
          <strong class="text-white">Luca Berton</strong> is an AI &amp; Cloud Advisor with 15+ years building enterprise infrastructure.
          Author of 8 books including <a href="https://kubernetes.recipes" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">Kubernetes Recipes</a>,
          creator of the <a href="https://www.youracclaim.com/users/luca-berton" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">40,000+ student learning community</a>,
          and hands-on consultant for GPU platforms, AI integration, and platform engineering.
        </p>
        <p class="text-slate-400 mb-8">
          Based in Amsterdam 🇳🇱 · Previously at Red Hat, Allianz, Databricks
        </p>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-blue-950 via-slate-950 to-slate-900 py-20">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Let's Talk GPU Infrastructure
        </h2>
        <p class="text-xl text-slate-300 mb-4">
          Building a multi-tenant GPU platform? Migrating to bare metal AI? Considering OpenShift AI?
        </p>
        <p class="text-lg text-blue-300 mb-10">
          I'm in Amsterdam for KubeCon — let's grab a coffee and talk shop.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://calendly.com/lucaberton/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center px-10 py-5 text-xl font-bold text-white bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-500 hover:to-cyan-500 rounded-xl shadow-lg shadow-blue-600/25 transition-all duration-200 hover:scale-105"
          >
            📅 Book 30 Min With Me
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center px-10 py-5 text-xl font-semibold text-blue-300 border-2 border-blue-500/40 hover:border-blue-400 rounded-xl transition-all duration-200 hover:bg-blue-900/30"
          >
            ✉️ Send a Message
          </a>
        </div>

        <p class="text-sm text-slate-500 mt-8">
          Or find me at the conference — I'm always up for a good conversation about GPU scheduling.
        </p>
      </div>
    </Container>
  </section>

  <!-- Related Content -->
  <section class="bg-slate-950 py-16 border-t border-slate-800">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">Related Resources</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <a href="/blog/nvidia-gpu-operator-kubernetes-setup/" class="group bg-slate-900/60 border border-slate-800 hover:border-blue-700 rounded-xl p-6 transition-all">
            <h3 class="text-white font-semibold group-hover:text-blue-400 transition-colors mb-2">NVIDIA GPU Operator Setup</h3>
            <p class="text-sm text-slate-400">Complete guide to GPU Operator on Kubernetes</p>
          </a>
          <a href="/blog/nvidia-gpu-operator-mig-partitioning/" class="group bg-slate-900/60 border border-slate-800 hover:border-blue-700 rounded-xl p-6 transition-all">
            <h3 class="text-white font-semibold group-hover:text-blue-400 transition-colors mb-2">GPU Time-Slicing</h3>
            <p class="text-sm text-slate-400">Share GPUs across workloads efficiently</p>
          </a>
          <a href="/blog/kubecon-europe-2026-side-events/" class="group bg-slate-900/60 border border-slate-800 hover:border-blue-700 rounded-xl p-6 transition-all">
            <h3 class="text-white font-semibold group-hover:text-blue-400 transition-colors mb-2">KubeCon EU 2026 Side Events</h3>
            <p class="text-sm text-slate-400">40+ events happening around KubeCon Amsterdam</p>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <!-- Newsletter -->
  <section class="bg-slate-900 py-12 border-t border-slate-800">
    <Container>
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-slate-400 mb-4">Get insights on AI infrastructure, GPU platforms, and cloud native engineering</p>
        <a
          href="https://luca-berton.kit.com/ce74a48bfa"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-amber-600 hover:bg-amber-500 rounded-lg transition-colors"
        >
          📬 Subscribe to the Newsletter
        </a>
      </div>
    </Container>
  </section>
</Layout>
