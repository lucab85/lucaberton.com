            <div class="chapter-part" data-part="2">
              <div class="part-header">
                <div class="part-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <div class="part-meta">
                  <span class="part-label">Chapters 3-4</span>
                  <h3 class="part-title-new">Stateful & Cloud</h3>
                </div>
              </div>
              <div class="chapters-list-new">
                <div class="chapter-item-new">
                  <span class="chapter-num-new">03</span>
                  <div class="chapter-content">
                    <span class="chapter-title-new">Configuring Stateful Applications</span>
                    <span class="chapter-desc">StatefulSets, databases, and data persistence</span>
                  </div>
                </div>
                <div class="chapter-item-new">
                  <span class="chapter-num-new">04</span>
                  <div class="chapter-content">
                    <span class="chapter-title-new">Kubernetes on Cloud Providers</span>
                    <span class="chapter-desc">AWS, Azure, GCP, and hybrid deployments</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Part III: Developer & Scaling -->
            <div class="chapter-part" data-part="3">
              <div class="part-header">
                <div class="part-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                </div>
                <div class="part-meta">
                  <span class="part-label">Chapters 5-6</span>
                  <h3 class="part-title-new">Developer & Scaling</h3>
                </div>
              </div>
              <div class="chapters-list-new">
                <div class="chapter-item-new">
                  <span class="chapter-num-new">05</span>
                  <div class="chapter-content">
                    <span class="chapter-title-new">Developer Experience</span>
                    <span class="chapter-desc">Local dev, inner-loop workflows, and tooling</span>
                  </div>
                </div>
                <div class="chapter-item-new">
