        font-size: 0.75rem;
        font-weight: 700;
        color: hsl(var(--primary));
        background: hsl(var(--primary) / 0.1);
        border: 1px solid hsl(var(--primary) / 0.2);
        border-radius: 8px;
      }

      .chapter-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .chapter-title-new {
        font-size: 0.9rem;
        font-weight: 600;
        color: hsl(var(--foreground));
        line-height: 1.3;
      }

      .chapter-desc {
        font-size: 0.8rem;
        color: hsl(var(--muted-foreground));
        line-height: 1.4;
      }

      /* Chapter Summary Stats */
      .chapter-summary {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 2rem;
        margin-top: 3rem;
        padding: 1.5rem 2rem;
        background: hsl(var(--card));
        border: 1px solid hsl(var(--border));
        border-radius: 1rem;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
      }

      .summary-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
      }

      .summary-number {
        font-size: 2rem;
        font-weight: 800;
        color: hsl(var(--primary));
        line-height: 1;
      }

      .summary-label {
        font-size: 0.8rem;
        font-weight: 500;
        color: hsl(var(--muted-foreground));
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .summary-divider {
        width: 1px;
        height: 40px;
        background: hsl(var(--border));
      }

      /* Legacy styles kept for compatibility */
      .chapters-grid {
        display: grid;
        gap: 2rem;
      }

      @media (min-width: 1024px) {
        .chapters-grid { grid-template-columns: repeat(2, 1fr); }
      }

      .part-title {
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: hsl(var(--muted-foreground));
        margin-bottom: 1rem;
      }

      .chapters-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .chapter-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background-color: hsl(var(--card));
        border: 1px solid hsl(var(--border));
        border-radius: 0.5rem;
        padding: 1rem;
        transition: border-color 0.2s ease;
      }

      .chapter-item:hover {
        border-color: hsl(var(--primary) / 0.5);
      }

      .chapter-info {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .chapter-num {
        font-family: ui-monospace, SFMono-Regular, monospace;
        font-size: 0.875rem;
        color: hsl(var(--muted-foreground));
      }

      .chapter-title {
        font-weight: 500;
      }

      /* ============================================
         FAQ
         ============================================ */
      .faq-container {
        max-width: 48rem;
        margin: 0 auto;
      }

      .faq-item {
        border-bottom: 1px solid hsl(var(--border) / 0.6);
      }

      .faq-question {
        display: block;
        width: 100%;
        padding: 1.25rem 0;
        font-size: 1rem;
        font-weight: 500;
        text-align: left;
        cursor: pointer;
        list-style: none;
      }

      .faq-question::-webkit-details-marker {
        display: none;
      }

      .faq-question::after {
        content: "+";
        float: right;
        font-size: 1.25rem;
        transition: transform 0.2s ease;
      }

      details[open] .faq-question::after {
        transform: rotate(45deg);
      }

      .faq-answer {
        padding-bottom: 1.25rem;
        color: hsl(var(--muted-foreground));
      }

      /* ============================================
         CTA
         ============================================ */
      .cta-container {
        max-width: 42rem;
        margin: 0 auto;
      }

      .cta-subtitle {
        margin: 1rem auto 0;
      }

      .cta-buttons {
        margin-top: 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
      }

      @media (min-width: 640px) {
        .cta-buttons { flex-direction: row; }
      }

      .cta-meta {
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: hsl(var(--muted-foreground));
      }

      /* ============================================
         Footer
         ============================================ */
      .footer {
        background-color: hsl(var(--card));
        border-top: 1px solid hsl(var(--border));
      }

      .footer-container {
        max-width: 64rem;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      @media (min-width: 640px) {
        .footer-container { flex-direction: row; }
      }

      .footer-copyright {
        font-size: 0.875rem;
        color: hsl(var(--muted-foreground));
      }

      .footer-nav {
        display: flex;
        gap: 1.5rem;
      }

      .footer-nav a {
        font-size: 0.875rem;
        color: hsl(var(--muted-foreground));
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .footer-nav a:hover {
        color: hsl(var(--foreground));
      }

      /* ============================================
         Animations
         ============================================ */
      .animate-fade-up {
        animation: fadeUp 0.5s ease-out forwards;
      }

      .animate-fade-up-delay {
        animation: fadeUp 0.5s ease-out 0.1s forwards;
        opacity: 0;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </body>
</html>
