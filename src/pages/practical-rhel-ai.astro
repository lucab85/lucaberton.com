---
/**
 * Practical RHEL AI — Astro Static Landing Page
 * Route: /practical-rhel-ai
 *
 * Create file: src/pages/practical-rhel-ai.astro
 */

// Canonical URLs
const CANONICAL_URL = "https://lucaberton.com/practical-rhel-ai/";

// Book links (safe defaults)
// DOI is always stable; you can replace BUY_URL with Springer/Apress product page if you prefer.
const BUY_URL = "https://amzn.to/49BtXPT";

// Companion repo (listed in the book’s front-matter)
const CODE_URL = "https://github.com/Apress/Practical-RHEL-AI";

// Optional: your contact
const CONTACT_EMAIL = "hello@lucaberton.com";

// Optional: sample chapter URL (if you host one). If not, keep it as mailto.
const SAMPLE_URL = `mailto:${CONTACT_EMAIL}?subject=Practical%20RHEL%20AI%20-%20Sample%20Chapter%20Request`;

// SEO Meta
const SITE_NAME = "Luca Berton";
const BOOK_TITLE = "Practical RHEL AI";
const FULL_TITLE = "Practical RHEL AI — Designing, Deploying & Scaling AI on Red Hat Enterprise Linux | Luca Berton";
const META_DESCRIPTION = "Master enterprise AI deployment on Red Hat Enterprise Linux. Learn InstructLab workflows, synthetic data generation, fine-tuning LLMs, GPU optimization, OpenAI-compatible serving, and production operations. By Luca Berton, published by Apress 2026.";
const OG_IMAGE = "https://lucaberton.com/blog/books/practical_RHEL_AI-large.jpg";

// Structured Data for SEO
const bookSchema = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": "Practical RHEL AI: Designing, Deploying and Scaling AI Solutions with Red Hat Enterprise Linux",
  "author": {
    "@type": "Person",
    "name": "Luca Berton",
    "url": "https://lucaberton.com",
    "jobTitle": "AI & Cloud Consultant"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Apress",
    "url": "https://www.apress.com"
  },
  "datePublished": "2026",
  "isbn": "979-8-8688-1901-8",
  "bookFormat": "https://schema.org/Paperback",
  "numberOfPages": "300",
  "inLanguage": "en",
  "image": OG_IMAGE,
  "url": CANONICAL_URL,
  "description": META_DESCRIPTION,
  "genre": ["Artificial Intelligence", "Linux", "DevOps", "Machine Learning"],
  "keywords": "RHEL AI, Red Hat Enterprise Linux AI, InstructLab, LLM fine-tuning, enterprise AI, GenAI deployment, vLLM, GPU optimization, AI operations"
};
---

<html lang="en">
