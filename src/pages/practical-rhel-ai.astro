    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-M9Q5F672JT"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      
      // Replace G-XXXXXXXXXX with your GA4 measurement ID
      gtag('config', 'G-XXXXXXXXXX', {
        'page_path': '/practical-rhel-ai/',
        'page_title': 'Practical RHEL AI',
        'anonymize_ip': false,
        'allow_google_signals': true,
        'allow_ad_personalization_signals': true
      });

      // Track LinkedIn referrer
      if (document.referrer.includes('linkedin.com') || document.referrer.includes('lnkd.in')) {
        gtag('event', 'linkedin_referral', {
          'referrer': document.referrer
        });
      }

      // Scroll depth tracking
      let scrollTracked = {25: false, 50: false, 75: false, 100: false};
      window.addEventListener('scroll', function() {
        const windowHeight = window.innerHeight;
        const documentHeight = document.documentElement.scrollHeight;
        const scrollTop = window.scrollY;
        const scrollPercent = Math.round((scrollTop + windowHeight) / documentHeight * 100);

        if (scrollPercent >= 25 && !scrollTracked[25]) {
          gtag('event', 'scroll_depth', {'scroll_percent': '25%'});
          scrollTracked[25] = true;
        }
        if (scrollPercent >= 50 && !scrollTracked[50]) {
          gtag('event', 'scroll_depth', {'scroll_percent': '50%'});
          scrollTracked[50] = true;
        }
        if (scrollPercent >= 75 && !scrollTracked[75]) {
          gtag('event', 'scroll_depth', {'scroll_percent': '75%'});
          scrollTracked[75] = true;
        }
        if (scrollPercent >= 100 && !scrollTracked[100]) {
          gtag('event', 'scroll_depth', {'scroll_percent': '100%'});
          scrollTracked[100] = true;
        }
      });

      // Track time on page
      let timeOnPageStart = Date.now();
      window.addEventListener('beforeunload', function() {
        const timeOnPage = Math.round((Date.now() - timeOnPageStart) / 1000);
        gtag('event', 'page_engagement', {
          'time_on_page_seconds': timeOnPage,
          'engagement_type': 'explicit'
        });
      });
    </script>

    <!-- Button Click Tracking Script -->
    <script is:inline>
      // Function to track external link clicks
      function trackExternalClick(url, label) {
        gtag('event', 'click', {
          'event_category': 'engagement',
          'event_label': label,
          'value': url,
          'transport_type': 'beacon'
        });
      }

      // Function to track CTA clicks
      function trackCTAClick(cta_name) {
        gtag('event', 'cta_click', {
          'event_category': 'conversion',
          'event_label': cta_name,
          'conversion_action': cta_name
        });
      }

      // Function to track section views
      function trackSectionView(section_name) {
        gtag('event', 'section_view', {
          'event_category': 'engagement',
          'event_label': section_name,
          'section_name': section_name
        });
      }

      // Wait for DOM to be ready
      document.addEventListener('DOMContentLoaded', function() {
        // Track "Buy" button clicks
        const buyButtons = document.querySelectorAll('a[href*="amzn.to"], a[href*="springer"]');
        buyButtons.forEach((btn, index) => {
          btn.addEventListener('click', function(e) {
            trackCTAClick('buy_book_' + (index + 1));
          });
        });

        // Track "Get Companion Resources" clicks
        const resourceButtons = document.querySelectorAll('a[href="#resources"]');
        resourceButtons.forEach((btn, index) => {
          btn.addEventListener('click', function(e) {
            trackCTAClick('view_resources_' + (index + 1));
          });
        });

        // Track GitHub repo link clicks
        const githubLinks = document.querySelectorAll('a[href*="github.com"]');
        githubLinks.forEach((link) => {
          link.addEventListener('click', function(e) {
            trackExternalClick(link.href, 'github_companion_repo');
          });
        });

        // Track sample chapter requests
        const sampleLinks = document.querySelectorAll('a[href*="mailto"]');
        sampleLinks.forEach((link) => {
          link.addEventListener('click', function(e) {
            trackCTAClick('request_sample_chapter');
          });
        });

        // Track FAQ interactions
        const faqItems = document.querySelectorAll('.faq-item');
        faqItems.forEach((item, index) => {
          item.addEventListener('toggle', function(e) {
            if (item.open) {
              gtag('event', 'faq_expansion', {
                'event_category': 'engagement',
                'event_label': 'faq_' + (index + 1),
                'value': item.querySelector('.faq-question').textContent.trim()
              });
            }
          });
        });

        // Track section visibility with Intersection Observer
        const sections = document.querySelectorAll('section');
        const observerOptions = {
          threshold: 0.25
        };

        const sectionObserver = new IntersectionObserver(function(entries) {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const sectionTitle = entry.target.querySelector('.section-title')?.textContent || entry.target.className;
              trackSectionView(sectionTitle);
              sectionObserver.unobserve(entry.target);
            }
          });
        }, observerOptions);

        sections.forEach(section => sectionObserver.observe(section));
      });
    </script>

    <!-- Conversion Tracking for Book Purchases -->
    <script is:inline>
      window.addEventListener('load', function() {
        // Track page load with full details
        gtag('event', 'page_view', {
          'page_title': document.title,
          'page_location': window.location.href,
          'page_path': '/practical-rhel-ai/',
          'traffic_source': document.referrer ? 'referral' : 'direct'
        });
      });
    </script>
  </head>

  <body>
    <main class="min-h-screen">
