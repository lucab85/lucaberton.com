    <!-- Structured Data / JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />
    
    <!-- Breadcrumb Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://lucaberton.com/"
        },
        {
          "@type": "ListItem",
