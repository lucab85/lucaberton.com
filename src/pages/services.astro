---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { Icon } from "astro-icon/components";
import Breadcrumb from "@components/Breadcrumb.astro";
export const prerender = true;
export const lastModified = '2025-03-25';
---

<Layout title="Services">
  <Breadcrumb items={[{ name: "Services" }]} />
  <Container>
    <Sectionhead>
      <Fragment slot="title">Consulting Services</Fragment>
      <Fragment slot="desc">AI. Cloud. Automation. Built for performance, sustainability & scale.</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-12 mt-16 max-w-6xl mx-auto">
      <!-- Automation Strategy -->
      <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl p-6 hover:shadow-2xl transition">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-blue-700 rounded-full p-2 flex items-center justify-center w-10 h-10">
            <Icon name="bx:bxs-cog" class="text-white w-5 h-5" />
          </div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Automation Strategy Consulting</h3>
        </div>
        <p class="text-slate-600 dark:text-slate-300">
          Streamline workflows and eliminate inefficiencies using Ansible, Terraform & Python. Build smarter systems that scale.
        </p>
        <a href="/services/automation-strategy/" class="inline-block mt-4 text-blue-600 dark:text-blue-400 font-semibold hover:underline">Learn More →</a>
      </div>

      <!-- Kubernetes -->
      <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl p-6 hover:shadow-2xl transition">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-blue-700 rounded-full p-2 flex items-center justify-center w-10 h-10">
            <Icon name="bx:bxs-cube" class="text-white w-5 h-5" />
          </div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Kubernetes & Containerization</h3>
        </div>
        <p class="text-slate-600 dark:text-slate-300">
          Master Kubernetes, Docker & microservices for agile, reliable infrastructure—ideal for DevOps teams & architects.
        </p>
        <a href="/services/kubernetes-workshops/" class="inline-block mt-4 text-blue-600 dark:text-blue-400 font-semibold hover:underline">Learn More →</a>
      </div>

      <!-- Cloud Infrastructure -->
      <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl p-6 hover:shadow-2xl transition">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-blue-700 rounded-full p-2 flex items-center justify-center w-10 h-10">
            <Icon name="bx:bxs-cloud" class="text-white w-5 h-5" />
          </div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Cloud Infrastructure Design</h3>
        </div>
        <p class="text-slate-600 dark:text-slate-300">
          Build resilient, cost-effective cloud environments on AWS, Azure & GCP. We prioritize performance & sustainability.
        </p>
        <a href="/services/cloud-infrastructure/" class="inline-block mt-4 text-blue-600 dark:text-blue-400 font-semibold hover:underline">Learn More →</a>
      </div>

      <!-- AI Integration -->
      <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl p-6 hover:shadow-2xl transition">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-blue-700 rounded-full p-2 flex items-center justify-center w-10 h-10">
            <Icon name="bx:bxs-brain" class="text-white w-5 h-5" />
          </div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white">AI Integration & Green Code</h3>
        </div>
        <p class="text-slate-600 dark:text-slate-300">
          Deploy intelligent systems with a green footprint. We help you launch AI solutions that save energy and reduce cost.
        </p>
        <a href="/services/ai-integration/" class="inline-block mt-4 text-blue-600 dark:text-blue-400 font-semibold hover:underline">Learn More →</a>
      </div>

      <!-- Ansible & Python Training -->
      <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl p-6 hover:shadow-2xl transition">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-blue-700 rounded-full p-2 flex items-center justify-center w-10 h-10">
            <Icon name="bx:bxl-python" class="text-white w-5 h-5" />
          </div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Ansible & Python Training</h3>
        </div>
        <p class="text-slate-600 dark:text-slate-300">
          Hands-on, real-world automation and ML training for tech teams using Python & Ansible.
        </p>
        <a href="/services/ansible-python-training/" class="inline-block mt-4 text-blue-600 dark:text-blue-400 font-semibold hover:underline">Learn More →</a>
      </div>

      <!-- Performance Optimization -->
      <div class="bg-white dark:bg-gray-900 shadow-lg rounded-2xl p-6 hover:shadow-2xl transition">
        <div class="flex items-center gap-3 mb-4">
          <div class="bg-blue-700 rounded-full p-2 flex items-center justify-center w-10 h-10">
            <Icon name="bx:bxs-rocket" class="text-white w-5 h-5" />
          </div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Performance Optimization</h3>
        </div>
        <p class="text-slate-600 dark:text-slate-300">
          Tune your infrastructure, playbooks & scripts for maximum performance and environmental impact reduction.
        </p>
        <a href="/services/performance-optimization/" class="inline-block mt-4 text-blue-600 dark:text-blue-400 font-semibold hover:underline">Learn More →</a>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center bg-blue-100 dark:bg-blue-900 py-12 rounded-2xl mt-20 shadow-inner">
      <div class="bg-blue-600 dark:bg-blue-400 text-white w-12 h-12 mx-auto flex items-center justify-center rounded-full">
        <Icon name="bx:bxs-rocket" class="w-6 h-6" />
      </div>
      <h3 class="text-3xl font-bold text-gray-800 dark:text-white mt-4">Ready to Transform Your Business?</h3>
      <p class="text-slate-600 dark:text-slate-300 mt-2 max-w-xl mx-auto">
        Let's talk AI, Automation & Cloud. Get expert guidance tailored to your goals.
      </p>
      <a href="/contact/" class="mt-6 inline-block bg-blue-600 dark:bg-blue-400 text-white font-bold py-3 px-8 rounded-full hover:bg-blue-700 dark:hover:bg-blue-300 transition">
        Get in Touch
      </a>
    </div>
  </Container>
</Layout>
