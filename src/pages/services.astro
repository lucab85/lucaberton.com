---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
export const prerender = true;
export const lastModified = '2025-03-25';
---

<Layout title="Services">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Consulting Services</Fragment>
      <Fragment slot="desc">Expert AI, Cloud & Automation Solutions</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-5xl mt-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Automation Strategy Consulting</h3>
        <p class="text-slate-500 mt-2">
          Enhance workflows, reduce errors, and boost efficiency with expert automation strategies using Ansible, Terraform, and Python.
          <a href="/services/automation-strategy" class="text-blue-500 hover:underline">Learn More</a>
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Kubernetes & Containerization</h3>
        <p class="text-slate-500 mt-2">
          Hands-on training in Kubernetes, Docker, and cloud-native applications for scalable, resilient infrastructure.
          <a href="/services/kubernetes-workshops" class="text-blue-500 hover:underline">Learn More</a>
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-5xl mt-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Cloud Infrastructure Design</h3>
        <p class="text-slate-500 mt-2">
          Optimize cloud architectures for AWS, Azure, and Google Cloud with a focus on performance and sustainability.
          <a href="/services/cloud-infrastructure" class="text-blue-500 hover:underline">Learn More</a>
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-gray-700">AI Integration & Green Code</h3>
        <p class="text-slate-500 mt-2">
          Deploy AI-driven solutions efficiently while maintaining sustainability with optimized cloud strategies.
          <a href="/services/ai-integration" class="text-blue-500 hover:underline">Learn More</a>
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-5xl mt-12">
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Ansible & Python Training</h3>
        <p class="text-slate-500 mt-2">
          Learn automation, configuration management, and machine learning workflows with hands-on Ansible & Python training.
          <a href="/services/ansible-python-training" class="text-blue-500 hover:underline">Learn More</a>
        </p>
      </div>
      <div>
        <h3 class="text-xl font-semibold text-gray-700">Performance Optimization & Custom Solutions</h3>
        <p class="text-slate-500 mt-2">
          Profile and optimize playbooks, scripts, and infrastructure for efficiency, cost reduction, and minimal environmental impact.
          <a href="/services/performance-optimization" class="text-blue-500 hover:underline">Learn More</a>
        </p>
      </div>
    </div>

    <div class="text-center bg-blue-50 mt-12">
      <h3 class="text-2xl font-semibold text-gray-700">Ready to Transform Your Business?</h3>
      <p class="text-slate-500 mt-2">
        Contact me TODAY to discuss your AI, Cloud, and Automation needs.
      </p>
      <div class="mt-4">
        <a href="/contact" class="bg-blue-500 text-white px-6 py-3 rounded-lg hover:bg-blue-600 font-bold">
          Get in Touch
        </a>
      </div>
    </div>
  </Container>
</Layout>
