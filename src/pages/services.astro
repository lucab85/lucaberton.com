---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import { Icon } from "astro-icon/components";
export const prerender = true;
export const lastModified = '2026-03-18';
---

<Layout title="AI & Cloud Consulting Services" description="Expert consulting in AI integration, GPU platforms, Kubernetes, cloud infrastructure, Ansible & Python training, and automation strategy.">
  <Breadcrumb items={[{ name: "Services" }]} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-20 text-center">
    <Container>
      <p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-3">Consulting & Advisory</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight max-w-3xl mx-auto">
        Turn AI & Cloud into <span class="text-blue-400">measurable business outcomes</span>
      </h1>
      <p class="text-slate-400 mt-4 max-w-2xl mx-auto text-lg">
        Not theory. Not slides. You get working systems, trained teams, and a clear scorecard showing what changed.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-8">
        <a href="/contact/" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Free Discovery Call</a>
        <a href="#how-it-works" class="border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white font-semibold py-3 px-8 rounded-lg transition-all cursor-pointer">See How It Works ↓</a>
      </div>
    </Container>
  </section>

  <!-- Trust Strip -->
  <section class="bg-slate-800 py-6 border-y border-slate-700">
    <Container>
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
        <div>
          <p class="text-2xl font-bold text-white">40,000+</p>
          <p class="text-xs text-slate-400 uppercase tracking-wider">Students Trained</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-white">15+</p>
          <p class="text-xs text-slate-400 uppercase tracking-wider">Years Experience</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-white">3</p>
          <p class="text-xs text-slate-400 uppercase tracking-wider">Published Books</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-white">100+</p>
          <p class="text-xs text-slate-400 uppercase tracking-wider">Enterprise Projects</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- How It Works -->
  <section id="how-it-works" class="py-20 bg-white">
    <Container>
      <div class="text-center mb-16">
        <p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-2">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Three steps to measurable results</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-blue-600">1</span>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">Discovery & Scorecard</h3>
          <p class="text-gray-600 text-sm leading-relaxed">We assess your current state across AI, cloud, and automation maturity. You get a clear scorecard with gaps, risks, and quick wins — before any engagement starts.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-blue-600">2</span>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">Build & Implement</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Hands-on delivery: architecture design, platform setup, automation pipelines, training workshops. Your team works alongside me — no black-box consulting.</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-blue-600">3</span>
          </div>
          <h3 class="font-bold text-gray-900 text-lg mb-2">Measure & Handover</h3>
          <p class="text-gray-600 text-sm leading-relaxed">We measure results against the scorecard. Your team owns everything: the platform, the runbooks, the knowledge. No vendor lock-in, no dependency.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-slate-50">
    <Container>
      <div class="text-center mb-16">
        <p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-2">What You Get</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Services built around outcomes</h2>
        <p class="text-gray-500 mt-3 max-w-2xl mx-auto">Each service has clear deliverables. No vague "advisory" — you know exactly what you receive.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">

        <!-- AI Integration -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border border-slate-100">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl p-3 flex items-center justify-center">
              <Icon name="bx:bxs-brain" class="text-white w-6 h-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">AI Integration & GPU Platforms</h3>
              <p class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Strategy + Implementation</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-5">Deploy AI into production — not just prototypes. GPU cluster design, model serving infrastructure, and cost optimization.</p>
          <div class="border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">What you receive:</p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>AI Readiness Scorecard</strong> — maturity assessment across data, infra, and team skills</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>GPU Cost Calculator</strong> — cloud vs on-prem TCO analysis for your workloads</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Production architecture</strong> — model serving, observability, and auto-scaling design</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Working deployment</strong> — not a slide deck, a running system your team owns</span>
              </li>
            </ul>
          </div>
          <a href="/services/ai-integration/" class="inline-flex items-center gap-1 mt-5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors cursor-pointer">
            Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Kubernetes -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border border-slate-100">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl p-3 flex items-center justify-center">
              <Icon name="bx:bxs-cube" class="text-white w-6 h-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">Kubernetes & Platform Engineering</h3>
              <p class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Workshop + Architecture</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-5">Build internal developer platforms that teams actually use. From cluster architecture to golden paths and self-service.</p>
          <div class="border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">What you receive:</p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>2-day hands-on workshop</strong> — your team builds a real cluster, not a toy demo</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Platform maturity scorecard</strong> — where you are vs. where you need to be</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Production-grade manifests</strong> — GitOps, RBAC, network policies, observability stack</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Golden path templates</strong> — CI/CD pipelines your developers deploy with on day one</span>
              </li>
            </ul>
          </div>
          <a href="/services/kubernetes-workshops/" class="inline-flex items-center gap-1 mt-5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors cursor-pointer">
            Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Automation Strategy -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border border-slate-100">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl p-3 flex items-center justify-center">
              <Icon name="bx:bxs-cog" class="text-white w-6 h-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">Automation Strategy & Ansible</h3>
              <p class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Assessment + Implementation</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-5">Eliminate manual toil. Build automation frameworks that scale from 10 servers to 10,000 without breaking.</p>
          <div class="border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">What you receive:</p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Automation maturity audit</strong> — current state, bottlenecks, and ROI opportunities</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Ansible playbook library</strong> — production-tested roles for your infrastructure</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>CI/CD pipeline integration</strong> — automated testing, linting, and deployment</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Team enablement sessions</strong> — your team writes and maintains playbooks independently</span>
              </li>
            </ul>
          </div>
          <a href="/services/automation-strategy/" class="inline-flex items-center gap-1 mt-5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors cursor-pointer">
            Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Cloud Infrastructure -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border border-slate-100">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl p-3 flex items-center justify-center">
              <Icon name="bx:bxs-cloud" class="text-white w-6 h-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">Cloud Infrastructure Design</h3>
              <p class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Architecture + Migration</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-5">Resilient, cost-effective cloud environments on AWS, Azure, or GCP. Designed for performance and sustainability.</p>
          <div class="border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">What you receive:</p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Cloud cost review</strong> — find savings before spending more</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Architecture blueprint</strong> — multi-AZ, IaC-first, security-hardened design</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Terraform/Ansible modules</strong> — reproducible infrastructure from day one</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Migration runbook</strong> — step-by-step plan with rollback procedures</span>
              </li>
            </ul>
          </div>
          <a href="/services/cloud-infrastructure/" class="inline-flex items-center gap-1 mt-5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors cursor-pointer">
            Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Training -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border border-slate-100">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl p-3 flex items-center justify-center">
              <Icon name="bx:bxl-python" class="text-white w-6 h-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">Ansible & Python Training</h3>
              <p class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Hands-On Workshop</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-5">Real-world training that sticks. Your team practices on production-like scenarios, not toy examples.</p>
          <div class="border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">What you receive:</p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Custom workshop</strong> — tailored to your tech stack and real infrastructure</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Lab environment</strong> — hands-on exercises every participant completes</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Reference code repository</strong> — production patterns your team keeps forever</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Skills assessment</strong> — before/after measurement of team capability</span>
              </li>
            </ul>
          </div>
          <a href="/services/ansible-python-training/" class="inline-flex items-center gap-1 mt-5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors cursor-pointer">
            Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

        <!-- Performance Optimization -->
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 border border-slate-100">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl p-3 flex items-center justify-center">
              <Icon name="bx:bxs-rocket" class="text-white w-6 h-6" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">Performance Optimization</h3>
              <p class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Audit + Quick Wins</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed mb-5">Find the bottlenecks, fix the quick wins, build a roadmap for the rest. Measurable improvement in weeks, not quarters.</p>
          <div class="border-t border-slate-100 pt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">What you receive:</p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Performance audit report</strong> — bottlenecks ranked by impact and effort</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Quick-win implementations</strong> — immediate fixes deployed in the first week</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Optimization roadmap</strong> — prioritized plan for the next 90 days</span>
              </li>
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-green-500 mt-0.5">✓</span>
                <span><strong>Before/after benchmarks</strong> — measurable proof of improvement</span>
              </li>
            </ul>
          </div>
          <a href="/services/performance-optimization/" class="inline-flex items-center gap-1 mt-5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors cursor-pointer">
            Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>

      </div>
    </Container>
  </section>

  <!-- Who It's For -->
  <section class="py-20 bg-white">
    <Container>
      <div class="text-center mb-12">
        <p class="text-blue-600 text-sm font-semibold uppercase tracking-widest mb-2">Who This Is For</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Built for engineering leaders</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🏢</div>
          <h3 class="font-bold text-gray-900 mb-2">CTOs & VPs of Engineering</h3>
          <p class="text-gray-600 text-sm">Need a clear AI and cloud strategy with measurable ROI. Want to move fast without building the wrong thing.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">⚙️</div>
          <h3 class="font-bold text-gray-900 mb-2">Platform & DevOps Teams</h3>
          <p class="text-gray-600 text-sm">Scaling infrastructure, adopting Kubernetes, or building internal platforms. Need expert guidance to avoid costly mistakes.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-4xl mb-4">🚀</div>
          <h3 class="font-bold text-gray-900 mb-2">Scale-ups & Enterprises</h3>
          <p class="text-gray-600 text-sm">Outgrowing current infrastructure. Need to level up automation, security, and AI capabilities without slowing down delivery.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-20">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white">Start with a free discovery call</h2>
        <p class="text-slate-400 mt-4 text-lg">
          30 minutes. No pitch. We look at your current setup, identify the highest-impact opportunity, and you decide if it makes sense to work together.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          <a href="/contact/" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Free Call</a>
          <a href="/gpu-cost-calculator/" class="border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white font-semibold py-3 px-8 rounded-lg transition-all cursor-pointer">Try the GPU Cost Calculator</a>
        </div>
      </div>
    </Container>
  </section>

</Layout>
