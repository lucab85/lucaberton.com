---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import ServiceRelatedPosts from "@components/ServiceRelatedPosts.astro";
export const prerender = true;
export const lastModified = '2026-03-19';
---

<Layout title="Ansible & Python Training" description="Hands-on Ansible and Python training for teams. From beginner to advanced automation, tailored workshops with real-world exercises.">
  <Breadcrumb items={[{ name: "Services", url: "/services/" }, { name: "Ansible & Python Training" }]} />
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="max-w-3xl">
        <p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-3">Ansible & Python Training</p>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">Your team writing production-ready playbooks by Friday</h1>
        <p class="text-slate-400 mt-4 text-lg">Hands-on workshops designed for engineers who need to automate real infrastructure, not pass a multiple-choice exam.</p>
        <a href="/contact/" class="mt-8 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Request a Workshop</a>
      </div>
    </Container>
  </section>

  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">The challenge</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-red-50 border border-red-100 rounded-xl p-5">
            <p class="text-sm text-red-800 font-semibold mb-2">Self-taught automation</p>
            <ul class="space-y-2 text-sm text-red-700">
              <li>{"❌"} Engineers copy-paste from Stack Overflow without understanding</li>
              <li>{"❌"} No consistent patterns — every playbook looks different</li>
              <li>{"❌"} No testing — changes go straight to production</li>
              <li>{"❌"} Python scripts that only the author can maintain</li>
            </ul>
          </div>
          <div class="bg-green-50 border border-green-100 rounded-xl p-5">
            <p class="text-sm text-green-800 font-semibold mb-2">After structured training</p>
            <ul class="space-y-2 text-sm text-green-700">
              <li>{"✓"} Team writes idiomatic, maintainable Ansible roles</li>
              <li>{"✓"} Shared conventions — any engineer can read any playbook</li>
              <li>{"✓"} Molecule testing in CI before every merge</li>
              <li>{"✓"} Clean Python modules that integrate with Ansible</li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Workshop formats</h2>
        <p class="text-gray-500 mb-8">Tailored to your team's level and infrastructure.</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">🎯</div>
            <h3 class="font-bold text-gray-900 mb-2">2-Day Ansible Fundamentals</h3>
            <p class="text-sm text-gray-600">From zero to production-ready. Inventory, playbooks, roles, variables, templates, handlers, and error handling. Every concept practiced on real infrastructure.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">🚀</div>
            <h3 class="font-bold text-gray-900 mb-2">Advanced Ansible & CI/CD</h3>
            <p class="text-sm text-gray-600">Collections, custom modules, Molecule testing, AWX/AAP integration, and Event-Driven Ansible. For teams already using Ansible who want to level up.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">🐍</div>
            <h3 class="font-bold text-gray-900 mb-2">Python for Infrastructure</h3>
            <p class="text-sm text-gray-600">Python scripting for DevOps: API automation, custom Ansible modules, data processing, and integration with cloud SDKs.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">📦</div>
            <h3 class="font-bold text-gray-900 mb-2">Custom Workshop</h3>
            <p class="text-sm text-gray-600">Built around your stack. Bring your real playbooks, real infrastructure, and real problems. We fix them together and your team leaves with working code.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Instructor credentials</h2>
        <div class="grid md:grid-cols-3 gap-6 text-center">
          <div class="p-4">
            <p class="text-3xl font-bold text-blue-600">8</p>
            <p class="text-sm text-gray-500">Published books on Ansible</p>
          </div>
          <div class="p-4">
            <p class="text-3xl font-bold text-blue-600">40,000+</p>
            <p class="text-sm text-gray-500">Students trained online</p>
          </div>
          <div class="p-4">
            <p class="text-3xl font-bold text-blue-600">15+</p>
            <p class="text-sm text-gray-500">Years hands-on experience</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related services</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/services/automation-strategy/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Automation Strategy</h3>
            <p class="text-xs text-gray-500 mt-1">Build the automation framework</p>
          </a>
          <a href="/services/kubernetes-workshops/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Kubernetes Workshops</h3>
            <p class="text-xs text-gray-500 mt-1">Container orchestration training</p>
          </a>
          <a href="/services/ai-integration/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">AI Integration</h3>
            <p class="text-xs text-gray-500 mt-1">Ansible Lightspeed and AI ops</p>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <Container><ServiceRelatedPosts keywords={["ansible", "python", "training", "automation", "molecule"]} /></Container>

  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-white">Ready to upskill your team?</h2>
        <p class="text-slate-400 mt-3">Tell me about your team size, current skill level, and infrastructure. I will propose a workshop that fits.</p>
        <a href="/contact/" class="mt-6 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Request a Workshop</a>
      </div>
    </Container>
  </section>
</Layout>
