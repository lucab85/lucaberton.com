---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import ServiceRelatedPosts from "@components/ServiceRelatedPosts.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;
export const lastModified = '2026-04-05';
---

<Layout title="Automation Strategy & Ansible Consulting" description="Ansible automation strategy consulting. Infrastructure as code, CI/CD pipelines, configuration management, compliance automation, and team enablement from an 8-book author.">
  <Breadcrumb items={[{ name: "Services", url: "/services/" }, { name: "Automation Strategy & Ansible" }]} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="max-w-3xl">
        <p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-3">Automation Strategy & Ansible</p>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">
          Stop doing manually what a playbook can do in seconds
        </h1>
        <p class="text-slate-400 mt-4 text-lg">
          Every manual process is a failure waiting to happen at 3 AM. I help you build automation frameworks that scale from 10 servers to 10,000 — and your team owns every line of code.
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <a href="/contact/" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Discovery Call</a>
          <a href="https://calendly.com/lucaberton/" class="border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white font-semibold py-3 px-8 rounded-lg transition-all cursor-pointer">Schedule on Calendly</a>
        </div>
      </div>
    </Container>
  </section>

  <!-- The Problem -->
  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">The challenge</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-red-50 border border-red-100 rounded-xl p-5">
            <p class="text-sm text-red-800 font-semibold mb-2">Manual operations</p>
            <ul class="space-y-2 text-sm text-red-700">
              <li>❌ Server configuration takes hours, varies between engineers</li>
              <li>❌ Deployments are fragile — one missed step breaks production</li>
              <li>❌ Compliance audits require weeks of manual evidence gathering</li>
              <li>❌ Knowledge lives in people's heads, not in code</li>
              <li>❌ Same mistakes repeated across teams and environments</li>
            </ul>
          </div>
          <div class="bg-green-50 border border-green-100 rounded-xl p-5">
            <p class="text-sm text-green-800 font-semibold mb-2">Automated operations</p>
            <ul class="space-y-2 text-sm text-green-700">
              <li>✓ Consistent configuration in minutes, every time</li>
              <li>✓ Deployments are repeatable, tested, and auditable</li>
              <li>✓ Compliance evidence generated automatically</li>
              <li>✓ Knowledge is in Git — survives team changes</li>
              <li>✓ Self-service provisioning for development teams</li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">How it works</h2>
        <p class="text-gray-500 mb-8">A structured approach — from audit to autonomous team in weeks.</p>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="text-center">
            <div class="w-12 h-12 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">1</div>
            <h3 class="font-bold text-gray-900 mb-2">Audit & Prioritize</h3>
            <p class="text-sm text-gray-600">Map every manual process across provisioning, configuration, deployment, and compliance. Rank by frequency, error rate, and business impact. Identify quick wins that deliver ROI in the first sprint.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">2</div>
            <h3 class="font-bold text-gray-900 mb-2">Build & Test</h3>
            <p class="text-sm text-gray-600">Develop production-grade Ansible roles and playbooks with your team. Every role tested with Molecule, linted with ansible-lint, and integrated into your CI/CD pipeline from day one.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xl font-bold mx-auto mb-4">3</div>
            <h3 class="font-bold text-gray-900 mb-2">Enable & Transfer</h3>
            <p class="text-sm text-gray-600">Hands-on training, code review sessions, and documentation. Your team writes and maintains playbooks independently. I leave when you do not need me anymore.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- What You Get -->
  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">What you receive</h2>
        <p class="text-gray-500 mb-8">Concrete deliverables your team owns from day one.</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">📊</div>
            <h3 class="font-bold text-gray-900 mb-2">Automation Maturity Audit</h3>
            <p class="text-sm text-gray-600">Current state assessment across provisioning, configuration, deployment, and compliance. Bottlenecks ranked by ROI impact with a phased roadmap — quick wins, medium-term projects, and strategic initiatives.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">📦</div>
            <h3 class="font-bold text-gray-900 mb-2">Ansible Playbook Library</h3>
            <p class="text-sm text-gray-600">Production-tested roles and playbooks tailored to your infrastructure. Modular, idempotent, linted, tested with Molecule, and documented with clear README files for every role.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">🔄</div>
            <h3 class="font-bold text-gray-900 mb-2">CI/CD Pipeline Integration</h3>
            <p class="text-sm text-gray-600">Automated testing, linting, and deployment pipelines. Your playbooks are validated on every commit, tested against ephemeral environments, and deployed through a controlled pipeline with approval gates.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">🛡️</div>
            <h3 class="font-bold text-gray-900 mb-2">Compliance as Code</h3>
            <p class="text-sm text-gray-600">CIS benchmarks, SOC 2, and custom policies encoded as Ansible roles. Automated evidence collection, drift detection, and remediation. Auditors get generated reports instead of spreadsheets.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">🎓</div>
            <h3 class="font-bold text-gray-900 mb-2">Team Enablement Program</h3>
            <p class="text-sm text-gray-600">Hands-on training sessions adapted to your team's level. Code review workshops, pair programming on real playbooks, and a skills progression framework from beginner to advanced automation engineer.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">📖</div>
            <h3 class="font-bold text-gray-900 mb-2">Automation Standards Guide</h3>
            <p class="text-sm text-gray-600">Naming conventions, directory structure, role design patterns, secrets management, inventory organization, and Git workflow. The playbook for writing playbooks — so quality stays consistent as the team grows.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Automation Domains -->
  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">What I automate</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-white rounded-xl p-5 border border-slate-100">
            <h3 class="font-bold text-gray-900 text-sm mb-2">🖥️ Server Provisioning</h3>
            <p class="text-xs text-gray-600">Bare metal, VMs, cloud instances. Consistent base images, security hardening, package management, user accounts, SSH keys, firewall rules.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-100">
            <h3 class="font-bold text-gray-900 text-sm mb-2">🔧 Configuration Management</h3>
            <p class="text-xs text-gray-600">Idempotent state enforcement across thousands of servers. Drift detection, remediation, and templated configurations for every environment.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-100">
            <h3 class="font-bold text-gray-900 text-sm mb-2">🚀 Application Deployment</h3>
            <p class="text-xs text-gray-600">Zero-downtime rolling deployments, canary releases, blue-green strategies. Database migrations, service health checks, automatic rollback.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-100">
            <h3 class="font-bold text-gray-900 text-sm mb-2">🛡️ Security & Compliance</h3>
            <p class="text-xs text-gray-600">CIS benchmark enforcement, patch management, vulnerability scanning, certificate rotation, secrets management, audit trail generation.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-100">
            <h3 class="font-bold text-gray-900 text-sm mb-2">☁️ Cloud Operations</h3>
            <p class="text-xs text-gray-600">Multi-cloud provisioning with Terraform + Ansible. AWS, Azure, GCP resource management, cost tagging, lifecycle policies, and cleanup automation.</p>
          </div>
          <div class="bg-white rounded-xl p-5 border border-slate-100">
            <h3 class="font-bold text-gray-900 text-sm mb-2">⚡ Event-Driven Automation</h3>
            <p class="text-xs text-gray-600">EDA with Ansible Rulebooks. Auto-remediate incidents, respond to monitoring alerts, orchestrate workflows triggered by webhooks and message queues.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Proven Track Record -->
  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Proven expertise</h2>
        <div class="grid md:grid-cols-4 gap-6 text-center">
          <div class="p-4">
            <p class="text-3xl font-bold text-blue-600">8</p>
            <p class="text-sm text-gray-500">Published books on Ansible</p>
          </div>
          <div class="p-4">
            <p class="text-3xl font-bold text-blue-600">40,000+</p>
            <p class="text-sm text-gray-500">Students trained online</p>
          </div>
          <div class="p-4">
            <p class="text-3xl font-bold text-blue-600">15+</p>
            <p class="text-sm text-gray-500">Years of automation</p>
          </div>
          <div class="p-4">
            <p class="text-3xl font-bold text-blue-600">500+</p>
            <p class="text-sm text-gray-500">Ansible YouTube videos</p>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-3 justify-center">
          {["Ansible", "Ansible Automation Platform", "AWX", "Terraform", "Python", "Molecule", "ansible-lint", "GitHub Actions", "GitLab CI", "Jenkins", "Event-Driven Ansible", "Ansible Lightspeed", "Jinja2", "YAML", "Vault", "Semaphore"].map(tech => (
            <span class="bg-slate-100 text-slate-700 text-sm font-medium px-3 py-1.5 rounded-lg">{tech}</span>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Related Services -->
  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related services</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/services/ansible-python-training/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Ansible & Python Training</h3>
            <p class="text-xs text-gray-500 mt-1">Hands-on workshop for your team</p>
          </a>
          <a href="/services/performance-optimization/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Performance Optimization</h3>
            <p class="text-xs text-gray-500 mt-1">Tune playbook execution speed at scale</p>
          </a>
          <a href="/services/cloud-infrastructure/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Cloud Infrastructure Design</h3>
            <p class="text-xs text-gray-500 mt-1">Automate cloud deployments end-to-end</p>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    <ServiceRelatedPosts keywords={["automation", "ansible", "strategy", "platform-engineering", "terraform", "iac"]} />
  </Container>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-white">Ready to automate?</h2>
        <p class="text-slate-400 mt-3">30-minute discovery call. We identify the highest-impact automation opportunities and build a plan that fits your team.</p>
        <div class="flex flex-wrap gap-4 mt-6 justify-center">
          <a href="/contact/" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Free Call</a>
          <a href="https://calendly.com/lucaberton/" class="border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white font-semibold py-3 px-8 rounded-lg transition-all cursor-pointer">Or Pick a Time on Calendly</a>
        </div>
      </div>
    </Container>
  </section>
</Layout>
