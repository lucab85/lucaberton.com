---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import ServiceRelatedPosts from "@components/ServiceRelatedPosts.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;
export const lastModified = '2026-03-18';
---

<Layout title="Cloud Infrastructure Design" description="Cloud infrastructure architecture and migration consulting. Multi-cloud strategy, hybrid deployments, cost optimization, and platform engineering.">
  <Breadcrumb items={[{ name: "Services", url: "/services/" }, { name: "Cloud Infrastructure Design" }]} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="max-w-3xl">
        <p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-3">Cloud Infrastructure Design</p>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">
          Cloud that performs, scales, and does not surprise you with the bill
        </h1>
        <p class="text-slate-400 mt-4 text-lg">
          I design cloud environments where reliability, cost, and security are baked in from the start — not bolted on when something breaks.
        </p>
        <a href="/contact/" class="mt-8 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Discovery Call</a>
      </div>
    </Container>
  </section>

  <!-- The Problem -->
  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">The challenge</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-red-50 border border-red-100 rounded-xl p-5">
            <p class="text-sm text-red-800 font-semibold mb-2">Common cloud problems</p>
            <ul class="space-y-2 text-sm text-red-700">
              <li>❌ Cloud bill 2-3x higher than expected</li>
              <li>❌ Infrastructure created manually — no reproducibility</li>
              <li>❌ Single region, single AZ — one outage takes everything down</li>
              <li>❌ Security added as an afterthought</li>
            </ul>
          </div>
          <div class="bg-green-50 border border-green-100 rounded-xl p-5">
            <p class="text-sm text-green-800 font-semibold mb-2">Properly designed cloud</p>
            <ul class="space-y-2 text-sm text-green-700">
              <li>✓ Right-sized resources — pay for what you use</li>
              <li>✓ 100% IaC — every resource is in Git</li>
              <li>✓ Multi-AZ by default, multi-region where needed</li>
              <li>✓ Security hardened from the foundation</li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- What You Get -->
  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">What you receive</h2>
        <p class="text-gray-500 mb-8">A complete cloud foundation your team can maintain and evolve.</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">💰</div>
            <h3 class="font-bold text-gray-900 mb-2">Cloud Cost Review</h3>
            <p class="text-sm text-gray-600">Line-by-line analysis of your current cloud spend. Savings opportunities identified with specific actions — typically 30-50% reduction without losing capability.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">🏗️</div>
            <h3 class="font-bold text-gray-900 mb-2">Architecture Blueprint</h3>
            <p class="text-sm text-gray-600">Multi-AZ, IaC-first, security-hardened design document. Network topology, IAM structure, compute strategy, storage tiers, and disaster recovery plan.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">📦</div>
            <h3 class="font-bold text-gray-900 mb-2">Terraform & Ansible Modules</h3>
            <p class="text-sm text-gray-600">Reproducible infrastructure modules for your specific environment. Tested, documented, and ready for your CI/CD pipeline. Your team maintains and extends them.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
            <div class="text-2xl mb-3">📋</div>
            <h3 class="font-bold text-gray-900 mb-2">Migration Runbook</h3>
            <p class="text-sm text-gray-600">Step-by-step plan with rollback procedures, risk assessment, and timeline. Every phase has clear success criteria and go/no-go checkpoints.</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Cloud Providers -->
  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Platforms and tools</h2>
        <div class="flex flex-wrap gap-3">
          {["AWS", "Azure", "Google Cloud", "Terraform", "Ansible", "Crossplane", "CloudFormation", "Pulumi", "Kubernetes", "Docker", "Prometheus", "Grafana", "Datadog", "Cloudflare", "GitLab CI", "GitHub Actions"].map(tech => (
            <span class="bg-slate-100 text-slate-700 text-sm font-medium px-3 py-1.5 rounded-lg">{tech}</span>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Related Services -->
  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related services</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/services/kubernetes-workshops/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Kubernetes & Platform Engineering</h3>
            <p class="text-xs text-gray-500 mt-1">Run containers on your cloud</p>
          </a>
          <a href="/services/automation-strategy/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Automation Strategy & Ansible</h3>
            <p class="text-xs text-gray-500 mt-1">Automate cloud provisioning</p>
          </a>
          <a href="/services/ai-integration/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">AI Integration & GPU Platforms</h3>
            <p class="text-xs text-gray-500 mt-1">Deploy AI in the cloud</p>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    <ServiceRelatedPosts keywords={["cloud", "aws", "azure", "infrastructure", "security", "networking", "terraform"]} />
  </Container>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-white">Ready to fix your cloud?</h2>
        <p class="text-slate-400 mt-3">30-minute discovery call. We review your current setup, identify cost savings and reliability gaps, and build a plan.</p>
        <a href="/contact/" class="mt-6 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Free Call</a>
      </div>
    </Container>
  </section>
</Layout>
