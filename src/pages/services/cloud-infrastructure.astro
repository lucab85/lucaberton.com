---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Cta from "@components/cta.astro";
import Breadcrumb from "@components/Breadcrumb.astro";

export const prerender = true;
export const lastModified = '2025-03-25';
---

<Layout title="Cloud Infrastructure Design">
  <Breadcrumb items={[{ name: "Services", url: "/services/" }, { name: "Cloud Infrastructure Design" }]} />
  <Container>
    <Sectionhead>
      <Fragment slot="title">Cloud Infrastructure Design</Fragment>
      <Fragment slot="desc">Optimize AWS, Azure, and Google Cloud Environments for Efficiency and Sustainability</Fragment>
    </Sectionhead>
    <p class="text-slate-500 mt-4">
      Ensure cost-efficient, scalable, and secure cloud architecture with Luca Berton’s cloud infrastructure consulting services.
    </p>
    <p class="text-slate-500 mt-4">
      <strong>Service Focus:</strong>
      <ul class="list-disc list-inside mt-2">
        <li>Right-sizing cloud resources to avoid over-provisioning.</li>
        <li>Implementing sustainable and energy-efficient cloud strategies.</li>
        <li>Integrating auto-scaling and serverless architectures.</li>
        <li>Ensuring compliance with security best practices.</li>
        <li>Optimizing cost-efficiency across AWS, Azure, and Google Cloud.</li>
      </ul>
    </p>

    <h3 class="text-xl font-semibold text-gray-700 mt-6">Related Services</h3>
    <ul class="list-disc list-inside text-slate-500 mt-2">
      <li><a href="/services/kubernetes-workshops/" class="text-blue-600 hover:underline">Kubernetes Workshops</a> – Run containers in the cloud.</li>
      <li><a href="/services/performance-optimization/" class="text-blue-600 hover:underline">Performance Optimization</a> – Right-size and tune cloud resources.</li>
      <li><a href="/services/ai-integration/" class="text-blue-600 hover:underline">AI Integration</a> – Deploy AI in cloud environments.</li>
    </ul>

    <Cta />
  </Container>
</Layout>