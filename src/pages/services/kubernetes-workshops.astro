---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import ServiceRelatedPosts from "@components/ServiceRelatedPosts.astro";
import { Icon } from "astro-icon/components";

export const prerender = true;
export const lastModified = '2026-03-18';
---

<Layout title="Kubernetes & Platform Engineering" description="Hands-on Kubernetes workshops and platform engineering consulting. Container orchestration, Helm, operators, security, and production-grade cluster management.">
  <Breadcrumb items={[{ name: "Services", url: "/services/" }, { name: "Kubernetes & Platform Engineering" }]} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="max-w-3xl">
        <p class="text-blue-400 text-sm font-semibold uppercase tracking-widest mb-3">Kubernetes & Platform Engineering</p>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">
          Build platforms your developers actually want to use
        </h1>
        <p class="text-slate-400 mt-4 text-lg">
          Your team should ship features, not fight infrastructure. I help you design internal developer platforms on Kubernetes that reduce cognitive load and accelerate delivery.
        </p>
        <a href="/contact/" class="mt-8 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Discovery Call</a>
      </div>
    </Container>
  </section>

  <!-- The Problem -->
  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">The challenge</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-red-50 border border-red-100 rounded-xl p-5">
            <p class="text-sm text-red-800 font-semibold mb-2">What I see in most organizations</p>
            <ul class="space-y-2 text-sm text-red-700">
              <li>❌ Developers wait days for environment provisioning</li>
              <li>❌ Every team invents their own deployment pipeline</li>
              <li>❌ Security policies applied inconsistently</li>
              <li>❌ "It works on my machine" still happens in production</li>
            </ul>
          </div>
          <div class="bg-green-50 border border-green-100 rounded-xl p-5">
            <p class="text-sm text-green-800 font-semibold mb-2">After the engagement</p>
            <ul class="space-y-2 text-sm text-green-700">
              <li>✓ Self-service platform — developers deploy in minutes</li>
              <li>✓ Golden paths with built-in security and compliance</li>
              <li>✓ Consistent environments from dev to production</li>
              <li>✓ Team owns and maintains everything independently</li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- What You Get -->
  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">What you receive</h2>
        <p class="text-gray-500 mb-8">Choose the format that fits: workshop, architecture engagement, or both.</p>

        <!-- Workshop -->
        <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm mb-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full uppercase">Workshop</span>
            <h3 class="font-bold text-gray-900 text-lg">2-Day Hands-On Kubernetes Workshop</h3>
          </div>
          <p class="text-sm text-gray-600 mb-4">Your team builds a real cluster, deploys real applications, and learns production patterns — not toy demos.</p>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Day 1: Foundations</p>
              <ul class="space-y-1.5 text-sm text-gray-700">
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> Cluster architecture & networking</li>
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> Deployments, Services, ConfigMaps</li>
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> Helm charts & templating</li>
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> RBAC & network policies</li>
              </ul>
            </div>
            <div>
              <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Day 2: Production</p>
              <ul class="space-y-1.5 text-sm text-gray-700">
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> GitOps with Flux or ArgoCD</li>
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> Observability (Prometheus, Grafana, OTel)</li>
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> Policy enforcement with Kyverno</li>
                <li class="flex items-start gap-2"><span class="text-green-500">✓</span> CI/CD golden path templates</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Architecture -->
        <div class="bg-white rounded-xl p-6 border border-slate-100 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-purple-100 text-purple-700 text-xs font-bold px-3 py-1 rounded-full uppercase">Architecture</span>
            <h3 class="font-bold text-gray-900 text-lg">Platform Engineering Engagement</h3>
          </div>
          <p class="text-sm text-gray-600 mb-4">For teams building or evolving an internal developer platform.</p>
          <div class="grid md:grid-cols-2 gap-4">
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex items-start gap-2"><span class="text-green-500">✓</span> <strong>Platform maturity scorecard</strong> — where you are vs. where you need to be</li>
              <li class="flex items-start gap-2"><span class="text-green-500">✓</span> <strong>Architecture design</strong> — multi-cluster, multi-tenant, GitOps-native</li>
              <li class="flex items-start gap-2"><span class="text-green-500">✓</span> <strong>Golden path templates</strong> — CI/CD pipelines developers use on day one</li>
            </ul>
            <ul class="space-y-2 text-sm text-gray-700">
              <li class="flex items-start gap-2"><span class="text-green-500">✓</span> <strong>Security baseline</strong> — policies, RBAC, network segmentation, image signing</li>
              <li class="flex items-start gap-2"><span class="text-green-500">✓</span> <strong>Observability stack</strong> — metrics, logs, traces, dashboards, alerts</li>
              <li class="flex items-start gap-2"><span class="text-green-500">✓</span> <strong>Team handover</strong> — your team owns and maintains everything</li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Technologies -->
  <section class="py-16 bg-white">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Technologies I work with</h2>
        <div class="flex flex-wrap gap-3">
          {["Kubernetes", "OpenShift", "Helm", "Kustomize", "ArgoCD", "Flux", "Kyverno", "Backstage", "Crossplane", "Prometheus", "Grafana", "OpenTelemetry", "Istio", "Cilium", "cert-manager", "Gateway API"].map(tech => (
            <span class="bg-slate-100 text-slate-700 text-sm font-medium px-3 py-1.5 rounded-lg">{tech}</span>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Related Services -->
  <section class="py-16 bg-slate-50">
    <Container>
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related services</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/services/ai-integration/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">AI Integration & GPU Platforms</h3>
            <p class="text-xs text-gray-500 mt-1">Run AI workloads on Kubernetes</p>
          </a>
          <a href="/services/automation-strategy/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Automation Strategy & Ansible</h3>
            <p class="text-xs text-gray-500 mt-1">Automate cluster and app deployment</p>
          </a>
          <a href="/services/cloud-infrastructure/" class="bg-white rounded-xl p-5 border border-slate-100 hover:shadow-md transition-all hover:-translate-y-0.5 cursor-pointer">
            <h3 class="font-bold text-gray-900 text-sm">Cloud Infrastructure Design</h3>
            <p class="text-xs text-gray-500 mt-1">Cloud foundation for your platform</p>
          </a>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    <ServiceRelatedPosts keywords={["kubernetes", "k8s", "docker", "container", "openshift", "helm", "platform"]} />
  </Container>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 py-16">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-white">Ready to build your platform?</h2>
        <p class="text-slate-400 mt-3">30-minute discovery call. We look at your current setup, team size, and goals — then design the right engagement.</p>
        <a href="/contact/" class="mt-6 inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-all hover:scale-105 active:scale-95 cursor-pointer">Book a Free Call</a>
      </div>
    </Container>
  </section>
</Layout>
