---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Cta from "@components/cta.astro";

export const prerender = true;
export const lastModified = '2025-03-25';
---

<Layout title="Kubernetes & Containerization Workshops">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Kubernetes & Containerization Workshops</Fragment>
      <Fragment slot="desc">Build Scalable, Cloud-Native Infrastructure with Expert Kubernetes and Docker Training</Fragment>
    </Sectionhead>
    <p class="text-slate-500 mt-4">
      Learn to manage scalable, secure, and efficient cloud-native applications with hands-on Kubernetes and Docker training from Luca Berton.
    </p>
    <p class="text-slate-500 mt-4">
      <strong>Workshop Highlights:</strong>
      <ul class="list-disc list-inside mt-2">
        <li>Understanding Kubernetes architecture and components.</li>
        <li>Deploying and managing applications in Kubernetes.</li>
        <li>Building and optimizing Docker containers.</li>
        <li>Scaling and securing containerized applications.</li>
        <li>Monitoring Kubernetes clusters for performance and reliability.</li>
      </ul>
    </p>
    <Cta />
  </Container>
</Layout>