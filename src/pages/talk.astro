---
import Layout from "../layouts/Layout.astro";

// ============================================
// TALK CONFIGURATION — Edit this for each event
// ============================================
const talk = {
  title: "Lessons Learned Orchestrating Multi-Tenant GPUs on OpenShift AI",
  subtitle: "with NVIDIA KAI GH200",
  speaker: "Luca Berton",
  speakerTitle: "AI & Cloud Advisor | Co-author, Kubernetes Recipes",
  speakerImage: "/luca-hero.jpg",

  // Current event
  event: "KubeCon Europe 2026",
  eventDate: "24–27 March 2026",
  eventLocation: "RAI Amsterdam",
  eventUrl: "https://kccnceu2026.sched.com/event/2CVzs/lessons-learned-orchestrating-multi-tenant-gpus-on-openshift-ai-with-nvidia-kai-gh200-luca-berton-dell-technologies",
  accentColor: "blue", // blue | red | purple

  // Also presenting at
  otherEvents: [
    {
      name: "Red Hat Summit 2026",
      talk: "GPUs take flight: Safety-first multi-tenant Platform Engineering with NVIDIA and OpenShift AI",
      date: "June 2026",
      url: "/blog/red-hat-summit-2026/",
      color: "red",
    },
  ],

  // Talk topics / what attendees will learn
  takeaways: [
    "How to architect multi-tenant GPU isolation on OpenShift AI",
    "Real-world lessons from NVIDIA KAI GH200 orchestration",
    "Safety-first patterns for shared GPU infrastructure",
    "MIG partitioning and NVIDIA GPU Operator configuration",
    "Cost optimization strategies for GPU clusters",
    "Day-2 operations and monitoring with DCGM + Prometheus",
  ],

  // Related resources
  resources: [
    { label: "Kubernetes Recipes", url: "https://kubernetes.recipes/", icon: "📘" },
    { label: "GPU Cost Calculator", url: "/gpu-cost-calculator/", icon: "💰" },
    { label: "Book Signing Events", url: "/book-signing/", icon: "✍️" },
    { label: "KubeCon Side Events Guide", url: "/blog/kubecon-europe-2026-side-events/", icon: "🗓️" },
  ],

  // Kit.com form for lead capture
  kitFormId: "ce74a48bfa",
};

const colorMap: Record<string, Record<string, string>> = {
  blue: {
    gradient: "from-blue-950 via-blue-900 to-cyan-900",
    accent: "bg-blue-600",
    accentHover: "hover:bg-blue-700",
    accentLight: "bg-blue-500/10 text-blue-300 border-blue-500/20",
    accentBadge: "bg-blue-100 text-blue-800",
    ring: "ring-blue-500/30",
    shadow: "shadow-blue-600/25",
    text: "text-blue-400",
    glow: "rgba(59,130,246,0.15)",
  },
  red: {
    gradient: "from-red-950 via-red-900 to-orange-900",
    accent: "bg-red-600",
    accentHover: "hover:bg-red-700",
    accentLight: "bg-red-500/10 text-red-300 border-red-500/20",
    accentBadge: "bg-red-100 text-red-800",
    ring: "ring-red-500/30",
    shadow: "shadow-red-600/25",
    text: "text-red-400",
    glow: "rgba(239,68,68,0.15)",
  },
  purple: {
    gradient: "from-purple-950 via-purple-900 to-indigo-900",
    accent: "bg-purple-600",
    accentHover: "hover:bg-purple-700",
    accentLight: "bg-purple-500/10 text-purple-300 border-purple-500/20",
    accentBadge: "bg-purple-100 text-purple-800",
    ring: "ring-purple-500/30",
    shadow: "shadow-purple-600/25",
    text: "text-purple-400",
    glow: "rgba(147,51,234,0.15)",
  },
};

const c = colorMap[talk.accentColor] || colorMap.blue;
---

<Layout
  title={`${talk.title} — ${talk.event}`}
  description={`${talk.speaker} presents "${talk.title}" at ${talk.event}. ${talk.eventDate}, ${talk.eventLocation}.`}
>
  <main>

    <!-- Hero -->
    <section class={`relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-br ${c.gradient}`}>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(255,255,255,0.05),_transparent_60%)]"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-50"></div>

      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12 py-20 lg:py-28">
        <div class="grid lg:grid-cols-5 gap-12 lg:gap-16 items-center">

          <!-- Text (3 cols) -->
          <div class="lg:col-span-3 animate-fade-in">
            <div class="flex flex-wrap gap-3 mb-6">
              <span class={`inline-flex items-center rounded-full ${c.accentLight} border px-4 py-1.5 text-sm font-semibold`}>
                🎤 {talk.event}
              </span>
              <span class="inline-flex items-center rounded-full bg-white/10 text-white/70 border border-white/10 px-4 py-1.5 text-sm">
                {talk.eventDate}
              </span>
            </div>

            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight tracking-tight">
              {talk.title}
            </h1>
            {talk.subtitle && (
              <p class={`text-xl mt-3 font-medium ${c.text}`}>{talk.subtitle}</p>
            )}

            <div class="flex items-center gap-4 mt-8">
              <div class="w-14 h-14 rounded-full bg-white/10 ring-2 ring-white/20 overflow-hidden">
                <img src={talk.speakerImage} alt={talk.speaker} class="w-full h-full object-cover" loading="eager" />
              </div>
              <div>
                <div class="text-white font-semibold text-lg">{talk.speaker}</div>
                <div class="text-white/60 text-sm">{talk.speakerTitle}</div>
              </div>
            </div>

            <div class="mt-8 flex flex-col sm:flex-row gap-4">
              <a
                href="#get-slides"
                class={`inline-flex items-center justify-center px-7 py-3.5 ${c.accent} ${c.accentHover} hover:scale-[1.02] active:scale-[0.98] text-white font-semibold rounded-xl shadow-lg ${c.shadow} transition-all duration-200 text-base`}>
                Get the Slides & Resources
              </a>
              <a
                href={talk.eventUrl}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center px-7 py-3.5 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 hover:border-white/50 active:scale-[0.98] transition-all duration-200 text-base">
                View Session →
              </a>
            </div>
          </div>

          <!-- Quick Info Card (2 cols) -->
          <div class="lg:col-span-2 animate-fade-in-up">
            <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 space-y-5">
              <div>
                <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Event</div>
                <div class="text-white font-semibold">{talk.event}</div>
              </div>
              <div>
                <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Date</div>
                <div class="text-white font-semibold">{talk.eventDate}</div>
              </div>
              <div>
                <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Location</div>
                <div class="text-white font-semibold">{talk.eventLocation}</div>
              </div>
              <div>
                <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Speaker</div>
                <div class="text-white font-semibold">{talk.speaker}</div>
              </div>
              {talk.otherEvents.length > 0 && (
                <div class="border-t border-white/10 pt-4">
                  <div class="text-xs text-white/40 uppercase tracking-wider mb-2">Also presenting at</div>
                  {talk.otherEvents.map((evt) => (
                    <a href={evt.url} class="block text-white/80 hover:text-white text-sm transition-colors">
                      <span class="font-semibold">{evt.name}</span> · {evt.date}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- What You'll Learn -->
    <section class="py-20 px-6 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">What You'll Learn</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {talk.takeaways.map((item, i) => (
            <div class="flex items-start gap-4 bg-white rounded-xl p-5 border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 group">
              <div class={`shrink-0 w-8 h-8 ${c.accent} rounded-lg flex items-center justify-center text-white text-sm font-bold group-hover:scale-110 transition-transform duration-200`}>
                {i + 1}
              </div>
              <p class="text-gray-700 text-sm leading-relaxed">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Lead Capture Form -->
    <section id="get-slides" class="py-20 px-6 bg-white">
      <div class="max-w-xl mx-auto">
        <div class="text-center mb-10">
          <span class={`inline-flex items-center rounded-full ${c.accentBadge} px-4 py-1.5 text-sm font-semibold mb-4`}>
            📦 Free Resources
          </span>
          <h2 class="text-3xl font-bold text-gray-900">Get the Slides & Resources</h2>
          <p class="text-gray-600 mt-3">Enter your details below and I'll send you the presentation slides, architecture diagrams, and reference configurations.</p>
        </div>

        <form
          action={`https://luca-berton.kit.com/${talk.kitFormId}`}
          method="post"
          target="_blank"
          class="space-y-4"
        >
          <div>
            <label for="fields[first_name]" class="block text-sm font-medium text-gray-700 mb-1.5">First Name</label>
            <input
              type="text"
              name="fields[first_name]"
              id="fields[first_name]"
              placeholder="Your first name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200"
            />
          </div>
          <div>
            <label for="email_address" class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
            <input
              type="email"
              name="email_address"
              id="email_address"
              placeholder="you@company.com"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200"
            />
          </div>
          <button
            type="submit"
            class={`w-full px-7 py-4 ${c.accent} ${c.accentHover} hover:scale-[1.01] active:scale-[0.99] text-white font-bold rounded-xl shadow-lg ${c.shadow} transition-all duration-200 text-base`}
          >
            Send Me the Slides →
          </button>
          <p class="text-xs text-gray-400 text-center mt-2">No spam. Unsubscribe anytime.</p>
        </form>
      </div>
    </section>

    <!-- Resources -->
    <section class="py-16 px-6 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">Related Resources</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {talk.resources.map((res) => (
            <a href={res.url} class="flex items-center gap-3 bg-white rounded-xl p-4 border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 group" target={res.url.startsWith('http') ? '_blank' : undefined} rel={res.url.startsWith('http') ? 'noopener' : undefined}>
              <span class="text-2xl">{res.icon}</span>
              <span class="text-sm font-semibold text-gray-800 group-hover:text-blue-600 transition-colors">{res.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class={`py-20 px-6 bg-gradient-to-br ${c.gradient} relative overflow-hidden`}>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(255,255,255,0.05),_transparent_60%)]"></div>
      <div class="relative z-10 max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white">Let's Talk GPU Infrastructure</h2>
        <p class="text-white/70 mt-4 text-lg">Need help architecting multi-tenant GPU platforms? I work with regulated enterprises to build AI infrastructure that scales.</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://calendly.com/lucaberton"
            class="inline-flex items-center justify-center px-8 py-4 bg-white text-gray-900 font-bold rounded-xl hover:bg-gray-100 hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 shadow-lg"
          >
            Schedule a Call
          </a>
          <a
            href="/services/"
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/40 text-white font-semibold rounded-xl hover:bg-white/10 hover:border-white/60 active:scale-[0.98] transition-all duration-200"
          >
            View Services
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.6s ease-out both;
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.7s ease-out 0.2s both;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in, .animate-fade-in-up {
      animation: none;
    }
  }
</style>
