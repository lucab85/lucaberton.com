---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
export const prerender = true;
export const lastModified = '2025-03-25';
---

<Layout title="Terms and Conditions">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Terms and Conditions</Fragment>
      <Fragment slot="desc">Last Updated: March 2025</Fragment>
    </Sectionhead>

    <div class="prose max-w-5xl mx-auto mt-12 text-gray-700">
      <h2 id="introduction">1. Introduction</h2>
      <p>Welcome to <strong>Luca Berton Consulting</strong>. By accessing or using our website and services, you agree to comply with and be bound by these Terms and Conditions. If you do not agree, please do not use our services.</p>
      
      <h2 id="services">2. Services</h2>
      <p>We provide <strong>consulting, training, and digital content</strong> related to AI, automation, and cloud computing. The specifics of each service are outlined in our agreements with clients.</p>
      
      <h2 id="intellectual-property">3. Intellectual Property</h2>
      <p>All content on this website, including text, graphics, logos, and training materials, is the property of <strong>Luca Berton</strong> and protected by copyright laws. Unauthorized reproduction is strictly prohibited.</p>
      
      <h2 id="user-obligations">4. User Obligations</h2>
      <p>Users agree to use our services responsibly and in compliance with applicable laws. Any misuse, including unauthorized sharing of paid content, will result in account termination.</p>
      
      <h2 id="payments-refunds">5. Payments and Refunds</h2>
      <p>Payments for consulting and training services must be made in advance. Refunds are issued only under exceptional circumstances and at our discretion.</p>
      
      <h2 id="limitation-liability">6. Limitation of Liability</h2>
      <p>We provide services on an "<strong>as is</strong>" basis. <strong>Luca Berton Consulting</strong> is not liable for any indirect damages, including lost profits or data loss, resulting from service usage.</p>
      
      <h2 id="third-party-links">7. Third-Party Links</h2>
      <p>Our website may contain links to third-party services. We are not responsible for their content or privacy practices.</p>
      
      <h2 id="governing-law">8. Governing Law</h2>
      <p>These terms are governed by the <strong>laws of the Netherlands</strong>. Any disputes shall be resolved in Dutch courts.</p>
      
      <h2 id="amendments">9. Amendments</h2>
      <p>We reserve the right to modify these Terms and Conditions. Users will be notified of any significant changes.</p>
      
      <h2 id="contact-us">10. Contact Us</h2>
      <p>If you have any questions, please contact us at 
        <a href="mailto:info@lucaberton.com" class="text-blue-500 hover:underline" aria-label="Contact Luca Berton via email">
          info@lucaberton.com
        </a>.
      </p>
    </div>
  </Container>
</Layout>
