/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Prevent indexing of feed and PDF resources (they should not rank in search).
/rss.xml
  X-Robots-Tag: noindex, follow
  Content-Type: application/rss+xml; charset=utf-8

/slides/*
  X-Robots-Tag: noindex, follow

/pdf/*
  X-Robots-Tag: noindex, follow

# Site-wide security headers + tightened Content-Security-Policy.
# - 'unsafe-inline' is still required for Tailwind/JSON-LD inline scripts
#   and for inline event handlers used by some 3rd-party widgets.
# - Wildcards are scoped to known providers (analytics, Convertkit/MailerLite,
#   YouTube embeds, image CDNs).
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://*.convertkit.com https://*.kit.com https://*.mailerlite.com; img-src 'self' data: blob: https:; font-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://*.googletagmanager.com https://*.google-analytics.com https://f.convertkit.com https://*.convertkit.com https://*.kit.com https://*.mailerlite.com https://www.youtube.com https://s.ytimg.com https://platform.twitter.com https://cdn.jsdelivr.net; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://*.googletagmanager.com https://api.convertkit.com https://*.convertkit.com https://*.kit.com https://*.mailerlite.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://platform.twitter.com https://*.convertkit.com https://*.kit.com https://*.mailerlite.com; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests
